#!/bin/bash
PROGRAM_PATH=$(realpath -e "${0}")

# Remove shortest suffix matching "/*"
PROGRAM_DIR="${PROGRAM_PATH%/*}"


# - Option followed by : indicate a required argument to option
# - Option followed by :: indicate an optional argument to option
# - Comma (,) separates multiple long options
OPTIONS="+lh"
LONGOPTS="list,help"


function synopsis()
{
    cat <<EOF
  Execute a ${BOLD}frija${CLEAR} command.
EOF
}


function usage()
{
    cat <<EOF
${BOLD}Usage:${CLEAR} ${NAME} [COMMAND] [OPTION]
${BOLD}  or:${CLEAR}  ${NAME} [OPTION]
$(synopsis)

Additionally it is for instance possible to list available ${BOLD}frija${CLEAR} commands.

  -l, --list  list available ${BOLD}frija${CLEAR} commands and exit
  -h, --help  print this message
EOF
}


# Include core command line parsing support, common settings and
# utility functions.
# shellcheck source=./.core_preamble.bash
source "${PROGRAM_DIR}/.core_preamble.bash"


function list_commands()
{
    # Go to folder containing commands
    ! pushd "${PROGRAM_DIR}" &> /dev/null

    # Get list of all files in current folder as an array that start with
    # "frija-" and exclude all files that contain at least one "." after
    # the prefix, e.g. exclude all Emacs backup files
    GLOBIGNORE="frija*.*"

    declare -a commands
    commands=(frija*)

    # sed command regex that extracts all lines (inclusive) between
    # what is left of the comma and right of the comma. That is all
    # lines from "funcion synopsis()" to the "}" that ends the function
    local synopsisFunction=""
    local i
    # Iterate over the array, the '!' before the array causes it to expand
    # to the available indexes of the array (starting from 0)
    for i in "${!commands[@]}"; do
        # Replace any hyphens ("-") in command name with space, e.g.
        # "frija-list" is transformed to "frija list".
        name="${commands[$i]//-/ }"
        echo "${BOLD}${name}${CLEAR}"

        # Extract the commands synopsis function definition
        synopsisFunction=$(sed -n '/^function synopsis()$/,/^}$/p' "./${commands[$i]}")
        if [[ -n "${synopsisFunction}" ]]; then
            # Evaluate the synopsis function definition, overwriting
            # any previous definition
            eval "${synopsisFunction}"
            # Call the synopsis function to evaluate it, i.e. print synopsis
            synopsis
        else
            echo "  No description available."
        fi
    done
}


# Iterate over options in order and nicely split until we see --
while true; do
    echo "${1}"
    case "${1}" in
        -l|--list)
            list_commands
            exit 0
            ;;
        -h|--help)
            echo "${*}"
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done


echo "${*}"

# handle non-option argument
if [[ $# -eq 0 ]]; then
    print_error "A frija command is required." 4
fi

# Extract command name from given argument list
commandName="${1}"
# Move on to rest of argument list
shift

# Execute sub-command
exec "${PROGRAM_DIR}/frija-${commandName}" "${@}"
