            deps=${deps//$'\r'}
            rest=${rest//$'\r'}

            if [[ "${os}" == "#"* || "${os}" != "${operatingSystem}" ]]; then
                continue
            fi

            print_debug "os='${os}', " \
                        "kind='${kind}', " \
                        "deps='${deps}', " \
                        "rest='${rest}'"

            case "${kind}" in
                "${DEPENDENCY_LIB64}")
                    local path=""
                    # JSON does not allow trailing commas. Due to this we
                    # have to use this unusual construct where the read
                    # items are delayed one iteration. The end result is
                    # that we can do special treatment of the last item
                    # read (no trailing comma added).
                    local lastpath=""
                    local buildType="\${CMAKE_BUILD_TYPE}"
                    while read -d, -r path; do
                        if [[ -n "${lastpath}" ]]; then
                            # There is more than one path, but operate on
                            # previous path which makes it safe to append
                            # a comma to the output
                            cat <<EOF
                    "${depPath}/${BUILD_RESULT_DIR}/${buildType}/${lastpath}",
EOF
                        fi
                        lastpath="${path}"
                    done <<<"${deps}," # Add ',' to cover single-item case
                    # Last path read (or first if there is only one) is
                    # found in $lastPath. Send it to stdout without any
                    # trailing comma.
                    cat <<EOF
                    "${depPath}/${BUILD_RESULT_DIR}/${buildType}/${lastpath}"
EOF
                    ;;
            esac
        done <"${depFile}"
    fi

    print_debug_exit
}


function cmake_insert_dependency_external_libs()
{
    print_debug_enter "${@}"

    local name="${1}"
    local depPath="${2}"  # Linux path

    local depFile="${depPath}/${DEPENDENCY_FILE}"

    print_debug "depFile='${depFile}'"
    if [[ -r "${depFile}" ]]; then
        local os=""
        local kind=""
        local deps=""
        local rest=""
        print_debug "Reading '${kind}' from dependency file '${depFile}'"
        while read -r os kind deps rest; do
            # Strip any carriage returns from the read values
            os=${os//$'\r'}
            kind=${kind//$'\r'}
            deps=${deps//$'\r'}
            rest=${rest//$'\r'}

            if [[ "${os}" == "#"* || "${os}" != "${operatingSystem}" ]]; then
                continue
            fi

            print_debug "os='${os}', " \
                        "kind='${kind}', " \
                        "deps='${deps}', " \
                        "rest='${rest}'"

            case "${kind}" in
                "${DEPENDENCY_EXTERNAL_LIBS}")
                    local lib=""
                    local lastlib=""
                    # JSON does not allow trailing commas. Due to this we
                    # have to use this unusual construct where the read
                    # items are delayed one iteration. The end result is
                    # that we can do special treatment of the last item
                    # read (no trailing comma added).
                    while read -d, -r lib; do
                        if [[ -n "${lastlib}" ]]; then
                            # There is more than one path, but operate on
                            # previous path which makes it safe to append
                            # a comma to the output
                            cat <<EOF
                    "${lastlib}",
EOF
                        fi
                        lastlib="${lib}"
                    done <<<"${deps}," # Add ',' to cover single-item case

                    # Last path read (or first if there is only one) is
                    # found in $lastPath. Send it to stdout without any
                    # trailing comma.
                    cat <<EOF
                    "${lastlib}"
EOF
                    ;;
            esac
        done <"${depFile}"
    fi

    print_debug_exit
}


function cmake_format_external_build_dependencies()
{
    local externalDeps="${1}"
    local indent="${2}"

    local message=""

    # Since JSON requires that the last item in a sequence does not
    # end with a comma each new entry written must first write a
    # comma, a newline and then the field. In this way we ensure the
    # last line is always without a comma at the end. After we have
    # iterated over any build environment entries an empty line is
    # written.

    if [[ -z "${externalDeps}" ]]; then
        # No external dependencies requested; just write an empty line
        # and return
        echo ""
        return
    fi

    local rest=""

    local locale=""
    local version=""
    local configs=""
    IFS=";" read -r locale version configs rest <<< "${externalDeps}"

    if [[ -z "${version}" ]]; then
        message="Corrupt external build configuration specification "
        message+="'${externalDeps}'; missing version as well as build "
        message+="configuration and external build tools."
        print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
    fi


    if [[ -z "${configs}" ]]; then
        # No build configuration specified; nothing to do
        return
    fi

    # Common base path to the locale repo
    local repopath="${_VOLLA_PATH}/${locale}"

    if [[ "${version}" == "${NON_VERSION}" ]]; then
        # Read directly from filesystem
        local confFile=""
        for confFile in ${configs//,/ }; do
            local confFile="${repopath}/${BUILD_CONF}/${confFile}"
            if [[ -f "${confFile}" ]]; then
                local param=""
                local value=""
                while read -r param value rest; do
                    if [[ "${param}" == "#"* ]]; then
                        # Skip comments
                        continue
                    fi
                    # Append each param with value read to output
                    # file. This is done by writing a comma
                    # immediately followed by a newline and then the
                    # JSON-formatted parameter with value WITHOUT any
                    # newline at the end.
                    echo -n -e ",\\n${indent}\"${param}\": \"${value}\""
                done < "${confFile}"
            else
                message="Requested build configuration file '${confFile}' "
                message+="in locale '${locale}' "
                message+="(referenced by the input file) could not be found."
                break
            fi
        done
    else
        # Check if given tag exist in locale repo
        if git -C "${repopath}" show-ref --tags "${version}" --quiet; then
            # Read from given version in Git repo
            local confFile=""
            for confFile in ${configs//,/ }; do
                # Build Git version specifier
                confFile="${version}:${BUILD_CONF}/${confFile}"

                # Check if requested external configs file exist
                if git -C "${repopath}" cat-file -e "${confFile}"; then
                    local param=""
                    local value=""
                    while read -r param value rest; do
                        # Append each param with value read to output file
                        echo -n -e ",\\n${indent}\"${param}\": \"${value}\""

                        # Use Process Substitution ('<(command)') to
                        # get output from a command into a while loop
                        # without creating a subshell executing the
                        # while loop
                    done < <(git -C "${repopath}" cat-file "${confFile}")
                else
                    message="Requested build configuration file '${confFile}' "
                    message+="in locale '${locale}' "
                    message+="(referenced by the input file) "
                    message+="could not be found."
                    break;
                fi
            done
        else
            message="Input file refers to tag '${version}' in "
            message+="locale '${locale}', alas this tag does not exist!"
        fi
    fi

    if [[ -n "${message}" ]]; then
        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    fi

    # Write the final newline
    echo ""
}


# TODO: Generate a file directly in CMake format instead that just
# sets the variables?
function cmake_generate_json()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"          # Composite/Repo Name (+ optional Version)
    local parameters="${2}"          # E.g. csproj or sln
    local dependencies="${3}"        # dep-A;dep-B;dep-C;...
    local repoKind="${4}"            # E.g. app, lib, ...
    local toolDependencies="${5:-}"  # Implicitly tell shellcheck it is optional

    print_debug "1: '${1}'"
    print_debug "2: '${2}'"
    print_debug "3: '${3}'"
    print_debug "4: '${4}'"
    print_debug "5: '${5:-}'"

    print_debug "repoFolder='${repoFolder}'"
    print_debug "parameters='${parameters}'"
    print_debug "dependencies='${dependencies}'"
    print_debug "repoKind='${repoKind}'"
    print_debug "toolDependencies='${toolDependencies}'"

    local currentPath=""
    currentPath=$(pwd)
    local repoPath="${currentPath}/${repoFolder}"
    local generatedRoot="${currentPath}/${generatedFolder}"

    print_debug "currentPath='${currentPath}'"
    print_debug "repoPath='${repoPath}' (${currentPath}/${repoFolder})"
    print_debug "generatedRoot='${generatedRoot}'"

    print_debug "Checking if '${repoPath}/.git' exists..."

    if [[ -e "${repoPath}/.git" ]]; then
        local branchName=""
        branchName=$(get_branch_name "${repoPath}")
    else
        local message="Cannot find repo '${repoFolder}'; please make sure "
        message+="it has been cloned, for instance by using the "
        message+="${BOLD}frija clone${CLEAR} command, aborting."

        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    fi

    local composite=""
    local name=""
    local version=""
    local sha=""

    # There is a bug in Bash 4.2 that can not handle certain
    # characters when do string replacement, for instance "." and "@".
    # As a workaround sed command is used to do the needed
    # replacement.
    #
    # Extract composite, repo name, and version from given path. To be
    # able to extract version and SHA replace first all '__' with '/'
    # and then read() command will split on '/'.
    #
    # Note that $repoFolder is guaranteed to not contain any spaces
    # due to how it is constructed.
    #
    # shellcheck disable=SC2046
    IFS='/' read -r composite name version sha<<<\
       $(sed -e "s,__,/,"<<<"${repoFolder}")

    print_debug "composite='${composite}'"
    print_debug "name='${name}'"
    print_debug "version='${version}'"
    print_debug "sha='${sha}'"

    # Save repo $composite, $name, and $version since they will be
    # overwritten several times.
    #local repoComposite="${composite}"
    local repoName="${name}"
    local repoVersion="${version}"
    local repoSha="${sha}"

    local destination="${repoFolder}/${repoName}${CMAKE_DEPENDENCY_FILE_SUFFIX}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    #
    # TODO: Double-check that there are no problems with this. Also
    # does MSBuild-variant support this?
    destination=$(get_echo_destination "${destination}")

    local message="  Generating ${BOLD}JSON${CLEAR} dependency file "
    message+="'${BOLD}${destination}${CLEAR}'..."

    print_debug "currentPath='${currentPath}'"
    print_debug "repoPath='${repoPath}'"

    local metaversion=""
    if [[ -n "${repoSha}" ]]; then
        metaversion="${repoVersion}${repoSha}"
    fi
    metaversion="${metaversion:-${repoVersion:-${NON_VERSION}}}"

    # Force overwrite of any existing file even when 'noclobber'
    # option is set using operator ">|"
    cat <<EOF >| "${destination}"
{
    "systemName": "${SYS_NAME}",
    "name": "${composite}/${repoName}${CMAKE_DEPENDENCY_FILE_SUFFIX}",
    "version": "${metaversion}",
    "description": "Dependencies for ${composite}/${repoName}",
    "repokind": "${repoKind}",
    "dependencies": [
EOF

    # Append dependencies as properties
    {
        local dependencyRootPath=""
        local dependencyBuildPath=""
        if [[ -n "${dependencies}" ]]; then
            local deltapath=""
            local dep=""
            local lastdep=""
            while read -d, -r dep; do
                # Strip any carriage returns from the read value
                dep=${dep//$'\r'}

                # FIXME: Is vp needed!??!
                #
                # Split on ';'
                local composite=""
                local version=""
                local name=""
                local vp=""
                local rest=""
                IFS=';' read -r composite version name vp rest<<<"${dep}"
                deltapath=$(make_destination "${composite}" \
                                             "${name}" \
                                             "${version}")
                print_debug "deltapath='${deltapath}'"
                dependencyRootPath="${currentPath}/${deltapath}"
                dependencyBuildPath="${dependencyRootPath}/Build"

                print_debug "dependencyRootPath='${dependencyRootPath}'"
                print_debug "dependencyBuildPath='${dependencyBuildPath}'"

                # Due to that JSON disallows trailing commas we have
                # to ensure that there are no such trailing commas
                if [[ -n "${lastdep}" ]]; then
                    # Close previous object since on first iteration
                    # $lastdep is an empty string, but on all other
                    # iterations it is a non-empty string
                    cat <<EOF
            ]
        },
EOF
                fi

                local repoVariable="${name^^}"
                if [[ "${vp}" == "${VARIATION_POINT}" ]]; then
                    # We have found a variation point and must thus
                    # ensure the name used in the generated file is
                    # generic and not specific
                    repoVariable=$(transformVariationPoint "${repoVariable}")
                fi

                # Output current object (which may be the last one)
                cat <<EOF
        {
            "${repoVariable}": "${dependencyBuildPath}",
            "${repoVariable}-ROOT": "${dependencyRootPath}",
            "${repoVariable}-INCLUDES": [
EOF
                # For C and C++ projects, paths to include files
                # introduced by the repo must be listed
                cmake_insert_dependency_includes "${name}" \
                                                 "${dependencyRootPath}"

                cat <<EOF
            ],
            "${repoVariable}-LIB64": [
EOF
                # For C and C++ projects, dependencies to
                # repo-specific folder containing libraries provided
                # by the repo must be listed
                cmake_insert_dependency_lib64 "${name}" \
                                              "${dependencyRootPath}"

                cat <<EOF
            ],
            "${repoVariable}-EXTLIBS": [
EOF
                # For C and C++ projects, dependencies to external
                # libraries introduced by the repo must be listed
                cmake_insert_dependency_external_libs "${name}" \
                                                      "${dependencyRootPath}"

                # Marker to keep track of if there are more than one iteration.
                lastdep="${dep}"
            done <<<"${dependencies}," # Add ',' to cover single-item case

            if [[ -n "${lastdep}" ]]; then
                # Finally close the last object (which may be the
                # first one if there is only one object)
                cat <<EOF
            ]
        }
EOF
            fi
        fi
            cat <<EOF
    ],
EOF
    } >> "${destination}"


    # Extract tool definitions used during the build from the given
    # dependency. As a side effect TOOL_COMMANDS, TOOL_LIBS, and
    # TOOL_INCLUDES are updated based on content of $toolDependencies
    # or cleared if corresponding is empty.

    extract_tool_dependencies "${currentPath}" "${toolDependencies}"

    # Assume that having a tool key is a precondition for having libs.
    local toolKeys="${!TOOL_COMMANDS[*]}"
    print_debug "toolKeys='${toolKeys}'"

    cat <<EOF >> "${destination}"
    "tools": [
EOF
    # Ensure there are no trailing commas as JSON standard disallows
    # them
    local lastToolKey=""
    if [[ -n "${toolKeys}" ]]; then
        {
            # For every key in the associative array $TOOL_COMMANDS...
            local toolPath=""
            for key in $toolKeys; do
                toolPath="${currentPath}/${TOOL_COMMANDS[$key]}"
                toolLib="${currentPath}/${TOOL_LIBS[$key]}"
                toolInc="${currentPath}/${TOOL_INCS[$key]}"

                if [[ -n "${lastToolKey}" ]]; then
                    # Close previous tool object
                    cat <<EOF
        },
EOF
                fi

                cat <<EOF
        {
            "FRIJA_${key}": "${toolPath}",
            "FRIJA_${key}_LIB": "${toolLib}",
            "FRIJA_${key}_INCLUDE": "${toolInc}"
EOF
                lastToolKey="${key}"
            done

            # Close last tool object
            cat <<EOF
        }
EOF
        } >> "${destination}"
    fi

    cat <<EOF >> "${destination}"
    ],
EOF

    # Append rest of JSON to output file.
    local tarPrefix="${SYS_NAME}_${branchName}/\${BUILD_ID}/${composite}/"
    tarPrefix+="${buildType}/${repoName}"

    local repoIdentity=""
    repoIdentity=$(git_repo_identity "${repoPath}" \
                                     "${composite}" \
                                     "${repoName}" \
                                     "${SYS_NAME}")

    local indent="        "
    # shellcheck disable=SC2129
    cat <<EOF >> "${destination}"
    "buildProperties": {
${indent}"frijaRepoIdentity": "${repoIdentity}",
${indent}"frijaRoot": "${repoPath}",
${indent}"frijaBuildRoot": "${repoPath}/Build",
${indent}"frijaBuildResultRoot": "${repoPath}/BuildResult",
${indent}"frijaBuildResult": "${repoPath}/BuildResult/${buildType}",
${indent}"frijaPrepareRoot": "${repoPath}/Prepare",
${indent}"frijaArchiveRoot": "${repoPath}/Archive",
${indent}"frijaGeneratedRoot": "${generatedRoot}",
${indent}"frijaVersionsFile": "${repoPath}/Archive/${buildType}_versions.txt",
${indent}"frijaTarPrefix": "${tarPrefix}",
${indent}"frijaTarTransform": "s|^${buildType}|${tarPrefix}|",
EOF

    local field="frijaVersionCommand"
    local value="${_FENSALIR_HOME}/frija-version"
    {
        echo -n "${indent}\"${field}\": \"${value}\""

        # Format external build dependencies that are not stored in a
        # repo
        #print_message "Calling cmake_format_external_build_dependencies"
        cmake_format_external_build_dependencies "${externalDeps}" "${indent}"
        #print_message "Done"
    } >> "${destination}"


    cat <<EOF >> "${destination}"
    }
}
EOF
}

#
# CMAKE
################################################################################



################################################################################
# MSBUILD
#

# Redirects an echo destination to /dev/stdout if DRY_RUN is enabled.
# Note that if no argument is given then /dev/stdout is returned.
function get_echo_destination()
{
    local result=""
    if [[ "${DRY_RUN}" == "y" ]]; then
        result="/dev/stdout"
    elif [[ "${1-}" == "" ]]; then
        result="/dev/stdout"
    else
        result="${1}"
    fi

    echo "${result}"
}


# Definition of how to use a tool defined by a repo; that is name of
# tool, interface file folders (for instance include file folders for
# C/C++ based repos) as well as link time dependencies to folder
# containing any libraries needed when using the output from the tool
# (e.g. protoc compiler gerenate source code that depend on the protoc
# runtime library).
declare -r TOOLS_FILE="${_FRIJA_TOOLS_FILE}"

# Extract tool definitions used during the build from the given
# dependency. These are then used when for instance the corresponding
# Directory.Build.props file is created.
function extract_tool_dependencies()
{
    local repoPath="${1}"
    local toolDependencies="${2}"

    # Ensure global associative arrays TOOL_COMMANDS, TOOL_LIBS, and
    # TOOL_INCLUDES are empty before we fill them with information.
    TOOL_COMMANDS=( )
    TOOL_LIBS=( )
    TOOL_INCS=( )

    while read -d, -r toolDep; do
        # Strip any carriage returns from the read value
        toolDep=${toolDep//$'\r'}

        if [[ -z "${toolDep}" ]]; then
            # Guard against empty $toolDep, that is no tool
            # dependencies exist.
            continue;
        fi

        local composite=""
        local version=""
        local name=""
        local rest=""
        # Parse content of toolDep where fields are split on ';'
        IFS=';' read -r composite version name rest<<<"${toolDep}"

        # shellcheck disable=SC2155
        local repoSubPath=$(make_destination "${composite}" \
                                             "${name}" \
                                             "${version}")

        local toolRepoPath="${repoPath}/${repoSubPath}"
        toolRepoPath="${toolRepoPath}/${TOOLS_FILE}"

        if [[ ! -r "${toolRepoPath}" ]]; then
            local message="Could not read from '${toolRepoPath}'; "
            message+="ensure file exists and is readable and/or update "
            message+="${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file and re-run "
            message+="${BOLD}frija fetch${CLEAR} or "
            message+="${BOLD}frija clone${CLEAR}, aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
        fi

        local os=""
        local variable=""
        local path=""
        local lib=""
        local include=""
        while read -r os variable path lib include rest; do
            # Strip any carriage returns from the read values
            os=${os//$'\r'}
            variable=${variable//$'\r'}
            path=${path//$'\r'}
            lib=${lib//$'\r'}
            include=${include//$'\r'}
            rest=${rest//$'\r'}

            if [[ "${os}" == "#"* ]] || [[ -z "${os}" ]]; then
                # Skip to next entry since it is a commented or empty line
                continue
            fi

            if [[ "${os}" != "${operatingSystem}" ]]; then
                # Skip to next entry since it is not intended for our OS
                continue
            fi

            print_debug "os='${os}', " \
                        "variable='${variable}', " \
                        "path='${path}', " \
                        "lib='${lib}', " \
                        "include='${include}', " \
                        "rest='${rest}'"


            # Parse line we read from $toolRepoPath and ensure that
            # there are no duplicate data.

            if [[ ! -v "TOOL_COMMANDS[$variable]" ]]; then
                TOOL_COMMANDS[$variable]="${repoSubPath}/${path}"
            else
                message="Duplicate definitions of tool variable "
                message+="${BOLD}'${variable}'${CLEAR} found; "
                message+="'${TOOL_COMMANDS[$variable]}' and '${path}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi

            if [[ ! -v "TOOL_LIBS[$variable]" ]]; then
                TOOL_LIBS[$variable]="${repoSubPath}/${lib}"
            else
                message="Duplicate definitions of tool lib variable "
                message+="${BOLD}'${variable}'${CLEAR} found; "
                message+="'${TOOL_LIBS[$variable]}' and '${path}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi

            if [[ ! -v "TOOL_INCS[$variable]" ]]; then
                TOOL_INCS[$variable]="${repoSubPath}/${include}"
            else
                message="Duplicate definitions of tool include variable "
                message+="${BOLD}'${variable}'${CLEAR} found; "
                message+="'${TOOL_INCLUDES[$variable]}' and '${path}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi

        done < "${toolRepoPath}"
    done <<<"${toolDependencies}," # Add ',' to cover single-item case
}


function insert_dependency_includes()
{
    local name="${1}"
    local linuxDepPath="${2}"
    local dependencyPath="${3}"  # OS-dependent path
    local vp="${4}"

    local dependencyFile="${linuxDepPath}/${DEPENDENCY_FILE}"
    local dependencies=""
    local -r element="${name^^}-INCLUDES"
    local -r INCS="incs"

    if [[ "${vp}" == "${VARIATION_POINT}" ]]; then
        # We have found a variation point and must thus
        # ensure the name used in the generated file is
        # generic and not specific
        element=$(transformVariationPoint "${element}")
    fi

    print_debug "dependencyFile='${dependencyFile}'"
    if [[ -r "${dependencyFile}" ]]; then
        print_debug "dependencyFile found!"
        while read -r os kind deps rest; do
            # Strip any carriage returns from the read values
            os=${os//$'\r'}
            kind=${kind//$'\r'}
            deps=${deps//$'\r'}
            rest=${rest//$'\r'}

            if [[ "${os}" == "#"* || "${os}" != "${operatingSystem}" ]]; then
                continue
            fi

            print_debug "os='${os}', " \
                        "kind='${kind}', " \
                        "deps='${deps}', " \
                        "rest='${rest}'"

            if [[ "${kind}" == "${INCS}" ]]; then
                while read -d, -r path; do
                    if [[ -n "${dependencies}" ]]; then
                        dependencies="${dependencies}${OS_PATH_SEPARATOR}"
                    fi

                    # Prepend a separator before we do any OS-specific
                    # transformation of the found path.
                    path="/${path}"

                    if [[ "${os}" == "${WINDOWS_OS}" ]]; then
                        # Replace all forward slashes with backward
                        # slashes using built-in string replace;
                        # ${foo//what-to-replace/replacement} and
                        # 'what-to-replace' is a '/' and this must be
                        # escaped using a backslash, hence '\/' and
                        # the replacement is a backslash that must be
                        # escaped, hence '\\'.
                        path="${path//\//\\}"
                    fi

                    dependencies="${dependencies}${dependencyPath}${path}"
                done <<<"${deps}," # Add ',' to cover single-item case
            fi
        done <"${dependencyFile}"
    fi

    if [[ -n "${dependencies}" ]]; then
        echo "    <${element}>${dependencies}</${element}>"
    fi
}


function msbuild_format_external_build_dependencies()
{
    local externalDeps="${1}"
    local indent="${2}"

    local message=""

    if [[ -z "${externalDeps}" ]]; then
        # No external dependencies requested, just return
        return
    fi

    local rest=""

    local locale=""
    local version=""
    local configs=""
    IFS=";" read -r locale version configs rest <<< "${externalDeps}"

    if [[ -z "${version}" ]]; then
        message="Corrupt external build configuration specification "
        message+="'${externalDeps}'; missing version as well as build "
        message+="configuration and external build tools."
        print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
    fi

    if [[ -z "${configs}" ]]; then
        # No build configuration specified; nothing to do
        return
    fi

    # Common base path to the locale repo
    local repopath="${_VOLLA_PATH}/${locale}"

    if [[ "${version}" == "${NON_VERSION}" ]]; then
        # Read directly from filesystem
        local confFile=""
        for confFile in ${configs//,/ }; do
            local confFile="${repopath}/${BUILD_CONF}/${confFile}"
            if [[ -f "${confFile}" ]]; then
                local param=""
                local value=""
                while read -r param value rest; do
                    if [[ "${param}" == "#"* ]]; then
                        # Skip comments
                        continue
                    fi
                    # Append each param with value read to output file
                    echo "${indent}<${param^^}>${value}</${param^^}>"
                done < "${confFile}"
            else
                message="Requested build configuration file '${confFile}' "
                message+="in locale '${locale}' "
                message+="(referenced by the input file) could not be found."
                break
            fi
        done
    else
        # Check if given tag exist in locale repo
        if git -C "${repopath}" show-ref --tags "${version}" --quiet; then
            # Read from given version in Git repo
            local confFile=""
            for confFile in ${configs//,/ }; do
                # Build Git version specifier
                confFile="${version}:${BUILD_CONF}/${confFile}"

                # Check if requested external configs file exist
                if git -C "${repopath}" cat-file -e "${confFile}"; then
                    local param=""
                    local value=""
                    while read -r param value rest; do
                        # Append each param with value read to output file
                        echo "${indent}<${param}>${value}</${param}>"

                        # Use Process Substitution ('<(command)') to
                        # get output from a command into a while loop
                        # without creating a subshell executing the
                        # while loop
                    done < <(git -C "${repopath}" cat-file "${confFile}")
                else
                    message="Requested build configuration file '${confFile}' "
                    message+="in locale '${locale}' "
                    message+="(referenced by the input file) "
                    message+="could not be found."
                    break;
                fi
            done
        else
            message="Input file refers to tag '${version}' in "
            message+="locale '${locale}', alas this tag does not exist!"
        fi
    fi

    if [[ -n "${message}" ]]; then
        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    fi
}

function msbuild_generate()
{
    local repoFolder="${1}"        # Composite/Repo Name (+ optional Version)
    local parameters="${2}"        # E.g. csproj or sln
    local dependencies="${3}"      # dep-A;dep-B;dep-C;...
    local repoKind="${4}"          # E.g. app, lib, ...
    local toolDependencies="${5}"  # Optional tools dependencies; empty if none
    local externalDeps="${6}"      # External dependencies to use

    # External dependencies are dependencies to files stored outside
    # of the repo structure. This means that those files are outside
    # of the scope for version controll by Frija. The content of the
    # $externalDeps parameter follow the format (as a single word
    # without any spaces)
    #
    # locale;version,deps-file*,build-tools-file*
    #
    # Where "deps-file*" means zero or more occurrences of deps-file
    # separated by ';' and "build-tools-file*" means zero or more
    # occurrences of build-tools-file separated by ';'.
    #
    # THIS function is only interested in the locale, version and
    # deps-file list fields and ignores the build-tools-file list.

    print_debug "Dependencies are '${dependencies}'"

    local destination=""
    destination=$(get_echo_destination "${repoFolder}/${MSBUILD_PROPERTY_FILE}")


    local message="  Generating ${BOLD}MSBuild${CLEAR} Property file "
    message+="'${BOLD}${destination}${CLEAR}'..."

    # Extract composite, repo name, and version from given path
    IFS='/' read -r composite name version<<<"${repoFolder}"

    # Save repo name since the variables 'composite', 'name', and 'version'
    # will be overwritten several times.
    local repoName="${name}"

    local repoPath=""
    local linuxRepoPath=""
    local currentPath=""
    local linuxCurrentPath=""

    if [[ "${operatingSystem}" == "${WINDOWS_OS}" ]]; then
        # Get Windows variant of current working directory
        currentPath=$(pwd -W)
        linuxCurrentPath=$(pwd)

        repoPath="${currentPath}/${repoFolder}"
        # Replace all forward slashes with backward slashes using
        # built-in string replace; ${foo//what-to-replace/replacement}
        # and 'what-to-replace' is a '/' and this must be escaped
        # using a backslash, hence '\/' and the replacement is a
        # backslash that must be escaped, hence '\\'.
        repoPath="${repoPath//\//\\}"
    else
        currentPath=$(pwd)
        linuxCurrentPath="${currentPath}"
        repoPath="${currentPath}/${repoFolder}"
    fi
    linuxRepoPath="${linuxCurrentPath}/${repoFolder}"


    # Force overwrite of any existing file
    cat <<EOF >| "${destination}"
<?xml version="1.0" encoding="utf-8" ?>
<!--
  ***************************************
  This is a generated file - Do Not Edit!
  This is a generated file - Do Not Store in Git!
  This is a generated file - Do Not Version Control!
  This is a generated file - Do Not Transfer Anywhere!
  ***************************************
-->
<Project>
  <ImportGroup Label="Shared">
    <!--
        Repo-specific settings that have to be applied BEFORE this file
        is evaluated.
    -->
    <Import Condition="Exists('SolutionProperties.props')"
            Project="SolutionProperties.props" />
  </ImportGroup>

  <PropertyGroup>
    <!--
        Force target platform to x64.
    -->
    <Platform>x64</Platform>

EOF

    # Append dependencies as properties
    {
        local dependencyRootPath=""
        local dependencyBuildPath=""
        if [[ -n "${dependencies}" ]]; then
            cat <<EOF
  <!--
      Dependencies to Build folder in other repos represented as
      properties named using repo-name in all uppercase. Root of
      these repos get properties with the same name with an additional
      \"-ROOT\" suffix. Other kinds of paths within a repo get
      corresponding suffixes, e.g. \"-INCLUDES\" for include file path
      needed when building a C++ project.
  -->
EOF

            local deltapath=""
            while read -d, -r dep; do
                # Strip any carriage returns from the read value
                dep=${dep//$'\r'}

                # Split on ';'
                local composite=""
                local version=""
                local name=""
                local vp=""
                local rest=""
                IFS=';' read -r composite version name vp rest<<<"${dep}"
                deltapath=$(make_destination "${composite}" \
                                             "${name}" \
                                             "${version}")
                print_debug "deltapath='${deltapath}'"
                dependencyRootPath="${currentPath}/${deltapath}"
                linuxDepRootPath="${linuxCurrentPath}/${deltapath}"
                dependencyBuildPath="${dependencyRootPath}/Build"

                print_debug "dependencyRootPath='${dependencyRootPath}'"
                print_debug "linuxDepRootPath='${linuxDepRootPath}'"
                print_debug "dependencyBuildPath='${dependencyBuildPath}'"

                if [[ "${operatingSystem}" == "Windows" ]]; then
                    dependencyRootPath="${dependencyRootPath//\//\\}"
                    dependencyBuildPath="${dependencyBuildPath//\//\\}"
                fi

                print_debug "dependencyRootPath='${dependencyRootPath}'"
                print_debug "dependencyBuildPath='${dependencyBuildPath}'"

                local repoVariable="${name^^}"
                if [[ "${vp}" == "${VARIATION_POINT}" ]]; then
                    # We have found a variation point and must thus
                    # ensure the name used in the generated file is
                    # generic and not specific
                    repoVariable=$(transformVariationPoint "${repoVariable}")
                fi

                cat <<EOF
    <${repoVariable}>${dependencyBuildPath}</${repoVariable}>
    <${repoVariable}-ROOT>${dependencyRootPath}</${repoVariable}-ROOT>
EOF

                # For C++ projects paths to include files in other
                # repos might need to be inserted.
                insert_dependency_includes "${name}" \
                                           "${linuxDepRootPath}" \
                                           "${dependencyRootPath}" \
                                           "${vp}"
            done <<<"${dependencies}," # Add ',' to cover single-item case
            echo ""
            echo ""
        fi
    } >> "${destination}"

    local branchName=""
    branchName=$(get_branch_name "${linuxRepoPath}")

    cat <<EOF >> "${destination}"
    <!--
        Known kinds of repos as well as kind assigned to current repo.
    -->
    <FrijaAppKind>${APP_REPO}</FrijaAppKind>
    <FrijaLibKind>${LIB_REPO}</FrijaLibKind>
    <FrijaInterfaceKind>${INF_REPO}</FrijaInterfaceKind>
    <FrijaToolKind>${TOL_REPO}</FrijaToolKind>
    <FrijaPluginKind>${PLG_REPO}</FrijaPluginKind>
    <FrijaDataKind>${DTA_REPO}</FrijaDataKind>
    <FrijaRepoKind>${repoKind}</FrijaRepoKind>


EOF

    # Extract tool definitions used during the build from the given
    # dependency. As a side effect TOOL_COMMANDS, TOOL_LIBS, and
    # TOOL_INCLUDES are updated based on content of $toolDependencies
    # or cleared if corresponding is empty.
    extract_tool_dependencies "${linuxCurrentPath}" "${toolDependencies}"

    # Assume that having a tool key is a precondition for having libs.
    local toolKeys="${!TOOL_COMMANDS[*]}"
    print_debug "toolKeys='${toolKeys}'"

    if [[ -n "${toolKeys}" ]]; then
        {
            cat <<EOF
    <!--
        Dependencies to Build Tools represented as properties.
    -->
EOF
            # For every key in the associative array $TOOL_COMMANDS...
            local toolPath=""
            for key in $toolKeys; do
                toolPath="${currentPath}/${TOOL_COMMANDS[$key]}"
                toolPath="${toolPath//\//\\}"

                echo "    <${key}>${toolPath}</${key}>"

                toolLib="${TOOL_LIBS[$key]}"
                if [[ -n "${toolLib}" ]]; then
                    toolLib="${currentPath}/${toolLib}"
                    toolLib="${toolLib//\//\\}"
                    echo "    <${key}LibPath>${toolLib}</${key}LibPath>"
                fi
            done
            echo ""
            echo ""
        } >> "${destination}"
    fi

    # Build include path for tools
    local toolIncPath=""
    local toolIncKeys="${!TOOL_INCS[*]}"
    print_debug "toolIncKeys='${toolIncKeys}'"

    cat <<EOF >> "${destination}"
    <!--
        Include paths for Build Tools as property.
    -->
EOF

    if [[ -n "${toolIncKeys}" ]]; then
        # For every key in the associative array $TOOL_INCS...
        for key in $toolIncKeys; do
            if [[ -n "${toolIncPath}" ]]; then
                toolIncPath="${toolIncPath}${OS_PATH_SEPARATOR}"
            fi
            toolIncPath="${toolIncPath}${currentPath}/${TOOL_INCS[$key]}"
        done
        toolIncPath="${toolIncPath//\//\\}"
    fi

    # shellcheck disable=SC2129
    cat <<EOF >> "${destination}"
    <ToolIncludePaths>${toolIncPath}</ToolIncludePaths>


EOF

    # Append rest of XML to output file.
    #
    # NOTE: All backslashes must be escaped due to that we also want
    # to expand variables, e.g. $repoPath and so on.
    #
    # shellcheck disable=SC2129
    cat <<EOF >> "${destination}"
    <!--
        Redirect where build results ends up
    -->
    <FrijaRoot>${repoPath}</FrijaRoot>
    <FrijaBuildRoot>${repoPath}\\Build</FrijaBuildRoot>
    <FrijaArchiveRoot>${repoPath}\\Archive</FrijaArchiveRoot>

    <BaseIntermediateOutputPath>${repoPath}\\Build\\obj\\\$(AssemblyName)</BaseIntermediateOutputPath>
    <IntDir>\$(FrijaBuildRoot)\\Intermediate\\\$(Platform)\\\$(Configuration)\\</IntDir>
    <IntermediateOutputPath>\$(IntDir)obj\\</IntermediateOutputPath>
    <OutDir>\$(FrijaBuildRoot)\\\$(Configuration)\\</OutDir>
    <OutputPath>\$(FrijaBuildRoot)\\\$(Configuration)\\</OutputPath>


    <!--
        Where generated source code from for instance Google proto-files
        are placed. Also used by clean target.
    -->
    <GeneratedPath>\$(FrijaBuildRoot)\\${GENERATED}\\</GeneratedPath>


    <!--
        Properties used by prepare and clean targets.
    -->
    <FrijaLinuxArchiveRoot>${linuxRepoPath}/Archive</FrijaLinuxArchiveRoot>
    <VersionsFile>\$(FrijaArchiveRoot)\\\$(Configuration)_versions.txt</VersionsFile>
    <TarPrefix>${SYS_NAME}_${branchName}/6666/\$(CSCI)/\$(Configuration)/\$(AssemblyName)</TarPrefix>
    <TarTransform>s|^\$(Configuration)|\$(TarPrefix)|</TarTransform>
    <VollaCommandRoot>${_FENSALIR_HOME}</VollaCommandRoot>
    <SystemName>${SYS_NAME}</SystemName>


    <!--
        Properties defining external dependencies for this repo.
    -->
EOF


    local repoIdentity=""
    repoIdentity=$(git_repo_identity "${repoPath}" \
                                     "${composite}" \
                                     "${repoName}" \
                                     "${SYS_NAME}")

    # Format Git information about repo
    #
    # shellcheck disable=SC2129
    cat <<EOF >> "${destination}"


    <!--
        Properties defining Git information for this repo.
    -->
    <FrijaRepoIdentity>${repoIdentity}</FrijaRepoIdentity>
EOF

    # Format external build dependencies that are not stored in a repo
    #
    # shellcheck disable=SC2129
    msbuild_format_external_build_dependencies "${externalDeps}" "    " >> "${destination}"

    # shellcheck disable=SC2129
    cat <<EOF >> "${destination}"
  </PropertyGroup>


  <!--

      This item group contain dependencies to all DLLs used directly
      and indirectly by projects we depend on, i.e. secondary,
      tertiary, etc. dependency chains (DLLs that in turn depends on
      DLLs that depends on DLLs and so on).

     If it is empty it should be because there are no repos we
     directly depend on.
  -->
  <ItemGroup>
EOF

    # Append instructions to copy DLLs from projects in other repos we
    # depend on.
    #
    # NOTE: All backslashes must be escaped. This is also true for all
    # $-characters since they should be written to the output file.
    # Otherwise the sequence '$(...)' would have triggered Bash to try
    # to execute whatever is within the parentheses, which is not what
    # we want.
    #
    # NOTE: The sequence ${...} is intentionally NOT escaped since it
    # triggers an expansion of a Bash variable, e.g. '${name^^}' which
    # expands the variable 'name' in all uppercase.
    {
        if [[ -n "${dependencies}" ]]; then
            declare -i counter
            counter=1
            while read -d, -r dep; do
                # Strip any carriage returns from the read value
                dep=${dep//$'\r'}

                # Split on ';'
                IFS=';' read -r composite version name rest<<<"${dep}"

                # Ensure empty separator line is ONLY written on all
                # iterations EXCEPT first.
                ((counter > 1)) && echo ""
                ((counter++))

                cat <<EOF
    <None Include="\$(${name^^})\\\$(Configuration)\\*.dll">
      <Link>%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="\$(${name^^})\\\$(Configuration)\\*.pdb">
      <Link>%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
EOF
            done <<<"${dependencies}," # Add ',' to cover single-item case
        fi
    } >> "${destination}"


    # Append rest of XML to output file.
    #
    # NOTE: All backslashes must be escaped. This is also true for all
    # $-characters since they should be written to the output file.
    # Otherwise the sequence '$(...)' would have triggered Bash to try
    # to execute whatever is within the parentheses, which is not what
    # we want.
    cat <<EOF >> "${destination}"
  </ItemGroup>


  <!--
      Common compilation options for all Release builds of C# projects.
  -->
  <PropertyGroup Condition="'\$(Configuration)' == 'Release'">
    <PathMap>\$(BaseIntermediateOutputPath)\\\$(Platform)\\\$(Configuration)=.</PathMap>
  </PropertyGroup>


  <!--
      Common compilation and linking options for all Release builds of
      C++ projects.
  -->
  <ItemDefinitionGroup Condition="'\$(Configuration)' == 'Release'">
    <Link>
      <!--
          Store only filename of PDB file within .EXE/.DLL for
          deterministic builds.
      -->
      <AdditionalOptions>/PDBALTPATH:%_PDB% %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>


  <!--
       Ensure IntermediateOutputPath exist. If this path does not exist
       once the build has started you will receive warning MSB3101
       "Could not write to state file".
  -->
  <Target Name="FrijaCreateIntermediateOutoutPath"
          BeforeTargets="PrepareForBuild">
    <MakeDir Directories="\$(IntermediateOutputPath)"
             Condition="!Exists('\$(IntermediateOutputPath)')" />
  </Target>


  <!--
       Default empty implementation of prepare target.
  -->
  <Target Name="prepare" />


  <!--
       Enhance clean target so it becomes a deep-clean target.
  -->
  <Target Name="CleanBuildFolder"
          BeforeTargets="CoreClean">
    <RemoveDir Condition="Exists(\$(OutputPath))"
               Directories="\$(OutputPath)"
               ContinueOnError="true" />
    <RemoveDir Condition="Exists(\$(BaseIntermediateOutputPath))"
               Directories="\$(BaseIntermediateOutputPath)"
               ContinueOnError="true" />
    <RemoveDir Condition="Exists(\$(IntDir))"
               Directories="\$(IntDir)"
               ContinueOnError="true" />
    <RemoveDir Condition="Exists(\$(GeneratedPath))"
               Directories="\$(GeneratedPath)"
               ContinueOnError="true" />
  </Target>


  <ImportGroup Label="Shared">
    <!--
        Repo-specific settings that have to be applied AFTER this file
        is evaluated, e.g. to override settings.
    -->
    <Import Condition="Exists('Post.Directory.Build.props')"
            Project="Post.Directory.Build.props" />
  </ImportGroup>
</Project>
EOF


    if [[ -r "${repoFolder}/NuGet.config" ]]; then
        # shellcheck disable=SC2155
        local cmd="$(type -p cmd.exe)"
        if [[ -z "${cmd}" ]]; then
            local message="Could not find CMD.EXE in PATH, aborting."
            print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
        fi

        local locale=""
        local version=""
        local configs=""
        local seciList=""
        local rest=""

        # shellcheck disable=SC2034
        IFS=";" read -r locale version configs seciList rest <<< \
           "${externalDeps}"

        # Common base path to the locale repo
        local localePath="${_VOLLA_PATH}/${locale}"

        # Input file to MSBuild.exe command
        local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"
        local inputFile="${repoFolder}/${repoName}.${type}"

        declare -a command=()

        # Restore NuGet files using MSBuild. Note that "//c" is used
        # instead of "/c" as argument to cmd.exe due to that Git Bash
        # implementation contain a workaround for how true Windows
        # binaries are invoked from within Bash. This means that "//c"
        # must be used instead of "/c" to get a "/c" sent to
        # cmd.exe...
        local message="Restoring NuGet packages in ${repoFolder} "
        message+="using MSBuild..."
        command=("${SINGLE}" "${message}" \
                             "${localePath}" \
                             "${version}" \
                             "${seciList}" \
                             "" \
                             "${cmd}" "//c" \
                             "${_FENSALIR_HOME}/run_windows_command.bat" \
                             MSBuild.exe \
                             "-t:restore" \
                             "-p:RestorePackagesConfig=true" \
                             "${inputFile}")
        run_isolated "${command[@]}"

        local nugets=("${repoFolder}/Packages/"*)
        if [[ "${nugets[0]}" == "${repoFolder}/Packages/"* ]] \
               || (( ${#nugets[@]} == 0 ))
        then
            local message="Something went wrong when restoring NuGet packages "
            message+="to ${BOLD}${repoFolder}/Packages${CLEAR} folder "
            message+="since none were restored, aborting."
            print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
        else
            print_message "    Done!"
        fi
    else
        local message="  No NuGet packages to restore! "
        message+="(NuGet.config file does not exist)"

        print_message "${message}"
    fi
}

#
# MSBUILD
################################################################################



################################################################################
# Dot graph
#

function dotgraph_generate()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"          # Composite/Repo Name (+ optional Version)
    local target="${2}"
    local dependencies="${3}"
    local repoKind="${4}"            # E.g. app, lib, ...
    local toolDependencies="${5:-}"  # Implicitly tell shellcheck it is optional
    local externalDeps="${6}"        # External dependencies to use


    print_message "Generating dependency graph Dot-file for ${repoFolder}..." 2

    local destination=""
    destination="${_FRIJA_WS_PATH}/${repoFolder}"

    dotgraph_generate_header "${destination}"

    dotgraph_append_body "${destination}" "${repoFolder}" "${dependencies}"

    dotgraph_generate_footer "${destination}"
}


function dotgraph_generate_header()
{
    # Where to write
    local destination="${1}"

    destination+="/${FRIJA_GENERATED_DEPENDENCY_GRAPH}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    destination=$(get_echo_destination "${destination}")

    # Force overwrite of any existing file even when 'noclobber'
    # option is set using operator ">|"
    echo "digraph {" >| "${destination}"
}


function dotgraph_append_body()
{
    print_debug_enter "${@}"

    local destination="${1}"
    local repoFolder="${2}"
    local dependencies="${3}"

    destination+="/${FRIJA_GENERATED_DEPENDENCY_GRAPH}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    local echoDestination=""
    echoDestination=$(get_echo_destination "${destination}")

    local dependencyId=""
    local depPath=""
    local dep=""
    for dep in ${dependencies//,/ }; do
        local dependencyComposite=""
        local dependencyVersion=""
        local dependencyName=""
        local rest=""

        # Parse content of an individual dependency where fields are
        # split on ';'
        IFS=';' read -r \
           dependencyComposite \
           dependencyVersion \
           dependencyName \
           rest<<<"${dep}"

        local destinationRepo=""
        destinationRepo=$(make_destination "${dependencyComposite}" \
                                           "${dependencyName}" \
                                           "${dependencyVersion}")

        # Append to Dot-file
        echo "\"${repoFolder}\" -> \"${destinationRepo}\"" \
             >> "${echoDestination}"
    done
}


function dotgraph_generate_footer()
{
    # Where to write
    local destination="${1}"
    destination+="/${FRIJA_GENERATED_DEPENDENCY_GRAPH}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    destination=$(get_echo_destination "${destination}")

    echo "}" >> "${destination}"
}

#
# Dot graph
################################################################################


function generate_global_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"         # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"    # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local repoFolder="${2}"
    local dependencies="${3}"

    local destination=""
    local message=""

    case "${tool}" in
        make)
            destination="${_FRIJA_WS_PATH}/Makefile"

            if [[ -z "${MAKE_FOUND}" ]]; then
                message="${BOLD}Generating header${CLEAR} for global Makefile "
                message+="in ${BOLD}${_FRIJA_WS_PATH##*/}${CLEAR} "
                print_message "${message}"

                # Insert header for the generated global Makefile
                make_generate_header "${destination}"
                MAKE_FOUND="y"
            fi

            message="${BOLD}Appending${CLEAR} to global Makefile "
            message+="for ${BOLD}${repoFolder}${CLEAR} "
            print_message "${message}"

            make_append_body "${destination}" "${repoFolder}"
            ;;
        cmake)
            ;;
        msbuild)
            ;;
        dotgraph)
            destination="${_FRIJA_WS_PATH}"

            if [[ -z "${DOTGRAPH_FOUND}" ]]; then
                message="${BOLD}Generating header${CLEAR} for global "
                message+="dependency graph in "
                message+="${BOLD}${_FRIJA_WS_PATH##*/}${CLEAR} "
                print_message "${message}"

                # Insert header for the generated global dependency graph
                dotgraph_generate_header "${destination}"
                DOTGRAPH_FOUND="y"
            fi

            message="${BOLD}Appending${CLEAR} to global dependency graph "
            message+="for ${BOLD}${repoFolder}${CLEAR} "
            print_message "${message}"

            dotgraph_append_body "${destination}" \
                                 "${repoFolder}" \
                                 "${dependencies}"
            ;;
        *)
            message="Unsupported build tool '${tool}' for '${destination}', "
            message+="aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
    esac
}


function generate_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"         # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"    # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"
    local dependencies="${3}"
    local repoKind="${4}"         # E.g. app, lib, ...
    local toolDependencies="${5}" # If none, then it is empty
    local externalDeps="${6}"     # External dependencies to use if any

    local message=""

    case "${tool}" in
        make)
            make_generate "${destination}" "${parameters}" \
                          "${dependencies}" "${repoKind}" \
                          "${toolDependencies}" "${externalDeps}"
            ;;
        cmake)
            cmake_generate "${destination}" "${parameters}" \
                           "${dependencies}" "${repoKind}" \
                           "${toolDependencies}" "${externalDeps}"
            ;;
        msbuild)
            msbuild_generate "${destination}" "${parameters}" \
                             "${dependencies}" "${repoKind}" \
                             "${toolDependencies}" "${externalDeps}"
            ;;
        dotgraph)
            dotgraph_generate "${destination}" "${parameters}" \
                              "${dependencies}" "${repoKind}" \
                              "${toolDependencies}" "${externalDeps}"
            ;;
        *)
            message="Unsupported build tool '${tool}' for '${destination}', "
            message+="aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
    esac
}


function generate_footer_dispatch()
{
    if [[ -n "${MAKE_FOUND}" ]]; then
        message="${BOLD}Writing footer${CLEAR} to global Makefile "
        message+="in ${BOLD}${_FRIJA_WS_PATH##*/}${CLEAR}"
        print_message "${message}"

        # Insert footer for the generated global Makefile
        make_generate_footer "${_FRIJA_WS_PATH}/Makefile"
    elif [[ -n "${DOTGRAPH_FOUND}" ]]; then
        message="${BOLD}Writing footer${CLEAR} to global dependency "
        message+="graph in ${BOLD}${_FRIJA_WS_PATH##*/}${CLEAR}"
        print_message "${message}"

        # Insert footer for the generated dependency graph file
        dotgraph_generate_footer "${_FRIJA_WS_PATH}"
    fi
}


########
# Iterate over the lines in the input file and act on each line
# depending on $os and $vcs fields.

print_separator
print_message "Reading from ${inFile} and generating files in repos..."
print_message "Using system name '${BOLD}${SYS_NAME}${CLEAR}'"
print_double_separator

processedReposFlag=""
foundOperatingSystem=""
declare -a skippedOperatingSystems=()

# Now read line by line from the input file and build the repos!
#
# The -r flag causes read command to not treat backslash character as
# an escape character
#
# Any leading whitespace is automatically stripped by read command
while read -r line; do
    if [[ -z "${line}" ]]; then
        # Skip to next entry since it is an empty line
        continue
    fi

    if [[ "${line}" == "#"* ]]; then
        # Parse line and assign to global variable if comment contains
        # a known key-value pair
        _frija_parse_repos_file_comment_line "${line}"
        continue
    else
        ensure_all_metafields_set

        # Parse line and assign fields to global variables
        _frija_parse_repos_file_line "${line}"
    fi

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        skippedOperatingSystems+=("${os}")
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    if [[ "${tool}" == "none" ]]; then
        # Skip repos that does not have any build tool
        continue
    fi

    if [[ "${dependencies}" == "none" ]]; then
        # When there are no dependencies, set it to an empty string.
        dependencies=""
    fi

    if [[ "${toolDependencies}" == "none" ]]; then
        # When there are no tool dependencies, set it to an empty string.
        toolDependencies=""
    fi

    # If we reach this point then there is at least one row that
    # matches current operating system. Save this fact in this
    # variable so an error message can adapt to this situation
    #
    # shellcheck disable=SC2034
    foundOperatingSystem="${os}"

    # shellcheck disable=SC2154
    case "${vcs}" in
        git)
            if [[ "${uri}" =~ ${GIT_REPO_PATTERN} ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination=$(make_destination "${composite}" \
                                               "${repoName}" \
                                               "${version}")
            else
                message="Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is "
                message+="'${uri}' and pattern is '${GIT_REPO_PATTERN}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi
            ;;
        *)
            message="Unsupported VCS: '${vcs}' for '${uri}' found in input "
            message+="file '${inFile}', aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            ;;
    esac

    print_debug "repoName='${repoName}', destination='${destination}'"

    # Override given tool in repos file with 'dotgraph' to force
    # output of dependency information in Graphviz Dot format.
    if [[ -n "${generateGraph}" ]]; then
        tool="dotgraph"
    fi

    generate_global_dispatch "${tool}" \
                             "${destination}" \
                             "${dependencies}"

    if [[ -n "${REPO_SUBPATH}" ]] && [[ "${allRepos}" == "n" ]]; then
        # REPO_SUBPATH is set, this means that A) we are somewhere
        # below _FRIJA_WS_PATH and B) we are within a repo.
        #
        # NOTE: If inside a repo and 'all' option is set, then it will
        # override this behavior and force all repos to be operated on
        # regardless.
        print_debug "REPO_SUBPATH='${REPO_SUBPATH}'"
        if [[ "${REPO_SUBPATH}" != "${destination}"* ]]; then
            print_debug "destination='${destination}'"
            # In this case we should ONLY operate on repos where
            # REPO_SUBPATH and destination matches, which means that
            # for all other repos we should just skip it and move on
            # to the next one.
            continue;
        fi
    fi


    message="${BOLD}Generating${CLEAR} build-files for "
    message+="${BOLD}${buildType^^}${CLEAR} in ${BOLD}${destination}${CLEAR} "
    print_message "${message}"

    print_debug "generate ('${tool}' " \
                "'${buildType}' " \
                "'${destination}' " \
                "'${dependencies}')"

    generate_dispatch "${tool}" \
                      "${destination}" \
                      "${dependencies}" \
                      "${repoKind}" \
                      "${toolDependencies}" \
                      "${externalDeps}"

    # If we reach this point, at least one repo has been processed
    processedReposFlag="y"
done < "${inFile}"

if [[ "${MAKE_FOUND}" == "y" ]]; then
    generate_footer_dispatch
else
    generate_footer_dispatch
fi


if [[ -z "${processedReposFlag}" ]]; then
    if [[ "${allRepos}" == "n" ]]; then
        print_no_repo_match_error "${REPO_SUBPATH}" \
                       "${inFile}" \
                       "No files were generated for any repos!"
    else
        print_os_error "skippedOperatingSystems" \
                       "${inFile}" \
                       "No files were generated for any repos!"
    fi
else
    print_double_separator
    print_message "Generation of files completed successfully!"
    if [[ -z "${_FRIJA_SCRIPTED_BUILD:-}" ]]; then
        print_message
        print_double_separator
        print_message "Now use command"
        print_message "  ${BOLD}frija build --help${CLEAR}"
        print_message "to get instructions for how to proceed."
        message="(If you have multiple .repos-files in the workspace then you "
        message+="␀must choose which to use using '--input' flag)"
        print_message "${message}"
        print_message
    fi
fi
