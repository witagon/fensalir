#!/bin/bash --norc

_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")

function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "t:aVi:F:h"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "type:,all,verbose-build,input:,force-os:,help,graph,verbose,debug,dry-run"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Generate files Frija dependency files needed for building.
EOF
}


_FRIJA_BUILD_RELEASE="RELEASE"
_FRIJA_BUILD_DEBUG="DEBUG"
_FRIJA_DEFAULT_BUILD_TYPE="${_FRIJA_BUILD_DEBUG}"


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -t|--type)
            result="${_FRIJA_BUILD_RELEASE} ${_FRIJA_BUILD_DEBUG}"
            ;;
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            if [[ -z "${result}" ]]; then
                local message="Current Frija Workspace is corrupt; "
                message+="no ${REPO_LIST_EXTENSION} file found"
                _frija_completion_help_message "${message}"
            fi
            ;;
        -F|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


# Name of optional file detailing compile time dependencies when there
# is a dependency to a prebuilt repo containing libraries and/or
# includes.
_FRIJA_DEPENDENCY_FILE="Dependencies.data"

# Name of optional file detailing tool definitions for a tool-repo.
# That is name of the tool and where to find it within the repo, any
# libraries or include files needed when using the tool, and so on.
_FRIJA_TOOLS_FILE="content.tools"


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  The files generated by this command differ dependening on the target
  build system, for instance MSBuild and CMake. However what is common
  is the kind of configuration data inserted into the generated files;
  variables with paths to repos there is a dependency to.

  In each dependent repo (a repo other repos have dependencies to) there
  must be a
    ${BOLD}${_FRIJA_DEPENDENCY_FILE}${CLEAR}
  file in its root to make it visible to other repos if the repo contain
  prebuilt binaries and/or provide header files for C/C++ libraries or ALI
  files for Ada interface to such libraries. This file details dependency
  information needed by the dependent repos. Content of this file is used
  when creating the variables listed below. These variables are always in
  all uppercase and prefixed with ${BOLD}FRIJA_${CLEAR} and the name of the
  repo.

  For instance, if there is a dependency to repo ${BOLD}fnord-gazonk_42${CLEAR} then
  the following variables are created
    ${BOLD}FNORD-GAZONK_42${CLEAR}       Absolute search path to build folder
                            For CMake debug or release subfolder is included,
                            for MSBuild it is excluded

    ${BOLD}FNORD-GAZONK_42-ROOT${CLEAR}  Absolute search path to the root of the repo

  For repos containing C/C++ code or libraries three additional
  variables are created
    ${BOLD}FNORD-GAZONK_42-INCLUDES${CLEAR}   Absolute search path to include folders
                                 within the repo
    ${BOLD}FNORD-GAZONK_42-LIB64${CLEAR}      Absolute search path to the root folder
                                 of the repo
    ${BOLD}FNORD-GAZONK_42-EXTLIBS${CLEAR}    List of additional dependencies that
                                 should be included when linking, for
                                 instance "m" for libm.so dependency

  ${BOLD}Note:${CLEAR} There is one exception to the "reponame" rule above,, and that
        is when the dependee repo is a variant point (actual repo
        differs between configurations). For these repos the variable
        name is the name of the repo where the variant portion at the
        end is removed and thus a generic name is created. For
        instance if repo xyzzy_13 is a variant repo then the variable
        name used is "XYZZY" instead of "XYZZY_13". Due to this no
        other repo within the corresponding composite (e.g. "Bitbucket
        project" or similar concept) may be named "xyzzy".

  If there is a dependency to some kind of tool needed during the
  build process then the corresponding variables get their name from
  the file ${BOLD}content.tools${CLEAR} stored in the root of the tool
  repo. This file specify the keyword variable to use for each tool in
  the repo.

  For instance the tool ${BOLD}protoc${CLEAR} stored in google-protobuf repo specify
  (among other things) that the keyword variable to use for the tool
  is "ProtoCompiler". This result in the following variables

    ${BOLD}FRIJA_ProtoCompiler${CLEAR}           Absolute path to binary to use

    ${BOLD}FRIJA_ProtoCompiler_LIB${CLEAR}       Absolute path to folder containing
                                    libs to link to
    ${BOLD}FRIJA_ProtoCompiler_INCLUDE${CLEAR}   Absolute path to folder containing
                                    header files

  In addition to the above variables these are always inserted into
  the configuration file
    ${BOLD}frijaRoot${CLEAR}             Absolute path to root of current repo

    ${BOLD}frijaBuildRoot${CLEAR}        Absolute path to build folder excluding
                            debug/release subfolder

    ${BOLD}frijaPrepareRoot${CLEAR}      Absolute path to the prepare folder

    ${BOLD}frijaArchiveRoot${CLEAR}      Absolute path to the archive folder

    ${BOLD}frijaGeneratedRoot${CLEAR}    Absolute path to the folder continaing files
                            generated by the build system in the repo

    ${BOLD}frijaVersionsFile${CLEAR}     Absolute path to text file listing content of
                            installation archive file

    ${BOLD}frijaTarPrefix${CLEAR}        Name of TAR installation archive to create
                            excluding extension

    ${BOLD}frijaTarTransform${CLEAR}     Pattern to use in TAR command for transforming
                            search paths when adding files to the
                            installation archive. This pattern contain a
                            placeholder (\${BUILD_ID}) where the build
                            version should be inserted

    ${BOLD}frijaVersionCommand${CLEAR}   Absolute path to command to use for obtaining
                            the version to insert in the TAR transform
                            expression


  ${UNDERLINE_ON}Background${UNDERLINE_OFF}

  The complete build process consist of the stages
  ${BOLD}GENERATE${CLEAR}   Create non-version controlled files needed to build, for instance
               inter-repo dependency files, makefiles (generated by CMake),
               and so on

  ${BOLD}BUILD${CLEAR}      Actual compilation stage; which may also generate
             non-version controlled files like files generated
             from Google proto-files

  ${BOLD}PREPARE${CLEAR}    Copy files from Build folder to Prepare folder in a structure that
               is similar to how it should be installed on the target system

  ${BOLD}ARCHIVE${CLEAR}    Create installation archive based on content in Prepare folder and
                            place it within the Archive folder

  In addition to the above stages, there is also
  ${BOLD}CLEAN${CLEAR}      Clean build artifacts so a rebuild will trigger re-creation of all
               binaries, including any re-generation and compilation of any
               Google proto-files and so on; i.e. files produced by the build
               stage. Optionally files produced by the generate and prepare
               stages can also be cleaned.

  This command is thus the first stage which generate any necessary
  (and non-version-controlled) files for the build command. These
  files contain for instance inter-repo dependency information as well
  as adding default "glue" to adapt the repos for the following
  stages. For some build systems like CMake this stage also calls on
  CMake to generate the choosen flavor of makefiles for release or debug.

  If a file is generated for a repo it is always placed in the repo
  root folder. The name of any generated file differ depending on the
  build system used; CMake, MSBuild, and None are currently supported.

  For ${BOLD}CMake${CLEAR} its name is the repo name followed by ${BOLD}${CMAKE_DEPENDENCY_FILE_SUFFIX}${CLEAR}.
  For ${BOLD}MSBuild${CLEAR} its name is ${BOLD}Directory.Build.props${CLEAR}.

  ${BOLD}Note:${CLEAR} You usually only need to run the generate stage once! There is
        one exception to this rule and that is whenever CMake is used,
        files generated by CMake differ depending on if you want to
        build for release or debug and if any CMake-scripts are modifed this
        will most likely affect what is generated.

  That is, if you clone another repo or change the input file for the
  follwing stages, ${BOLD}then${CLEAR} you need to re-run generate. Or
  if you know that CMake is used to build some or all of the repos
  referenced from the input file and you want to switch between
  release and debug, then you also need to rerun the generate stage.

${BOLD}
  Behavior of this command varies slightly depending on where you are
  within generic folder structure shown below${CLEAR}

    frija
      |
      +-- WORKSPACE
                |
                +-- COMPOSITE-NAME
                               |
                               +-- REPO

  The basic rule of thumb is that when you are within a REPO then this
  command is ONLY applied to that repo, otherwise it is applied to
  all applicable repos listed in the input file.

  This default rule-of-thumb-behavior can be overridden when you are
  within REPO (or sub-folder to REPO); you give the -a/--all option on
  the command line.

  The -a/--all option is an escape mechanism that allow you to apply
  the command to all repos listed in the input file regardless of
  where you are within the WORKSPACE directory tree.

${BOLD}Options:${CLEAR}
  -t[TYPE],           generate build input files for given TYPE (release build
   --type[=TYPE]        is default). For local build systems that also must
                        generate build files before they can be built (for
                        instance CMake) this command will also trigger
                        generation of such vuild files.

                        ${BOLD}Note:${CLEAR} The TYPE parameter only matter when generated
                              build files differ depending on TYPE. Again CMake
                              is an example of when this is the case.

  -a,                 apply command to all applicable repos listed in input
   --all                file; default or given on the command line via
                        -i/--input option. This option is applied by default
                        when outside of a repo (but still within a workspace).

  -V,                 turn on verbose build, provided underlying build system
   --verbose-build      have support for controlling it in the generate phase.
                        Default behavior is whatever default behavior the
                        underlying build system have.

  -iFILE,             apply operation to repos listed in FILE
   --input=FILE

  -h,                 print this message
   --help

  --graph             generate dependency graph in Graphviz Dot format

                        ${BOLD}Note:${CLEAR} When using this option this command will only
                              generate dot files and no Frija dependency files.

  --verbose           verbose output

  --debug             enable debug printouts sent to stderr

  --dry-run           do not execute commands with side effects, just echo them

  --force-os=OS       force command to assume given OS instead of detected OS

${BOLD}Examples:${CLEAR}
  ${BOLD}$ ${_FRIJA_USAGE_NAME} --type=RELEASE --verbose-build${CLEAR}

  This command will generate necessary files for a release build and
  turn on verbose build (provided the underlying build system supports
  it) across repos listed in the default input file.

${BOLD}See also:${CLEAR}
  (frija) ${BOLD}archive${CLEAR}, ${BOLD}build${CLEAR}, ${BOLD}clean${CLEAR}, ${BOLD}prepare${CLEAR} commands for further information

EOF
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${_FENSALIR_HOME}/.preamble.bash"

# Include generic VCS support.
#
# shellcheck source=./.vcs_functions.bash
source "${_FENSALIR_HOME}/.vcs_functions.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


# Configure Bash options
_frija_configure_bash


SYS_NAME=""

MAKE_FOUND=""
DOTGRAPH_FOUND=""

DRY_RUN="n"
VERBOSE="n"
DEBUG="n"
allRepos="n"
buildType=""
verboseBuild=""
generateGraph=""
inFile=""
osOverride=""
operatingSystem="${OPERATING_SYSTEM}"


# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -t|--type)
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_BUILD_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_BUILD_DEBUG}" \
                                 "${_FRIJA_BUILD_RELEASE}"
            shift  # Move to next option
            ;;
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -V|--verbose-build)
            ensure_option_not_set "Verbose build" "${verboseBuild}"
            verboseBuild="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -F|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            operatingSystem="${osOverride}"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        --graph)
            generateGraph="y"
            shift  # Move to next option
            ;;
        --verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        --debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        --dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done


# Ensure $buildType has an assigned value
buildType="${buildType:-${_FRIJA_DEFAULT_BUILD_TYPE}}"

case "${buildType}" in
    "${_FRIJA_BUILD_DEBUG}")
        buildType="${DEBUG_DIR}"
        ;;
    "${_FRIJA_BUILD_RELEASE}")
        buildType="${RELEASE_DIR}"
        ;;
esac

################################################################################
# Consistency checks
################################################################################


# Ensure we have an input file and that it has a valid extension
inFile=$(ensure_input_file "${inFile}")

# TODO: Replace with parsing of metadata embedded in comment section
# of .repos file.
#
# In case user has provided an input file with an explicit search path
# we must remove it in order to obtain the system name from the input
# filename. And also remove $REPO_LIST_EXTENSION from it.
SYS_NAME="${inFile##*/}"
SYS_NAME="${SYS_NAME%%${REPO_LIST_EXTENSION}}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


print_debug "verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}"


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_WS_PATH, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_WS_PATH or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
_frija_locate_workspace
REPO_SUBPATH=$(cwd_in_workspace_repo_folder_p "")
cd "${_FRIJA_WS_PATH}"


####################
# Note: See .preamble.bash for more information about the run function!
####################

declare -A TOOL_COMMANDS=( )
declare -A TOOL_LIBS=( )
declare -A TOOL_INCS=( )


# Definition of dependencies introduced by a repo; that is interface
# file folders (for instance include file folders for C/C++ based
# repos) as well as link time dependencies to external libraries
# introduced by the repo
declare -r DEPENDENCY_FILE="${_FRIJA_DEPENDENCY_FILE}"

# Kinds of dependencies supported by the dependency file
# $DEPENDENCY_FILE
DEPENDENCY_INCLUDES="incs"
DEPENDENCY_LIB64="lib64"
DEPENDENCY_EXTERNAL_LIBS="extlibs"

#source "${_FENSALIR_HOME}/.vcs_functions.bash"

# shellcheck source=./.seci_parser.bash
source "${_FENSALIR_HOME}/.seci_parser.bash"

################################################################################
# GNU Make
#

function make_generate()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"          # Composite/Repo Name (+ optional Version)
    local target="${2}"
    local dependencies="${3}"
    local repoKind="${4}"            # E.g. app, lib, ...
    local toolDependencies="${5:-}"  # Implicitly tell shellcheck it is optional
    local externalDeps="${6}"        # External dependencies to use


    ######################################################################
    # Generate the per-repo file $FRIJA_GENERATED_MAKEFILE_FRAGMENT
    # with dependency information.
    ######################################################################

    print_message "Generating ${FRIJA_GENERATED_MAKEFILE_FRAGMENT}..." 2
    make_generate_fragment "${repoFolder}" \
                           "${parameters}" \
                           "${dependencies}" \
                           "${repoKind}" \
                           "${toolDependencies}"

    local destination=""
    local echoDestination=""


    ######################################################################
    # Generate the per-repo Makefile.
    ######################################################################

    destination="${_FRIJA_WS_PATH}/${repoFolder}/Makefile"

    make_generate_header "${destination}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    echoDestination=$(get_echo_destination "${destination}")

    # Append to Makefile
    cat <<EOF >> "${echoDestination}"

include \$(FRIJA_MAKEFILE_EXTRAS)
include \$(_FENSALIR_GNUMAKE_PATH)/Makefile.reporules

EOF

    make_generate_footer "${destination}"
}


function make_generate_header()
{
    # Where to write
    local destination="${1}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    destination=$(get_echo_destination "${destination}")

    # Force overwrite of any existing file even when 'noclobber'
    # option is set using operator ">|"
    cat <<EOF >| "${destination}"
################################################################################
#  NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE
################################################################################
#
# This Makefile requires GNU Make 4.4 or later.

# This Makefile is generated by Frija ('frija generate' command). Any
# edits made to this file will be lost next time 'frija generate'
# command is executed.
#
# For further information please read the instructions found at the
# top of the Makefile.preamble file found in the Fensalir repo.
#
################################################################################
#  NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE
################################################################################

include \$(_FENSALIR_GNUMAKE_PATH)/Makefile.preamble
EOF
}


function make_append_body()
{
    print_debug_enter "${@}"

    local destination="${1}"
    local repoFolder="${2}"


    ######################################################################
    # Generate middle of the global Makefile. This is very similar to
    # the per-repo Makefile but not identical. But it basically
    # follows the same pattern with some additions.

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    local echoDestination=""
    echoDestination=$(get_echo_destination "${destination}")

    # Append to global Makefile
    cat <<EOF >> "${echoDestination}"

REPONAME := ${repoFolder##*/}
REPOPATH := ${repoFolder}
\$(info Including '\$(REPOPATH)/${FRIJA_GENERATED_MAKEFILE_FRAGMENT}')
include \$(REPOPATH)/${FRIJA_GENERATED_MAKEFILE_FRAGMENT}
include \$(REPOPATH)/\$(FRIJA_MAKEFILE_EXTRAS)
include \$(_FENSALIR_GNUMAKE_PATH)/Makefile.reporules

EOF
}


function make_generate_footer()
{
    # Where to write
    local destination="${1}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    destination=$(get_echo_destination "${destination}")

    echo "include \$(_FENSALIR_GNUMAKE_PATH)/Makefile.postamble" \
         >> "${destination}"
}


function make_generate_fragment()
{
    print_debug_enter "${@}"

    # Note that each individual dependency in $dependency (third
    # argument below) is a 3-tuple consisting of composite, version,
    # and repo name all separated by ';'. Thus you have
    #
    #             "dep-A"                           "dep-B"
    #  _______________+_______________   _______________+_______________
    # /                               \ /                               \
    # <composite>;<version>;<repo-name>,<composite>;<version>;<repo-name>,...

    local repoFolder="${1}"          # Composite/Repo Name (+ optional Version)
    local parameters="${2}"          # E.g. csproj or sln
    local dependencies="${3}"        # dep-A,dep-B,dep-C,...
    local repoKind="${4}"            # E.g. app, lib, ...
    local toolDependencies="${5:-}"  # Implicitly tell shellcheck it is optional


    local currentPath=""
    currentPath=$(pwd)
    local repoPath="${currentPath}/${repoFolder}"
    local generatedDelta="${BUILD_DIR}/${GENERATED}"
    local generatedFolder="${repoFolder}/${generatedDelta}"
    local generatedRoot="${currentPath}/${generatedFolder}"

    print_debug "currentPath='${currentPath}'"
    print_debug "repoPath='${repoPath}' (${currentPath}/${repoFolder})"
    print_debug "generatedRoot='${generatedRoot}'"

    print_debug "Checking if '${repoPath}/.git' exists..."

    if [[ -e "${repoPath}/.git" ]]; then
        local branchName=""
        branchName=$(get_branch_name "${repoPath}")
    else
        local message="Cannot find repo '${repoFolder}'; please make sure "
        message+="it has been cloned, for instance by using the "
        message+="${BOLD}frija clone${CLEAR} command, aborting."

        print_error "${message}" _FRIJA_EXIT_OTHER_PROBLEM
    fi

    local destination="${repoFolder}/${FRIJA_GENERATED_MAKEFILE_FRAGMENT}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    #
    # TODO: Double-check that there are no problems with this. Also
    # does MSBuild-variant support this?
    destination=$(get_echo_destination "${destination}")

    local message="  Generating ${BOLD}GNU Make${CLEAR} dependency file "
    message+="'${BOLD}${destination}${CLEAR}'..."

    print_debug "currentPath='${currentPath}'"
    print_debug "repoPath='${repoPath}'"

    # Build lists of
    #
    # - Pure interface dependencies: Dependency ID fields stored in
    #   $interfaceDependencies[]
    # - Other dependencies: Dependency ID fields stored in
    #   $directDependencies[]
    # - Names of dependency variables
    # - Paths to repo root folders associated with dependency variables
    declare -a interfaceDependencies=()
    declare -a directDependencies=()
    declare -a dependencyVars=()
    declare -a dependencyPaths=()

    local dependencyId=""
    local depPath=""
    local dep=""
    for dep in ${dependencies//,/ }; do
        local dependencyComposite=""
        local dependencyVersion=""
        local dependencyName=""
        local rest=""

        # Parse content of an individual dependency where fields are
        # split on ';'
        IFS=';' read -r \
           dependencyComposite \
           dependencyVersion \
           dependencyName \
           rest<<<"${dep}"

        dependencyId="Frija_${dependencyComposite}"
        dependencyId+="_${dependencyName}"
        dependencyId+="_${dependencyVersion}"
        local dependencyKind=""
        dependencyKind=$(_frija_repo_kind "${dependencyComposite}" \
                                          "${dependencyName}" \
                                          "${dependencyVersion}")

        depPath=$(make_destination "${dependencyComposite}" \
                                   "${dependencyName}" \
                                   "${dependencyVersion}")
        case "${dependencyKind}" in
            "${INF_REPO}")
                interfaceDependencies+=("${dependencyId}")
                ;;
            "${APP_REPO}"|"${LIB_REPO}"|"${PLG_REPO}")
                directDependencies+=("${dependencyId}")
                ;;
            "")
                local message="${BOLD}${repoPath}${CLEAR} have a dependency to "
                message+="${BOLD}${depPath}${CLEAR} which have an empty repo "
                message+="kind."
                print_warning "${message}"
                ;;
            *)
                local message="${BOLD}${repoPath}${CLEAR} have a dependency to "
                message+="${BOLD}${depPath}${CLEAR} which have an "
                message+="${ITALIC}unexpected${CLEAR} repo kind of "
                message+="'${dependencyKind}'. Expected one of "
                message+="${APP_REPO}, ${LIB_REPO}, or ${PLG_REPO}."
                print_warning "${message}"
                ;;
        esac

        dependencyVars+=("${dependencyId}_ROOT")
        dependencyPaths+=("\$(frijaHome)/${depPath}")
    done

    # Dependency ID for current repo
    local frijaId="Frija_${composite}_${repoName}_${version}"

    # In case dry-run mode is enabled, redirect to STDOUT instead.
    destination=$(get_echo_destination "${destination}")

    cat <<EOF >| "${destination}"
################################################################################
#  NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE
################################################################################
#
# This Makefile is generated by Frija ('frija generate' command). Any
# edits made to this file will be lost next time 'frija generate'
# command is executed.
#
# For further information please read the instructions found at the
# top of the Makefile.preamble file found in the Fensalir repo.
#
################################################################################
#  NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE NOTE
################################################################################

# Globally unique identity for repo; these ID values are used by other
# generated dependency files in their respecitve *_DIRECT_DEPENDENCIES
# variables.
FRIJA_ID := ${frijaId}
EOF

    local modelRepoState=""
    if [[ -e "${repoPath}/${FRIJA_MODEL_REPO_ID}" ]]; then
        modelRepoState=" ${frijaId}"
    fi

    cat <<EOF >> "${destination}"

# If set to Frija ID then repo is a model repo.
${frijaId}_MODEL_REPO_MARKER :=${modelRepoState}

# Folder names used by Frija
frijaBuildFolder := Build
frijaResultFolder := Result
frijaReleaseFolder := Release
frijaDebugFolder := Debug
frijaStaticFolder := Static
frijaDynamicFolder := Dynamic

# Build properties
frijaHome := ${_FRIJA_WS_PATH}
frijaRoot := \$(frijaHome)/${repoFolder}
frijaBuildRoot := \$(frijaRoot)/Build
frijaResultRoot := \$(frijaRoot)/Result

# List of direct INTERFACE dependencies expressed as Frija ID (\$FRIJA_ID)
# values. This list excludes any INDIRECT dependencies, that is
# if A -> B -> C then B is a direct dependency and C is an indirect
# dependency to A and thus C would be excluded from the list.
EOF

    local index=""

    # shellcheck disable=SC2129
    {
        echo -n "${frijaId}_INTERFACE_DEPENDENCIES :="
        if (( ${#interfaceDependencies[@]} > 0 )); then
            for index in "${interfaceDependencies[@]}"; do
                echo -n " \\"
                # shellcheck disable=SC1117
                echo -e -n "\n  ${index}"
            done
        fi
        echo ""
    } >> "${destination}"

    cat <<EOF >> "${destination}"

# List of DIRECT dependencies expressed as Frija ID (\$FRIJA_ID)
# values. This list excludes any INDIRECT dependencies, that is
# if A -> B -> C then B is a direct dependency and C is an indirect
# dependency to A and thus C would be excluded from the list.
EOF

    local index=""

    # shellcheck disable=SC2129
    {
        echo -n "${frijaId}_DIRECT_DEPENDENCIES :="
        if (( ${#directDependencies[@]} > 0 )); then
            for index in "${directDependencies[@]}"; do
                echo -n " \\"
                # shellcheck disable=SC1117
                echo -e -n "\n  ${index}"
            done
        fi
        echo ""
    } >> "${destination}"

    cat <<EOF >> "${destination}"

# Search paths to the root folder of dependencies listed in
# \$(FRIJA_ID)_DIRECT_DEPENDENCIES where listed variable names use
# corresponding Frija ID as prefix and '_ROOT' as suffix. Note that if
# there are no dependencies listed then there are no lines below.
EOF

    # The lengths of arrays $dependencyVars[] and $dependencyPaths[]
    # are guaranteed to be the same as they are populated within the
    # same loop above. Hence we can just extract the indeces of one of
    # them which then can be used when indexing both of them.
    {
        for index in "${!dependencyVars[@]}"; do
            echo "${dependencyVars[${index}]} := ${dependencyPaths[${index}]}"
        done
    } >> "${destination}"


    cat <<EOF >> "${destination}"


################################################################################
# ENVIRONMENT TO USE WHEN BUILDING THIS REPO
################################################################################

# List SECI variables that should be exported to the recipes used by
# this repo. Note that the variables are prefixed with FRIJA_ID which
# should be removed when exported to the recipies.
EOF

    local buildEnvironment=""
    local buildEnvVersion=""
    local configs=""
    local seciList=""
    local rest=""

    # $externalDeps originates from parsing of the .repos file
    # shellcheck disable=SC2034
    IFS=";" read -r buildEnvironment buildEnvVersion configs seciList rest <<< \
       "${externalDeps}"

    # Common base path to the buildEnvironment repo
    local buildEnvPath="${_VOLLA_PATH}/${buildEnvironment}"

    if [[ -n "${seciList}" ]]; then
        # Transform $seciList by appending ${OPERATING_SYSTEM} to each
        # element in the list as the content of the SECI file need to
        # be adapted by selected OS. First fix the first element in
        # the list...
        seciList="${OPERATING_SYSTEM,,}-${seciList}"

        # ...and then fix the rest of the elements if there are any.
        seciList="${seciList//,/,${OPERATING_SYSTEM,,}-}"
    fi

    parse_seci_files "${buildEnvPath}" "${buildEnvVersion}" "${seciList}"

    # Note that by prepending $frijaId to the variable names makes it
    # unnecessary to remove them as they are ties to each repo due to
    # that $frijaId is globally unique.
    {
        echo -n "${frijaId}_EXPORTED_VARIABLES :="
        if (( ${#EXPORTED_SECI_VARIABLES[@]} > 0 )); then
            for index in "${!EXPORTED_SECI_VARIABLES[@]}"; do
                echo -n " \\"
                # shellcheck disable=SC1117
                echo -e -n "\n  ${frijaId}_${index}"
            done
        fi
        echo ""
    } >> "${destination}"


    {
    cat <<EOF >> "${destination}"

# All SECI variables for this repo; note that the variables are prefixed
# with FRIJA_ID which must be taken into account when used in rules.
EOF
        if (( ${#COMMON_SECI_VARIABLES[@]} > 0 )); then
            for index in "${!COMMON_SECI_VARIABLES[@]}"; do
                echo "${frijaId}_${index} := ${COMMON_SECI_VARIABLES[${index}]}"
            done
        fi
    } >> "${destination}"


    print_debug_exit
}

#
# GNU Make
################################################################################



################################################################################
# CMAKE
#

function cmake_generate()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"          # Composite/Repo Name (+ optional Version)
    local target="${2}"
    local dependencies="${3}"
    local repoKind="${4}"            # E.g. app, lib, ...
    local toolDependencies="${5:-}"  # Implicitly tell shellcheck it is optional
    local externalDeps="${6}"        # External dependencies to use

    local generatedDelta="${BUILD_DIR}/${GENERATED}"
    local generatedFolder="${repoFolder}/${generatedDelta}"

    # shellcheck disable=SC2034
    local buildFolder=""
    local buildResultFolder=""
    # shellcheck disable=SC2034
    local prepareFolder=""
    # shellcheck disable=SC2034
    local archiveFolder=""

    # Assign values to $buildFolder, $prepareFolder, and
    # $archiveFolder in for-loop below. At the same time the
    # corresponding folders are also created if they do not already
    # exist.
    declare -a command=()
    # TODO: Remove $PREPARE_DIR and $ARCHIVE_DIR and update
    # frija_json_dependencies.cmake accordingly in all CMake-repos...
    declare -a folderList=("${BUILD_DIR}" \
                               "${BUILD_RESULT_DIR}" \
                               "${PREPARE_DIR}" \
                               "${ARCHIVE_DIR}")
    for item in "${folderList[@]}"; do
        local delta="${item}/${buildType}"
        local folder="${repoFolder}/${delta}"

        # Dynamically assign $folder to the variable name
        # '${item,}Folder', that is if ${item} is "BuildResult" then
        # ${item,} is "buildResult" and the resulting variable name to
        # assign to is thus $buildResultFolder in this case
        declare "${item,}Folder=${folder}"

        # Ensure include folder exist in $BUILD_RESULT_DIR so CMake wont
        # freak out because the folder does not exist when there is a
        # dependency from another repo to current repo
        if [[ "${item}" == "${BUILD_RESULT_DIR}" ]]; then
            folder+="/include"
        fi

        if [[ "${VERBOSE}" == "y" ]]; then
            print_message "Checking if '${folder}' exists"
        fi
        if [[ ! -d "${folder}" ]]; then
            if [[ "${VERBOSE}" == "y" ]]; then
                print_message "Does not"
            fi
            command=("${SINGLE}" "Creating ${delta}..." \
                                mkdir --parents "${folder}")
            run "${command[@]}"
        elif [[ "${VERBOSE}" == "y" ]]; then
            print_message "Does"
        fi
    done

    # Create the $GENERATED folder if it does not already exist
    local generatedDelta="${BUILD_DIR}/${GENERATED}"
    local generatedFolder="${repoFolder}/${generatedDelta}"
    if [[ ! -d "${generatedFolder}" ]]; then
        command=("${SINGLE}" "Creating ${generatedDelta}..." \
                             mkdir --parents "${generatedFolder}")
        run "${command[@]}"
    fi

    print_message "Generating JSON file..."
    # Generated JSON file with dependency information
    cmake_generate_json "${repoFolder}" \
                        "${parameters}" \
                        "${dependencies}" \
                        "${repoKind}" \
                        "${toolDependencies}"

    # Set up defines to configure CMake
    local defines=""
    defines="-DCMAKE_BUILD_TYPE=${buildType}"
#    defines+=" -DSYSTEM_NAME=${SYS_NAME}"
#    defines+=" -DCMAKE_INSTALL_PREFIX=${prepareFolder}"
    defines+=" -DCMAKE_INSTALL_PREFIX=${buildResultFolder}"
    if [[ -n "${verboseBuild}" ]]; then
        # Enable CMake verbose build mode
        defines+=" -DCMAKE_VERBOSE_MAKEFILE:BOOL=ON"
    fi

    print_debug "CMake defines='${defines}'"

    local locale=""
    local version=""
    local configs=""
    local seciList=""
    local rest=""
    IFS=";" read -r locale version configs seciList rest <<< "${externalDeps}"

    # Common base path to the locale repo
    local localePath="${_VOLLA_PATH}/${locale}"

    #print_message "cmake -L -G ${target} -B ${buildFolder} -S ${repoFolder} ${defines[*]}"
    #print_message "cmake -L -B ${buildFolder} -S ${repoFolder} ${defines[*]}"
    # Finally call CMake. Here we DO want word splitting to happen for
    # ${defines}
    #
    # shellcheck disable=SC2206
    command=("$SINGLE" "Calling CMake..." \
                       "${localePath}" \
                       "${version}" \
                       "${seciList}" \
                       "" \
                       cmake -L \
                       -G "${target}" \
                       -B "${buildFolder}" \
                       -S "${repoFolder}" \
                       ${defines})
    run_isolated "${command[@]}"
}


function cmake_insert_dependency_includes()
{
    print_debug_enter "${@}"

    local name="${1}"
    local depPath="${2}"  # Linux path

    local depFile="${depPath}/${DEPENDENCY_FILE}"

    print_debug "depFile='${depFile}'"
    if [[ -r "${depFile}" ]]; then
        local os=""
        local kind=""
        local deps=""
        local rest=""
        print_debug "Reading '${kind}' from dependency file '${depFile}'"
        while read -r os kind deps rest; do
            # Strip any carriage returns from the read values
            os=${os//$'\r'}
            kind=${kind//$'\r'}
            deps=${deps//$'\r'}
            rest=${rest//$'\r'}

            if [[ "${os}" == "#"* || "${os}" != "${operatingSystem}" ]]; then
                continue
            fi

            print_debug "os='${os}', " \
                        "kind='${kind}', " \
                        "deps='${deps}', " \
                        "rest='${rest}'"

            case "${kind}" in
                "${DEPENDENCY_INCLUDES}")
                    local path=""
                    # JSON does not allow trailing commas. Due to this we
                    # have to use this unusual construct where the read
                    # items are delayed one iteration. The end result is
                    # that we can do special treatment of the last item
                    # read (no trailing comma added).
                    local lastpath=""
                    local buildType="\${CMAKE_BUILD_TYPE}"
                    while read -d, -r path; do
                        if [[ -n "${lastpath}" ]]; then
                            # There is more than one path, but operate on
                            # previous path which makes it safe to append
                            # a comma to the output
                            cat <<EOF
                    "${depPath}/${BUILD_RESULT_DIR}/${buildType}/${lastpath}",
EOF
                        fi
                        lastpath="${path}"
                    done <<<"${deps}," # Add ',' to cover single-item case
                    # Last path read (or first if there is only one) is
                    # found in $lastPath. Send it to stdout without any
                    # trailing comma.
                    cat <<EOF
                    "${depPath}/${BUILD_RESULT_DIR}/${buildType}/${lastpath}"
EOF
                    ;;
            esac
        done <"${depFile}"
    fi

    print_debug_exit
}


function cmake_insert_dependency_lib64()
{
    print_debug_enter "${@}"

    local name="${1}"
    local depPath="${2}"  # Linux path

    local depFile="${depPath}/${DEPENDENCY_FILE}"

