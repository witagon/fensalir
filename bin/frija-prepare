#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "t:ai:vhdDF:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "type:,all,input:,verbose,help,debug,dry-run,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Prepare repos listed in given repo-list file for archiving.
EOF
}


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -t|--type)
            result="${_FRIJA_BUILD_RELEASE} ${_FRIJA_BUILD_DEBUG}"
            ;;
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            if [[ -z "${result}" ]]; then
                local message="Current Frija Workspace is corrupt; "
                message+="no ${REPO_LIST_EXTENSION} file found"
                _frija_completion_help_message "${message}"
            fi
            ;;
        -F|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  For each applicable repo in the input file create the installation
  structure to use in the installation archive. When using CMake this
  is partly already done due to that the build stage (see overview
  below) also makes a call to the

    ${BOLD}CMake --install${CLEAR}

  command immediately after a successful build. This is due to that
  the build structure differ from the installation structure and when
  there are inter-repo dependencies the installation structure is
  assumed.

  This result in additional files being copied to the prepare folder
  that should not be included in the installation archive; these files
  are excluded by the ${BOLD}Frija archive${CLEAR} command).

  However, this command calls the prepare target for each repo that
  optionally can copy additional files to the prepare folder. Note
  that for repos using MSBuild build system this target has to copy
  all files that are to be included in the installation archive.

${BOLD}
  Behavior of this command varies slightly depending on where you are
  within generic folder structure shown below${CLEAR}

    frija
      |
      +-- WORKSPACE
                |
                +-- COMPOSITE-NAME
                               |
                               +-- REPO

  The basic rule of thumb is that when you are within a REPO then this
  command is ONLY applied to that repo, otherwise it is applied to
  all applicable repos listed in the input file.

  This default rule-of-thumb-behavior can be overridden when you are
  within REPO (or sub-folder to REPO); you give the -a/--all option on
  the command line.

  The -a/--all option is an escape mechanism that allow you to apply
  the command to all repos listed in the input file regardless of
  where you are within the WORKSPACE directory tree.


  ${UNDERLINE_ON}Background${UNDERLINE_OFF}

  The complete build process consist of the stages
  ${BOLD}GENERATE${CLEAR}   Create non-version controlled files needed to build, for instance
               inter-repo dependency files, make files (generated by CMake),
               and so on

  ${BOLD}BUILD${CLEAR}      Actual compilation stage; which may also generate
             non-version controlled files like files generated
             from Google proto-files

  ${BOLD}PREPARE${CLEAR}    Copy files from Build folder to Prepare folder in a structure that
               is similar to how it should be installed on the target system

  ${BOLD}ARCHIVE${CLEAR}    Create installation archive based on content in Prepare folder and
                            place it within the Archive folder

  In addition to the above stages, there is also
  ${BOLD}CLEAN${CLEAR}      Clean build artifacts so a rebuild will trigger re-creation of all
               binaries, including any re-generation and compilation of any
               Google proto-files and so on; i.e. files produced by the build
               stage. Optionally files produced by the generate and prepare
               stages can also be cleaned.

  ${BOLD}Note:${CLEAR} Before the build command can be called, the
               generate command must be called at least once.

${BOLD}Options:${CLEAR}
  -t[TYPE],           prepare the installation file structure for the given
  --type[=TYPE]         variant (debug or release) so it can be inspected
                        before the installation archive is created using the
                        ${BOLD}frija archive${CLEAR} command

  -a,                 apply command to all applicable repos listed in input
   --all                file; default or given on the command line via
                        -i/--input option. This option is applied by default
                        when outside of a repo (but still within a workspace).

  -iFILE,             apply operation to repos listed in FILE
   --input=FILE
  -v,                 verbose output
   --verbose
  -h,                 print this message
   --help
  -d,                 enable debug printouts sent to stderr
   --debug
  -D,                 do not execute commands with side effects, just echo them
   --dry-run
  -FOS,               force command to assume given OS instead of detected OS
   --force=OS

${BOLD}See also:${CLEAR}
  (frija) ${BOLD}archive${CLEAR}, ${BOLD}build${CLEAR}, ${BOLD}clean${CLEAR}, ${BOLD}generate${CLEAR}, commands for further information

EOF
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${REPO_TOOLS_HOME}/.preamble.bash"

# Include generic VCS support.
#
# shellcheck source=./.vcs_functions.bash
source "${REPO_TOOLS_HOME}/.vcs_functions.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...

SYS_NAME=""

DRY_RUN="n"
VERBOSE="n"
DEBUG="n"
allRepos="n"
buildType=""
inFile=""
osOverride=""


# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -t|--type)
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_BUILD_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_BUILD_DEBUG}" \
                                 "${_FRIJA_BUILD_RELEASE}"
            shift  # Move to next option
        ;;
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        -F|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done


# Ensure build type contain a legal value
case "${BUILD_TYPE}" in
    ${_FRIJA_BUILD_RELEASE}|${_FRIJA_BUILD_DEBUG})
        ;;
    *)
        # Illegal value given for the optional TYPE
        message="TYPE ('${BUILD_TYPE}') may only be one of "
        message+="'${_FRIJA_BUILD_RELEASE}' or '${_FRIJA_BUILD_DEBUG}', "
        message+="aborting."
        print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
        ;;
esac


################################################################################
# Consistency checks
################################################################################

# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    OPERATING_SYSTEM="${osOverride}"
fi


# Ensure we have an input file and that it has a valid extension
inFile=$(ensure_input_file "${inFile}")

# In case user has provided an input file with an explicit search path
# we must remove it in order to obtain the system name from the input
# filename. And also remove $REPO_LIST_EXTENSION from it.
SYS_NAME="${inFile##*/}"
SYS_NAME="${SYS_NAME%%${REPO_LIST_EXTENSION}}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


print_debug "verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}"


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_HOME or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
_frija_locate_frija_home
REPO_SUBPATH=$(cwd_in_workspace_repo_folder_p)
cd "${_FRIJA_HOME}"


####################
# Note: See .preamble.bash for more information about the run function!
####################


################################################################################
# CMAKE
#

function cmake_prepare()
{
    local repoFolder="${1}"
    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"
    local command

    command=("${SINGLE}" "${repoFolder}" \
                         cmake --build "${buildFolder}" \
                         --target prepare)
    run "${command[@]}"
}

#
# CMAKE
################################################################################



################################################################################
# MSBUILD
#

function msbuild_prepare()
{
    local repoFolder="${1}"  # Composite/Repo Name (+ optional Version)
    local parameters="${2}"  # E.g. csproj or sln

    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"
    local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"

    # Ensure archiveFolder exist
    command=("${MIDDLE}" "${repoFolder}" mkdir --parents "${archiveFolder}")
    run "${command[@]}"

    # Extract composite, repo name, and version from given path
    IFS='/' read -r composite name version<<<"${repoFolder}"
    local inputFile="${name}.${type}"

    local command
    command=("${SINGLE}" "${repoFolder}" \
                         MSBuild.exe \
                         "-warnaserror" \
                         "-p:Configuration=${BUILD_TYPE}" \
                         "-target:prepare" \
                         "${repoFolder}/${inputFile}")
    run "${command[@]}"
}

#
# MSBUILD
################################################################################


function prepare_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_prepare "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_prepare "${destination}" "${parameters}"
            ;;
        *)
            message="Unsupported build tool '${tool}' for '${destination}', "
            message+="aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
    esac
}


########
# Iterate over the lines in the input file and act on each line
# depending on $os and $vcs fields.

print_message "Reading from ${inFile} and preparing repos..."
print_separator

processedReposFlag=""
declare -a skippedOperatingSystems=()

# -r make read to not treat backslash character as an escape character
while read -r os \
           vcs \
           composite \
           version \
           uri \
           repoKind \
           tool \
           dependencies \
           toolDependencies \
           rest;
do
    # Strip any carriage returns from the read values
    os=${os//$'\r'}
    vcs=${vcs//$'\r'}
    composite=${composite//$'\r'}
    version=${version//$'\r'}
    uri=${uri//$'\r'}
    repoKind=${repoKind//$'\r'}
    tool=${tool//$'\r'}
    dependencies=${dependencies//$'\r'}
    toolDependencies=${toolDependencies//$'\r'}
    rest=${rest//$'\r'}

    print_debug "os='${os}', " \
                "vcs='${vcs}', " \
                "version='${version}', " \
                "uri='${uri}', " \
                "repotype='${repoKind}', " \
                "tool='${tool}', " \
                "dependencies='${dependencies}', " \
                "rest='${rest}'"


    if [[ "${os}" == "#"* ]] || [[ -z "${os}" ]]; then
        # Skip to next entry since it is a commented or empty line
        continue
    fi

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        skippedOperatingSystems+=("${os}")
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    if [[ "${tool}" == "none" ]]; then
        # Skip repos that does not have any build tool
        continue
    fi

    if [[ "${dependencies}" == "none" ]]; then
        # When there are no dependencies, set it to an empty string.
        dependencies=""
    fi

    if [[ "${toolDependencies}" == "none" ]]; then
        # When there are no tool dependencies, set it to an empty string.
        toolDependencies=""
    fi


    case "${vcs}" in
        git)
            if [[ "${uri}" =~ ${GIT_REPO_PATTERN} ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination=$(make_destination "${composite}" \
                                               "${repoName}" \
                                               "${version}")
            else
                message="Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is "
                message+="'${uri}' and pattern is '${GIT_REPO_PATTERN}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi
            ;;
        *)
            message="Unsupported VCS: '${vcs}' for '${uri}' found in input "
            message+="file '${inFile}', aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            ;;
    esac

    print_debug "repoName='${repoName}', destination='${destination}'"


    if [[ -n "${REPO_SUBPATH}" ]] && [[ "${allRepos}" == "n" ]]; then
        # REPO_SUBPATH is set, this means that A) we are somewhere
        # below _FRIJA_HOME and B) we are within a repo.
        #
        # NOTE: If inside a repo and 'all' option is set, then it
        # will override this behavior and force all repos to be
        # operated on regardless.
        print_debug "REPO_SUBPATH='${REPO_SUBPATH}'"
        if [[ "${REPO_SUBPATH}" != "${destination}"* ]]; then
            print_debug "destination='${destination}'"
            # In this case we should ONLY operate on repos where
            # REPO_SUBPATH and destination matches, which means that
            # for all other repos we should just skip it and move on
            # to the next one.
            continue;
        fi
    fi


    if [[ "${repoKind}" == "${TOL_REPO}" ]]; then
        message="${BOLD}Skipping${CLEAR} prepare of ${repoKind} repo "
        message+="${BOLD}${destination}${CLEAR}..."
        print_message "${message}"
        continue
    else
        message="${BOLD}Preparing${CLEAR} creation of installation archive "
        message+="in ${BOLD}${destination}${CLEAR}..."
        print_message "${message}"
        prepare_dispatch "${tool}" "${destination}"
    fi

    # If we reach this point, at least one repo has been processed
    processedReposFlag="y"
done < "${inFile}"


if [[ -z "${processedReposFlag}" ]]; then
    print_os_error "skippedOperatingSystems" \
                   "${inFile}" \
                   "No repos were prepared!"
fi
