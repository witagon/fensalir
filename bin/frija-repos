# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -c|--composite)
            ensure_option_not_set "Target composite" "${targetComposite}"
            shift  # Move to option argument
            targetComposite="${1}"
            shift  # Move to next option
            ;;
        -r|--repo)
            ensure_option_not_set "Target repo" "${targetRepo}"
            shift  # Move to option argument
            targetRepo="${1}"
            shift  # Move to next option
            ;;
        -R|--repoVersion)
            ensure_option_not_set "Target version" "${targetRepoVersion}"
            shift  # Move to option argument
            targetRepoVersion="${1}"
            shift  # Move to next option
            ;;
        -l|--locale)
            ensure_option_not_set "Locale" "${targetLocaleRepo}"
            shift  # Move to option argument
            targetLocaleRepo="${1}"
            shift  # Move to next option
            ;;
        -L|--localeVersion)
            ensure_option_not_set "Locale" "${targetLocaleVersion}"
            shift  # Move to option argument
            targetLocaleVersion="${1}"
            shift  # Move to next option
            ;;
        -V|--replacement)
            ensure_option_not_set "Replacement version" "${replacementVersion}"
            shift  # Move to option argument
            replacementVersion="${1}"
            shift  # Move to next option
            ;;
        -t|--target)
            ensure_option_not_set "Target for change" "${targetValue}"
            shift  # Move to option argument
            targetValue="${1}"
            shift  # Move to next option
            ;;
        -o|--os)
            ensure_option_not_set "Operating System" "${selectedOS}"
            shift  # Move to next option
            selectedOS="${1:-${_FRIJA_ANY_OS}}"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done


