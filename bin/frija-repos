# Not a pretty function, but it is local and very small.
#
# Function re-uses _frija_process_option() to try to deduce composite
# from input file; this will only work for the special case when a
# single composite is used.
function deduce_composite()
{
    # _frija_process_option depend on these
    local COMPOSITE="composite"
    local REPO="repo"
    local VERSION="version"
    local LOCALE_REPO="localeRepo"
    local LOCALE_VERSION="localeVersion"

    local result=""
    # Set $result
    _frija_process_option "${COMPOSITE}" "${inFile}"

    # Allow word splitting to occur when expanding
    # $result to get any space-separated values as
    # individual elements in the $composites array
    #
    # shellcheck disable=SC2206
    declare -a composites=( ${result} )
    if (( ${#composites[@]} == 1 )); then
        targetComposite="${composites[0]}"
    fi
}

if [[ -z "${targetComposite}" && -n "${targetRepo}" ]]; then
    deduce_composite
fi


message=""

# Both check that $targetValue is consistent with $targetRepo and
# $targetLocaleRepo and also try to set $targetValue if it is not set
# from the command line. Also check that $targetRepo and
# $targetLocaleRepo are consistent with each other.
if [[ -z "${targetValue}" ]]; then
    if [[ -z "${targetRepo}" && -z "${targetLocaleRepo}" ]]; then
        message="Neither repo nor locale repo specified, aborting."
    elif [[ -n "${targetRepo}" && -z "${targetLocaleRepo}" ]]; then
        targetValue="${REPO}"
    elif [[ -z "${targetRepo}" && -n "${targetLocaleRepo}" ]]; then
        targetValue="${LOCALE}"
    else
        message="Command is ambiguous as both repo and locale repo are "
        message+="specified, aborting."
    fi
else
    if [[ -z "${targetRepo}" && -z "${targetLocaleRepo}" ]]; then
        message="Neither repo nor locale repo specified, aborting."
    elif [[ -n "${targetRepo}" && -z "${targetLocaleRepo}" ]]; then
        if [[ "${targetValue}" != "${REPO}" ]]; then
            message="Command is inconsistent as "
            message+="target ${BOLD}${targetValue}${CLEAR} used in "
            message+="combination with ${BOLD}repo${CLEAR}, aborting."
        fi
    elif [[ -z "${targetRepo}" && -n "${targetLocaleRepo}" ]]; then
        if [[ "${targetValue}" != "${LOCALE}" ]]; then
            message="Command is inconsistent as "
            message+="target ${BOLD}${targetValue}${CLEAR} used in "
            message+="combination with ${BOLD}locale${CLEAR} repo, aborting."
        fi
    else
        # Consistent $targetValue specified, nothing to do
        :
    fi
fi

if [[ -n "${message}" ]]; then
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi

# Depending on which target has been selected the target version
# differ
if [[ "${targetValue}" == "${REPO}" ]]; then
    targetVersion="${targetRepoVersion}"
elif [[ "${targetValue}" == "${LOCALE}" ]]; then
    targetVersion="${targetLocaleVersion}"
else
    message="Unsupported target value '${targetValue}', aborting."
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi


# Ensure that $targetRepo is consistent with $targetComposite and
# $targetVersion, and also ensure that $targetLocaleRepo is consistent
# with $targetLocaleVersion
if [[ -n "${targetRepo}" ]]; then
    if [[ -z "${targetComposite}" && -z "${targetVersion}" ]]; then
        message="Command is inconsistent as repo is specified but "
        message+="${BOLD}neither composite nor version is${CLEAR}, aborting."
    elif [[ -z "${targetComposite}" ]]; then
        message="Command is inconsistent as repo and version is specified but "
        message+="${BOLD}not composite${CLEAR}, aborting."
    elif [[ -z "${targetVersion}" ]]; then
        message="Command is inconsistent as repo and composite are both "
        message+="specified but ${BOLD}repo version is not${CLEAR}, aborting."
    fi
else
    if [[ -z "${targetLocaleVersion}" ]]; then
        message="Command is inconsistent as locale repo is specified but "
        message+="${BOLD}locale version is not${CLEAR}, aborting."
    fi
fi

if [[ -n "${message}" ]]; then
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi


if [[ -z "${replacementVersion}" ]]; then
    message="No replacement version specified, aborting."
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi


