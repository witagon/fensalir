#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")


# See frija_completion.bash for more information
function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "c:r:V:l:L:R:t:o::i:vhdD"
}

# See frija_completion.bash for more information
function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "composite:,repo:,repoVersion:,locale:,localeVersion:,replacement:,target:,os::,input:,verbose,help,debug,dry-run"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


# See frija_completion.bash for more information
function synopsis()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
  Update referenced version of a repo in a ${REPO_LIST_EXTENSION} file.
EOF
}


# Used for designating no preference when it comes to OS
_FRIJA_ANY_OS="ANY"


# Internal helper function used for creating TAB-completion responses
# for values extracted from rows in $inFile.
#
# Note that this function rely on Bash call-by-name semantics for
# returning a value, that is $result refer to the first entry found on
# the stack with the same name.
function _frija_process_option()
{
    local field="${1}"
    local inFile="${2}"

    print_debug "field='${field}'"
    print_debug "inFile='${inFile}'"

    if [[ -z "${field}" ]]; then
        local message="Internal error, unexpected empty argument for 'field'"
        _frija_completion_error_message "${message}"
    fi

    print_debug "COMP_LINE='${COMP_LINE}'"
    [[ "${COMP_LINE}" =~ ^.*\ (-c|--composite=)([^\ ]*).*$ ]]
    local targetComposite="${BASH_REMATCH[2]:-}"

    [[ "${COMP_LINE}" =~ ^.*\ (-r|--repo=)([^\ ]*).*$ ]]
    local targetRepo="${BASH_REMATCH[2]:-}"

    [[ "${COMP_LINE}" =~ ^.*\ (-R|--repoVersion=)([^\ ]*).*$ ]]
    local targetVersion="${BASH_REMATCH[2]:-}"

    [[ "${COMP_LINE}" =~ ^.*\ (-l|--locale=)([^\ ]*).*$ ]]
    local targetLocaleRepo="${BASH_REMATCH[2]:-}"

    [[ "${COMP_LINE}" =~ ^.*\ (-L|--localeVersion=)([^\ ]*).*$ ]]
    local targetLocaleVersion="${BASH_REMATCH[2]:-}"

    [[ "${COMP_LINE}" =~ ^.*\ (-t|--target=)([^\ ]*).*$ ]]
    local target="${BASH_REMATCH[1]:-}"
    local targetValue="${BASH_REMATCH[2]:-}"

    [[ "${COMP_LINE}" =~ ^.*\ (-o|--os=)([^\ ]*).*$ ]]
    local targetOS="${BASH_REMATCH[2]:${_FRIJA_ANY_OS}}"

    print_debug targetComposite="'${targetComposite}'"
    print_debug targetRepo="'${targetRepo}'"
    print_debug targetVersion="'${targetVersion}'"
    print_debug targetLocaleRepo="'${targetLocaleRepo}'"
    print_debug targetLocaleVersion="'${targetLocaleVersion}'"
    print_debug target="'${target}'"

    if [[ -z "${target}" ]] \
           && [[ -n "${targetRepo}"       || -n "${targetVersion}" ]] \
           && [[ -n "${targetLocaleRepo}" || -n "${targetLocaleVersion}" ]]
    then
        local message="Command line might become ambiguous; please "
        message+="consider using the -t/--target option to resolve"
        _frija_completion_warning_message "${message}"


    elif [[ "${targetValue}" == "${REPO^^}" ]] \
             && [[ -z "${targetRepo}"       && -z "${targetVersion}" ]] \
             && [[ -n "${targetLocaleRepo}" || -n "${targetLocaleVersion}" ]]
    then
        local message="Command line is inconsistent; target "
        message+="${BOLD}${REPO^^}${CLEAR} used in combination with "
        message+="locale repo"
        _frija_completion_warning_message "${message}"


    elif [[ "${targetValue}" == "${LOCALE^^}" ]] \
             && [[ -n "${targetRepo}"       || -n "${targetVersion}" ]] \
             && [[ -z "${targetLocaleRepo}" && -z "${targetLocaleVersion}" ]]
    then
        local message="Command line is inconsistent; target "
        message+="${BOLD}${LOCALE^^}${CLEAR} used in combination with repo"
        _frija_completion_warning_message "${message}"
    fi


    if [[ -n "${inFile}" ]]; then
        # Use an associative array (hash map) to field out duplicate
        # items
        declare -A foundItems

        local os=""
        local vcs=""
        local composite=""
        local version=""
        local uri=""
        local repoKind=""
        local tool=""
        local dependencies=""
        local toolDependencies=""
        local locale=""
        local externalDeps=""
        local rest=""

        if [[ -f "${inFile}" ]]; then
            print_debug "Reading from '${inFile}'"

            # The names of some of the fields are stored in variables
            # due to that the caller has to name such a field in the
            # $field parameter (to be able to reuse this function).
            while read -r os \
                       vcs \
                       "${COMPOSITE:?}" \
                       "${VERSION:?}" \
                       uri \
                       repoKind \
                       tool \
                       dependencies \
                       toolDependencies \
                       locale \
                       externalDeps \
                       rest
            do
                os=${os//$'\r'}
                vcs=${vcs//$'\r'}
                composite=${composite//$'\r'}
                version=${version//$'\r'}
                uri=${uri//$'\r'}
                repoKind=${repoKind//$'\r'}
                tool=${tool//$'\r'}
                dependencies=${dependencies//$'\r'}
                toolDependencies=${toolDependencies//$'\r'}
                locale=${locale//$'\r'}
                externalDeps=${externalDeps//$'\r'}

                if [[ -z "${os}" ]] || [[ "${os}" == "#"* ]]; then
                    # Skipping blank lines and comments
                    continue
                fi

                if [[ "${targetOS}" == "${_FRIJA_ANY_OS}" ]] \
                       || [[ "${os^^}" == "${targetOS}" ]]
                then
                    # Do nothing when user has selected 'any' OS or
                    # there is a match between found OS and
                    # user-selected OS.
                    :
                else
                    # Skip lines only when user has NOT opted for
                    # 'any' OS and found OS does NOT match $targetOS.
                    continue
                fi


                # Create a local variable whose name is stored in $REPO
                #
                # shellcheck disable=SC2140
                local "${REPO:?}"=""

                # Note that we are silently ignoring error cases
                # below, not much else we can do when inside a while
                # loop and TAB-completion is ongoing...
                if [[ "${vcs}" == "git" ]]; then
                    if [[ "${uri}" =~ ${GIT_REPO_PATTERN} ]]; then
                        # shellcheck disable=SC2034
                        local matchOne="${BASH_REMATCH[1]}"
                        # shellcheck disable=SC2034
                        local matchTwo="${BASH_REMATCH[2]}"
                        # Due to that Bash 4.2 used in CentOS 7.9 does
                        # not support named variable references (this
                        # was introduced in Bash 4.3) we must use eval
                        # here to assign the value. When Bash 4.3 can
                        # be safely targeted this can be simplified by
                        # using a name ref instead, e.g. declaring the
                        # variable using "declare -n repo=REPO" and
                        # then assigning to it by just doing
                        # repo="${matchTwo:-${matchOne}}"
                        #
                        # A further benefit is that the two shellcheck
                        # directives for $matchOne and $matchTwo are
                        # no longer necessary.
                        eval "${REPO}="'"${matchTwo:-${matchOne}}"'
                    fi
                fi

                if [[ -n "${targetComposite}" ]]; then
                    if [[  "${!COMPOSITE}" != "${targetComposite}"* ]]
                    then
                        # No match between composite on the command
                        # line and what is read from row
                        continue
                    fi
                fi

                if [[ -n "${targetRepo}" ]]; then
                    if [[ "${!REPO}" != "${targetRepo}"* ]]
                    then
                        continue
                    fi
                fi

                if [[ -n "${targetVersion}" ]]; then
                    if [[ "${!VERSION}" != "${targetVersion}"* ]]
                    then
                        continue
                    fi
                fi

                # shellcheck disable=SC2140
                local "${LOCALE_REPO:?}"=""
                # shellcheck disable=SC2140
                local "${LOCALE_VERSION:?}"=""

                # Extract locale repo name and locale version from
                # $externalDeps field read from row
                IFS=';' read -r "${LOCALE_REPO:?}" "${LOCALE_VERSION:?}" rest \
                   <<< "${externalDeps}"

                if [[ -n "${targetLocaleRepo}" ]]; then
                    if [[ "${!LOCALE_REPO}" != "${targetLocaleRepo}"* ]]
                    then
                        continue
                    fi
                fi

                if [[ -n "${targetLocaleVersion}" ]]; then
                    if [[ "${!LOCALE_VERSION}" != "${targetLocaleVersion}"* ]]
                    then
                        continue
                    fi
                fi

                if [[ -v "${field}" ]]; then
                    print_debug "${field}='${!field}'"
                    # Indirect reference to the field read from
                    # $inFile, that is the name of the field variable
                    # is stored in $field
                    if [[ -n "${!field}" ]]; then
                        # As $foundItems is an associative array/hash
                        # map duplicate keys are ignored and in this
                        # case the field is used as a key. Hence we
                        # end up with a unique set of keys (no
                        # duplicates)
                        foundItems["${!field}"]=""
                        print_debug_array "foundItems"
                    fi
                else
                    print_debug "Variable '${field}' not found in scope"
                fi
            done < "${inFile}"

            # Get all keys in the associative array/hash map $foundItems
            result="${!foundItems[*]}"
        else
            local message="File '${inFile}' not found, "
            message+="can't complete"
            _frija_completion_error_message "${message}"
        fi

        if [[ -z "${result}" ]]; then
            # Note that $list below will most likely contain empty
            # elements, that is the array will always contain the same
            # number of elements but some of them might be empty
            # strings.
            declare -a list=("${targetComposite}"
                             "${targetRepo}"
                             "${targetVersion}"
                             "${targetLocaleRepo}"
                             "${targetLocaleVersion}")

            # Note that _frija_create_sentence_sequence() will
            # ignore any empty elements found in the array
            local sequence=""
            sequence=$(_frija_create_sentence_sequence "and" "list" "${BOLD}")

            # If $list only contain empty elements then $sequence will
            # be an empty string, that is no rows are found even when
            # no filter is applied and thus something fishy is going
            # on.
            if [[ -n "${sequence}" ]]; then
                message+="No row matching ${sequence} "
                message+="could be found in '${inFile}'"
                _frija_completion_warning_message "${message}"
            else
                message="No rows found in '${inFile}'; "
                message+="something is wrong"
                _frija_completion_error_message "${message}"
            fi
        fi
    else
        local message="No input file specified, can't complete"
        _frija_completion_error_message "${message}"
    fi
}


# See frija_completion.bash for more information
function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    local COMPOSITE="composite"
    local REPO="repo"
    local LOCALE="locale"
    local VERSION="version"
    local LOCALE_REPO="localeRepo"
    local LOCALE_VERSION="localeVersion"

    #echo "option='${option}'" 1>&2

    case "${option}" in
        -c|--composite)
            # Set $_FRIJA_HOME
            _frija_locate_frija_home

            if [[ -z "${_FRIJA_HOME}" ]]; then
                local message="You are NOT within a Frija Workspace; "
                message+="not possible to give any completion suggestions"
                _frija_completion_error_message "${message}"
            else
                [[ "${COMP_LINE}" =~ ^.*\ (-i|--input=)([^\ ]*).*$ ]]
                local inFile="${BASH_REMATCH[2]:-}"
                inFile=$(ensure_input_file "${inFile}")

                if [[ -n "${inFile}" ]]; then
                    # Set $result
                    _frija_process_option "${COMPOSITE}" "${inFile}"
                else
                    local message="No input file specified, can't complete"
                    _frija_completion_error_message "${message}"
                fi
            fi
            ;;

        -r|--repo)
            # Set $_FRIJA_HOME
            _frija_locate_frija_home

            if [[ -z "${_FRIJA_HOME}" ]]; then
                local message="You are NOT within a Frija Workspace; "
                message+="not possible to give any completion suggestions"
                _frija_completion_error_message "${message}"
            else
                [[ "${COMP_LINE}" =~ ^.*\ (-i|--input=)([^\ ]*).*$ ]]
                local inFile="${BASH_REMATCH[2]:-}"
                inFile=$(ensure_input_file "${inFile}")

                if [[ -n "${inFile}" ]]; then
                    # Set $result
                    _frija_process_option "${REPO}" "${inFile}"
                else
                    local message="No input file specified, can't complete"
                    _frija_completion_error_message "${message}"
                fi
            fi
            ;;

        -R|--repoVersion)
            # Set $_FRIJA_HOME
            _frija_locate_frija_home

            if [[ -z "${_FRIJA_HOME}" ]]; then
                local message="You are NOT within a Frija Workspace; "
                message+="not possible to give any completion suggestions"
                _frija_completion_error_message "${message}"
            else
                [[ "${COMP_LINE}" =~ ^.*\ (-i|--input=)([^\ ]*).*$ ]]
                local inFile="${BASH_REMATCH[2]:-}"
                inFile=$(ensure_input_file "${inFile}")

                if [[ -n "${inFile}" ]]; then
                    # Set $result
                    _frija_process_option "${VERSION}" "${inFile}"
                else
                    local message="No input file specified, can't complete"
                    _frija_completion_error_message "${message}"
                fi
            fi
            ;;

        -l|--locale)
            # Set $_FRIJA_HOME
            _frija_locate_frija_home

            if [[ -z "${_FRIJA_HOME}" ]]; then
                local message="You are NOT within a Frija Workspace; "
                message+="not possible to give any completion suggestions"
                _frija_completion_error_message "${message}"
            else
                [[ "${COMP_LINE}" =~ ^.*\ (-i|--input=)([^\ ]*).*$ ]]
                local inFile="${BASH_REMATCH[2]:-}"
                inFile=$(ensure_input_file "${inFile}")

                if [[ -n "${inFile}" ]]; then
                    # Set $result
                    _frija_process_option "${LOCALE_REPO}" "${inFile}"
                else
                    local message="No input file specified, can't complete"
                    _frija_completion_error_message "${message}"
                fi
            fi
            ;;

        -L|--localeVersion)
            # Set $_FRIJA_HOME
            _frija_locate_frija_home

            if [[ -z "${_FRIJA_HOME}" ]]; then
                local message="You are NOT within a Frija Workspace; "
                message+="not possible to give any completion suggestions"
                _frija_completion_error_message "${message}"
            else
                [[ "${COMP_LINE}" =~ ^.*\ (-i|--input=)([^\ ]*).*$ ]]
                local inFile="${BASH_REMATCH[2]:-}"
                inFile=$(ensure_input_file "${inFile}")

                if [[ -n "${inFile}" ]]; then
                    # Set $result
                    _frija_process_option "${LOCALE_VERSION}" "${inFile}"
                else
                    local message="No input file specified, can't complete"
                    _frija_completion_error_message "${message}"
                fi
            fi
            ;;

        -V|--replacement)
            print_debug "COMP_LINE='${COMP_LINE}'"
            [[ "${COMP_LINE}" =~ ^.*\ (-c|--composite=)([^\ ]*).*$ ]]
            local targetComposite="${BASH_REMATCH[2]:-}"

            [[ "${COMP_LINE}" =~ ^.*\ (-r|--repo=)([^\ ]*).*$ ]]
            local targetRepo="${BASH_REMATCH[2]:-}"

            [[ "${COMP_LINE}" =~ ^.*\ (-R|--repoVersion=)([^\ ]*).*$ ]]
            local targetVersion="${BASH_REMATCH[2]:-}"

            [[ "${COMP_LINE}" =~ ^.*\ (-l|--locale=)([^\ ]*).*$ ]]
            local targetLocaleRepo="${BASH_REMATCH[2]:-}"

            [[ "${COMP_LINE}" =~ ^.*\ (-L|--localeVersion=)([^\ ]*).*$ ]]
            local targetLocaleVersion="${BASH_REMATCH[2]:-}"

            [[ "${COMP_LINE}" =~ ^.*\ (-t|--target=)([^\ ]*).*$ ]]
            local target="${BASH_REMATCH[1]:-}"
            local targetValue="${BASH_REMATCH[2]:-}"

            # Set $_FRIJA_HOME
            _frija_locate_frija_home
            if [[ -z "${_FRIJA_HOME}" ]]; then
                local message="You are NOT within a Frija Workspace; "
                message+="not possible to give any completion suggestions"
                _frija_completion_error_message "${message}"

                # Abort completion; unfortunately we can not just exit
                # the case-switch, we have to return from the whole
                # function.
                return
            fi

            if [[ -z "${targetComposite}" && -n "${targetRepo}" ]]
            then
                # If input file only contain a single composite then
                # we can safely assume that it is this composite we
                # should consider. Thus extract all composites from
                # the input file and if there is only one, assign it
                # to $targetComposite.

                [[ "${COMP_LINE}" =~ ^.*\ (-i|--input=)([^\ ]*).*$ ]]
                local inFile="${BASH_REMATCH[2]:-}"
                inFile=$(ensure_input_file "${inFile}")

                if [[ -n "${inFile}" ]]; then
                    local result=""

                    # Set $result
                    _frija_process_option "${COMPOSITE}" "${inFile}"

                    # Allow word splitting to occur when expanding
                    # $result to get any space-separated values as
                    # individual elements in the $composites array
                    #
                    # shellcheck disable=SC2206
                    declare -a composites=( ${result} )
                    if (( ${#composites[@]} == 1 )); then
                        targetComposite="${composites[0]}"
                    fi
                fi
            fi

            if [[ -z "${targetValue}" ]] \
                     && [[ -n "${targetRepo}" ]] \
                     && [[ -n "${targetLocaleRepo}" ]]
            then
                local message="Command is ambiguous, unable to complete; "
                message+="(consider using the -t/--target option to resolve)"
                _frija_completion_error_message "${message}"


            elif [[ "${targetValue}" == "${REPO^^}" ]] \
                     && [[ -z "${targetRepo}" ]] \
                     && [[ -n "${targetLocaleRepo}" ]]
            then
                local message="Command is inconsistent, unable to complete; "
                message+="(target ${BOLD}${REPO^^}${CLEAR} used in combination "
                message+="with ${BOLD}locale${CLEAR} repo)"
                _frija_completion_warning_message "${message}"


            elif [[ "${targetValue}" == "${LOCALE^^}" ]] \
                     && [[ -n "${targetRepo}" ]] \
                     && [[ -z "${targetLocaleRepo}" ]]
            then
                local message="Command is inconsistent, unable to complete; "
                message+="(target ${BOLD}${LOCALE^^}${CLEAR} used in "
                message+="combination with ${BOLD}repo${CLEAR})"
                _frija_completion_warning_message "${message}"


            elif [[ -z "${targetRepo}" && -z "${targetLocaleRepo}" ]]
            then
                local message="Unable to complete replacement version; "
                message+="insufficient information on command line"
                _frija_completion_help_message "${message}"

            elif [[ -z "${targetComposite}" && -n "${targetRepo}" ]]; then
                local message="Unable to complete replacement version; "
                message+="missing composite for repo"
                _frija_completion_help_message "${message}"

            elif [[ "${targetValue}" == "${REPO^^}" ]] \
                     || [[ -n "${targetRepo}" && -z "${targetLocaleRepo}" ]]
            then
                local repopath="${_FRIJA_HOME}/${targetComposite}/${targetRepo}"
                if [[ -d "${repopath}" ]]; then
                    # Get version tags sorted IN FORWARD
                    # ORDER, that is lowest version first and
                    # release candidates before release
                    # versions
                    declare -a tagList=()
                    frija_git_version_tags "${repopath}" \
                                           "tagList" \
                                           "develop" \
                                           "${SORT_ASCENDING}"

                    # Ensure 'floating' is included in the list
                    tagList+=("floating")

                    # Filter $tagList so $targetVersion is not
                    # included and also trim the array (remove any
                    # empty elements) at the same time
                    _frija_filter_array "tagList" "${targetVersion}" "y"

                    result="${tagList[*]}"
                    if [[ -n "${result}" ]]
                    then
                        if [[ "${result}" != "${NON_VERSION}" ]]; then
                            local message="Listed version tags found when "
                            message+="searching from HEAD on develop branch"
                            message+=" (You might need to press TAB again)"
                            _frija_completion_note_message "${message}"
                        fi
                    else
                        local message="No replacement tags exist for "
                        message+="given repo"
                        _frija_completion_warning_message "${message}"
                    fi
                else
                    local message="Repo '${targetRepo}' in composite "
                    message+="'${composite}' has not been cloned; "
                    message+="not possible to provide any completions"
                    _frija_completion_warning_message "${message}"
                fi

            elif [[ "${targetValue}" == "${LOCALE^^}" ]] \
                     || [[ -z "${targetRepo}" && -n "${targetLocaleRepo}" ]]
            then
                local repopath="${_VOLLA_PATH}/${targetLocaleRepo}"
                if [[ -d "${repopath}" ]]; then
                    # Get version tags sorted IN FORWARD
                    # ORDER, that is lowest version first and
                    # release candidates before release
                    # versions
                    declare -a tagList=()
                    frija_git_version_tags "${repopath}" \
                                           "tagList" \
                                           "HEAD" \
                                           "${SORT_ASCENDING}"

                    # Ensure 'floating' is included in the list
                    tagList+=("floating")

                    # Filter $tagList so $targetVersion is not
                    # included and also trim the array (remove any
                    # empty elements) at the same time
                    _frija_filter_array "tagList" "${targetLocaleVersion}" "y"

                    result="${tagList[*]}"
                else
                    local message="Locale repo '${targetLocaleRepo}' "
                    message+="has not been cloned; "
                    message+="not possible to provide any completions"
                    _frija_completion_warning_message "${message}"
                fi
            else

                local message="No input file specified, can't complete"
                _frija_completion_error_message "${message}"
            fi
            ;;

        -t|--target)
            result="${REPO^^} ${LOCALE^^}"
            ;;

        -o|--os)
            # Set $_FRIJA_HOME
            _frija_locate_frija_home

            if [[ -z "${_FRIJA_HOME}" ]]; then
                local message="You are NOT within a Frija Workspace; "
                message+="not possible to give any completion suggestions"
                _frija_completion_error_message "${message}"
            else
                [[ "${COMP_LINE}" =~ ^.*\ (-i|--input=)([^\ ]*).*$ ]]
                local inFile="${BASH_REMATCH[2]:-}"
                inFile=$(ensure_input_file "${inFile}")
                if [[ -n "${inFile}" ]]; then
                    # Use an associative array (hash map) to filter
                    # out duplicate items
                    declare -A foundItems

                    local os=""
                    if [[ -f "${inFile}" ]]; then
                        print_debug "Reading from '${inFile}'"
                        while read -r os rest; do
                            os=${os//$'\r'}

                            if [[ -z "${os}" ]] || [[ "${os}" == "#"* ]]; then
                                # Skipping blank lines and comments
                                continue
                            else
                                foundItems["${os^^}"]=""
                            fi
                        done < "${inFile}"

                        # Add option for no OS preference; this is the
                        # default behavior when this option is not
                        # used
                        foundItems["${_FRIJA_ANY_OS}"]=""

                        result="${!foundItems[*]}"
                    else
                        local message="File '${inFile}' not found, "
                        message+="can't complete"
                        _frija_completion_error_message "${message}"
                    fi
                else
                    local message="No input file specified, can't complete"
                    _frija_completion_error_message "${message}"
                fi
            fi
            ;;

        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            if [[ -z "${result}" ]]; then
                local message="Current Frija Workspace is corrupt; "
                message+="no ${REPO_LIST_EXTENSION} file found"
                _frija_completion_error_message "${message}"
            fi
            ;;

        *)
            ;;
    esac

    print_debug "result='${result}'"
    echo "${result}"
}


# See frija_completion.bash for more information
function _frija_subcommand_dynamic_options()
{
    echo "a/b/c d/e/f a/e/f"
}


# See frija_completion.bash for more information
function _frija_dynamic_option_values()
{
    local option="${1}"
    local result="${NON_VERSION} "

    local pattern="^([^/]*)(/(([^/]*)(/([^/]*))?))?$"
    if [[ "${option}" =~ ${pattern} ]]; then
        local composite="${BASH_REMATCH[1]}"
        local reponame="${BASH_REMATCH[4]}"
        local repopath="${_FRIJA_HOME}/${composite}/${reponame}"

        result=$(git_list_tags "${repopath}" \
                               "HEAD" \
                               "${MATCH_LENIENT}" \
                               "${SORT_ASCENDING}" \
                               "" \
                               "" \
                               "${_FRIJA_INHIBIT_PRINTOUTS}")
    fi

    echo "${result}"
}



function _frija_subcommand_usage()
{
    cat <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  A version (for a specific combination of repo and version) can be
  updated to point to another version; a version may be
  an existing version tag reachable from develop branch or ${BOLD}${NON_VERSION}${CLEAR}.

  This means that any references to such a modified repo version are
  also automatically updated by this command.

  ${BOLD}Note:${CLEAR} This command cannot undo introduced version aliasing.
        However, the source file is never updated and instead a
        numbered copy with the new version is always created after a
        succsessful change. Thus in order to untangle aliasing that
        has been introduced the user must manually find out which
        earlier variant does not contain the unwanted aliasing and
        start over from that numbered file.

  A user may also opt to manually editing an input file, but this is
  not a recommended practice.

  Supported (and mutually excluded) variants
    - Update Repo version to use for repos cloned into workspace
        composite, repo name, version and replacement version
      must all be provided
    - Update Locale Repo version to use for repos cloned into Volla folder
        locale repo name, version and replacement version
      must all be provided

  This command is functional only in workspaces; works ${BOLD}both${CLEAR} within a
  cloned repo ${BOLD}and${CLEAR} outside of repos (for instance the workspace root).


  ${UNDERLINE_ON}${BOLD}floating${CLEAR}${UNDERLINE_ON} versions${UNDERLINE_OFF}

  The keyword ${BOLD}floating${CLEAR} refer to when no specific version is selected
  in a repo. That is, whatever is currently checked out is used. This
  is for instance exactly the case you want to have when working on
  feature branches in a repo.

  ${BOLD}Note:${CLEAR} Strictly speaking, this is also true when a specific version
        of a repo ${BOLD}cloned into a Frija workspace${CLEAR} is selected. What
        happen then is that a Git Worktree is automatically created
        (named after both the repo and the version tag) where the
        selected version within the repo is the version tag (such a
        repo is said to be in a "headless" state). But nothing stops a
        user from checking out another version for that worktree and
        Frija would be none the wiser.

${BOLD}Options:${CLEAR}
  -cCOMP,               composite COMP to modify version for
   --composite=COMP       ${BOLD}Note:${CLEAR} May not be used with -l/--locale

  -rREPO,               repo REPO to modify version for
   --repo=REPO            ${BOLD}Note:${CLEAR} May not be used with -l/--locale

  -RVER,                repo vesrion VER; is either a version tag found in the
   --repoVersion=VER      input file or the keyword ${BOLD}floating${CLEAR}

  -lLOCALE,             name of already cloned locale repo LOCALE to modify used
   --locale=LOCALE        version for
                          ${BOLD}Note:${CLEAR} May not be used with any of
                                -c/--composite or -r/--repo

  -LVER,                locale repo version VER; is either an existing version
   --localeVersion=VER    tag found in the input file or the keyword ${BOLD}floating${CLEAR}

  -VVER,                replacecment version VER; is either an existing version
   --replacement=VER      tag for the referenced repo or the keyword ${BOLD}floating${CLEAR}

  -tTARGET              apply version change to TARGET; option only required
   --target=TARGET        when command line is ambigious
                          - TYPE "REPO" means change repo version
                          - TYPE "LOCALE" means change locale repo version

  -o[OS],               apply change to repos associated with OS listed in input
   --os[=OS]              file. To apply change to any OS the keyword ANY is
                          used which is also the ${BOLD}default${CLEAR} value.

  -iFILE,               modify version for a repo or locale repo listed in FILE
   --input=FILE

  -v,                   verbose output
   --verbose

  -h,                   print this message
   --help

  -d,                   enable debug printouts sent to stderr
   --debug

  -D,                   do not execute commands with side effects, just echo
   --dry-run              them
EOF
};


