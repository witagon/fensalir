################################################################################

# Given two triplets { composite, version, reponame } and replacement
# version, either return the replacement version if both triplets
# match or the current version if they do not match. That is, if
#
# First triplet: { "foo", "1.2.3", "bar" }
# Second triplet: { "foo", "1.2.3", "bar" }
# Replacement version: "2.3.4"
#
# Then "2.3.4" is returned (as all fields in both triplets match). On
# the other hand, if
#
# First triplet: { "foo", "1.2.3", "bar" }
# Second triplet: { "foo", "2.1.3", "bar" }
# Replacement version: "2.3.4"
#
# Then "1.2.3" is returned (as "1.2.3" and "2.1.3" do not match).
#
#
# First parameter: Current composite
# Second parameter: Current version
# Third parameter: Current repo name
# Fourth parameter: Target composite
# Fifth parameter: Target version
# Sixth parameter: Target repo name
# Seventh parameter: Replacement version if both triplets match
#
# Returns replacement version if there is a match, otherwise current version.
function update_repo_version()
{
    print_debug_enter "${@}"

    local currentComposite="${1}"
    local currentVersion="${2}"
    local currentReponame="${3}"

    local targetComposite="${4}"
    local targetRepo="${5}"
    local targetVersion="${6}"

    local replacementVersion="${7}"

    local result="${currentVersion}"


    if [[ "${targetValue}" == "${REPO}" ]]; then

        if [[ -n "${targetLocaleRepo}" ]]; then
            if [[ -z  "${externalDeps}" ]]; then
                # User requires that there is an external dependency
                # for the change to go through
                return
            else
                # If there is no match, then the change is vetoed and
                # there is no point in continuing
                local repoName=""
                local version=""
                local rest=""

                IFS=';' read -r repoName version rest <<< "${externalDeps}"

                if [[ "${targetLocaleRepo}" != "${repoName}" ]]; then
                    return
                elif [[ "${targetLocaleVersion}" != "${version}" ]]; then
                    return
                fi
            fi
        fi

        if [[ "${currentComposite}" == "${targetComposite}" ]]; then
            if [[ "${currentReponame}" == "${targetRepo}" ]]; then
                if [[ "${currentVersion}" == "${targetVersion}" ]]; then
                    result="${replacementVersion}"
                fi
            fi
        fi
    fi

    print_debug_exit "${result}"
    echo "${result}"
}


# Replaces <version> with given value in a string formatted like this
#
# <composite>;<version>;<repo name>,...,<composite>;<version>;<repo name>
#
# Provided that <composite>, <version>, and <repo name> matches. That
# is each sub-sequence separated by ',' is considered independently.
# When there is only one such sub-sequence then it must not end with
# ','.
#
#
# First parameter: String to update (assumed to be in a;b;c format)
#
# Second parameter: Composite name that must match
#
# Third parameter: Repo name that must match
#
# Fourth parameter: Version that must match
#
# Fifth parameter: Version to replace with
#
# Returns updated string.
function update_dependency()
{
    print_debug_enter "${@}"

    local dependencies="${1}"
    local targetComposite="${2}"
    local targetRepo="${3}"
    local targetVersion="${4}"
    local replacementVersion="${5}"

    local composite=""
    local version=""
    local repoName=""

    local result="${dependencies}"

    if [[ "${targetValue}" == "${REPO}" ]]; then

        if [[ -n "${targetLocaleRepo}" ]]; then
            if [[ -z  "${externalDeps}" ]]; then
                # User requires that there is an external dependency
                # for the change to go through
                return
            else
                # If there is no match, then the change is vetoed and
                # there is no point in continuing
                local repoName=""
                local version=""
                local rest=""

                IFS=';' read -r repoName version rest <<< "${externalDeps}"

                if [[ "${targetLocaleRepo}" != "${repoName}" ]]; then
                    return
                elif [[ "${targetLocaleVersion}" != "${version}" ]]; then
                    return
                fi
            fi
        fi

        # Reset $result so there is a clean starting point
        result=""

        # Iterate over dependencies separated by comma
        local dep=""
        while read -d, -r dep; do
            if [[ "${dep}" == "${NONE}" ]]; then
                result+="${dep}"
                break;
            else
                IFS=';' read -r composite version repoName <<< "${dep}"

                if [[ "${composite}" == "${targetComposite}" ]]; then
                    if [[ "${repoName}" == "${targetRepo}" ]]; then
                        if [[ "${version}" == "${targetVersion}" ]]; then
                            version="${replacementVersion}"
                        fi
                    fi
                fi

                result+="${result:+,}${composite};${version};${repoName}"
            fi
        done <<< "${dependencies}," # Add ',' to cover single-item case
    fi

    print_debug_exit "${result}"
    echo "${result}"
}


# Replaces <version> with given value in a string formatted like this
#
# <repo name>;<version>;<field #1>,...,<field #n>;<field #1>,...,<field #n>
#
# Where field lists may be empty. A version replacement ONLY occurs
# when there is a match with both <repo name> and <version>.
#
#
# First parameter: String to update (assumed to be in a;b;c;d format)
#
# Second parameter: Name of repo to match with
#
# Third parameter: Version to match with
#
# Fifth parameter: Version to replace with
#
# Returns updated string.
function update_external_dependency()
{
    print_debug_enter "${@}"

    local dependencies="${1}"
    local targetLocaleRepo="${2}"
    local targetVersion="${3}"
    local replacementVersion="${4}"

    local result="${dependencies}"

    if [[ "${targetValue}" == "${LOCALE}" ]]; then

        if [[ -n "${targetComposite}" ]] \
               && [[ "${composite}" != "${targetComposite}" ]]
        then
            # User has selected a composite on the command line and
            # there is no match
            echo "${result}"
            return
        fi

        if [[ -n "${targetRepo}" ]] \
               && [[ "${repoName}" == "${targetRepo}" ]]
        then
            # User has selected a repo on the command line and there
            # is a match, now check if there is perhaps a repo version
            # mismatch
            if [[ -n "${targetRepoVersion}" ]] \
                   && [[ "${version}" != "${targetRepoVersion}" ]]
            then
                # User has also selected a repo version on the command
                # line and there is no match
                echo "${result}"
                return
            fi
        else
            # User has only selected a repo but no repo-version on
            # the command line and there is no match
            echo "${result}"
            return
        fi

        if [[ -n "${dependencies}" ]]; then
            local repoName=""
            local version=""
            local rest=""

            IFS=';' read -r repoName version rest <<< "${dependencies}"

            if [[ "${repoName}" == "${targetLocaleRepo}" ]]; then
                if [[ "${version}" == "${targetVersion}" ]]; then
                    version="${replacementVersion}"
                fi
            fi

            result="${repoName};${version};${rest}"
        fi
    fi

    print_debug_exit "${result}"
    echo "${result}"
}


function create_output_line()
{
    print_debug_enter "${@}"

    local os="${1}"
    local vcs="${2}"
    local composite="${3}"
    local version="${4}"
    local uri="${5}"
    local repoKind="${6}"
    local tool="${7}"
    local dependencies="${8}"
    local toolDependencies="${9}"
    local locale="${10}"
    local externalDeps="${11:-}"
    local rest="${12:-}"

    local result=""
    result+="${os}"
    result+="${vcs}"
    result+="${composite}"
    result+="${version}"
    result+="${uri}"
    result+="${repoKind}"
    result+="${tool}"
    result+="${dependencies}"
    result+="${toolDependencies}"
    result+="${locale}"

    if [[ -n "${externalDeps}" ]]; then
        result+="${externalDeps}"
        if [[ -n "${rest}" ]]; then
            result+="${rest}"
        fi
    fi

    print_debug_exit "${result}"
    echo "${result}"
}
################################################################################
# Find input file with highest sequence number; we do not know if we
# were handed an input file with mid sequence number or not.
declare -i highest=-1
sansSequenceNumber=""

# Start by getting the everything up to (but not including) any
# existing sequence number or extension
sequenceNumberPattern="^(((.*/)+)?[^/~]+)(~([1-9][0-9]*))?"
sequenceNumberPattern+="[.]${REPO_LIST_EXTENSION_NO_DOT}$"

declare -i FILENAME_INDEX=1
declare -i SEQUENCE_NUMBER_INDEX=5

# Obtain part of input filename without any sequence number nor
# extension $REPO_LIST_EXTENSION. This is used below for creating a
# file GLOB pattern to get a list of all filenames starting with this
# prefix and ending with the extension.
if [[ "${inFile}" =~ ^${sequenceNumberPattern}$ ]]; then
    sansSequenceNumber="${BASH_REMATCH[${FILENAME_INDEX}]}"
else
    message="Input filename error: '${inFile}' does not match regular "
    message+="expression '${sequenceNumberPattern}', aborting."

    print_error "${message}" _FRIJA_EXIT_INTERNAL_ERROR
fi

# Then iterate over all files starting with the same character
# sequence; within the loop we further downselects the files to
# consider by checking against our regexp above to find the file name
# with the highest sequence number
for file in "${sansSequenceNumber}"*"${REPO_LIST_EXTENSION}"; do
    if [[ "${file}" =~ ${sequenceNumberPattern} ]]; then
        if [[ -n "${BASH_REMATCH[${SEQUENCE_NUMBER_INDEX}]}" ]]; then
            declare -i current="${BASH_REMATCH[${SEQUENCE_NUMBER_INDEX}]}"
            (( current > highest )) && highest=${current}
        fi
    fi
done
print_debug "highest='${highest}'"

nextSequenceNumber="1"
if (( highest > 0 )); then
    nextSequenceNumber=$(( highest+1 ))
fi
print_debug "nextSequenceNumber='${nextSequenceNumber}'"

# This is the name of the transformed output file. If nothing is
# changed compared to $inFile then this file is removed before this
# script exits.
outFile="${sansSequenceNumber}~${nextSequenceNumber}${REPO_LIST_EXTENSION}"

message=""
# Ensure we can create a file named $outFile
if [[ -d "${outFile}" ]]; then
    message="Found directory named '${outFile}', cannot step sequence "
    message+="number for '${inFile}', aborting."
elif [[ -f "${outFile}" ]]; then
    message="'${outFile}' already exist; cannot step sequence "
    message+="number for '${inFile}', aborting."
fi

if [[ -n "${message}" ]]; then
    print_error "${message}" _FRIJA_EXIT_OTHER_PROBLEM
fi

print_debug "verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}"

# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_HOME or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
_frija_locate_frija_home
REPO_SUBPATH=$(cwd_in_workspace_repo_folder_p "")
cd "${_FRIJA_HOME}"

print_message "REPO_SUBPATH='${REPO_SUBPATH}'"


# TODO: Generalize this; install a trap for ERR-signal next to where
# it is done for EXIT. That function should write the generic error
# message and check if the function "error_handler" exist and if so
# call it.

# Error handler function used for cleaning up any output file created
# by this Frija command. Intended to be called from an installed trap.
function error_handler()
{
    declare -i error=$?

    local message="${BOLD}${BASH_LINENO[0]}:${FUNCNAME[1]}:${CLEAR} "
    message+="Line resulted in exit code ${error}."
    print_message "${message}"

    if [[ -n "${outFile}" ]]; then
        # Clean up any generated file without triggering any new trap
        rm -f "${outFile}"
        if [[ -e "${outFile}" ]]; then
            message="Unable to clean up partially generated file '${outFile}', "
            message+="${BOLD}please remove this file manually${CLEAR}."
        else
            message="Successfully removed partially generated file "
            message+="'${outFile}'."
        fi
    else
        message="File '${outFile}' not yet created; nothing to clean up."
    fi

    print_message "${message}"
    print_message "Frija command aborted prematurely."
}

# Install error handler trap for ERR signal calling error_handler();
# the ERR signal is raised when an error occurs.
#
# There is already a trap installed for the EXIT signal which is
# raised just before the shell exits. The EXIT-signal can not be used
# here since Bash clears BASH_LINENO etc. before calling the
# registered trap for that signal. However, Bash do not touch those
# variables when the ERR-signal is raised, and due to this it is
# suitable for cleaning up any partially created file.
trap error_handler ERR


# Apply a regular expression multiple times and a capture group to
# stdout each time there is a match. Capture group #0 is removed from
# the beginning of the input string before the regular expression is
# applied aagain. The process is repeated until there no longer is any
# match.
#
# By default capture group #1 is echoed to stdout, but this may be
# overridden. See parameter 3 below for more information.
#
#
# The output from this function may be stored in array $matches by doing
#
# mapfile -t matches < <(global_rematch "${string}" "${regex}")
#
#
# Parameter 1: String to process
#
# Parameter 2: Regular expression to apply
#
# Parameter 3: Capture group to echo to stdout (optional); must be a
# positive integer, default value is 1 (one)
function global_rematch()
{
    local string="${1}"
    local regex="${2}"
    declare -i index="${3:-1}"

    while [[ "${string}" =~ ${regex} ]]; do
        # Make it possible to "capture" our match by the caller of
        # this function
        echo "${BASH_REMATCH[index]}"

        # Chop of the prefix stored in $BASH_REMATCH[0], that is the
        # complete match, so we can move on to the next part and see
        # if that matches and so on
        string=${string#*"${BASH_REMATCH[0]}"}
    done
}


print_separator
print_message "Reading from '${inFile}'"
print_message "Writing to '${outFile}'"
print_separator


# Flag used for detecting if no repos were touched; if it is non-empty
# after processing then no repos were touched
processedReposFlag=""


# Regular expression that captures sequence of whitespace before a
# non-whitespace sequence where '[:blank:]' is a character class
# matching a single blank character (space and tab). This means that
# the regular expression matches zero or more blank characters
# (anchored at the beginning of the line) followed by at least one
# non-blank character. The blank characters are stored in catching
# group #1.
WHITESPACE_REGEX="^([[:blank:]]*)[^[:blank:]]+"

print_debug "    targetComposite='${targetComposite}'"
print_debug "         targetRepo='${targetRepo}'"
print_debug "      targetVersion='${targetVersion}'"
print_debug "   targetLocaleRepo='${targetLocaleRepo}'"
print_debug "targetLocaleVersion='${targetLocaleVersion}'"
print_debug "        targetValue='${targetValue}'"
print_debug " replacementVersion='${replacementVersion}'"
print_debug "         selectedOS='${selectedOS}'"
print_debug "=================================================================="

# Now read from the input file and clone the repos!
# -r make read to not treat backslash character as an escape character
while read -r line; do
    if [[ -z "${line}" ]] || [[ "${line}" == "#"* ]]; then
        # Copy line to output; either empty or commented line
        echo "${line}" >> "${outFile}"

        # Skip to next line
        continue
    fi

    # Extract whitespace before and between the fields and store them
    # in an array. This is needed to recreate the line (minus any
    # trailing whitespace at the end of the line).
    declare -a whitespace=()
    mapfile -t whitespace < <(global_rematch "${line}" "${WHITESPACE_REGEX}")

    # Items to read from the line
    declare -a items=("os"
                      "vcs"
                      "composite"
                      "version"
                      "uri"
                      "repoKind"
                      "tool"
                      "dependencies"
                      "toolDependencies"
                      "locale"
                      "externalDeps"
                      "rest")

    # Ensure $whitespace contain at least the same amount of items as
    # $items does
    declare -i itemcount=${#items[@]}
    declare -i wscount=${#whitespace[@]}
    declare -i count=$(( itemcount - wscount ))
    if (( count > 0 )); then
        for ((index=0; index<count; index++)); do
            # Add empty string to force creation of an "empty" element
            # in the array so no unbound variable error is triggered
            # when accessing this index.
            whitespace+=("")
        done
    fi

    # Parse line we just read; values are stored in the variable names
    # listed in $items, the expression ${items[@]} (NOT "${items[@]}")
    # expands to a space separated list of the values which then the
    # read command uses to assign values to the respective variable
    # names.
    read -r "${items[@]}" <<< "${line}"

    # Strip any carriage returns from the read values
    for element in "${items[@]}"; do
        # We are forced to use eval here since it is not possible to
        # do indirect assignments in Bash 4.2. However named variable
        # references might work which are included in Bash 4.3 and if
        # so the code would be much cleaner.
        eval "${element}=\${${element}//\$'\\r'}"
        print_debug "${element}='${!element}', "
    done

    print_debug_indirect_array "items"

    repoName=""
    case "${vcs}" in
        git)
            if [[ "${uri}" =~ ${GIT_REPO_PATTERN} ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
            else
                message="Unsupported ${BOLD}Git repo URI path${CLEAR}: "
                message+="URI is '${uri}' and pattern is "
                message+="'${GIT_REPO_PATTERN}', aborting."
                print_error "${message}" \
                            $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi
            ;;
        *)
            message="Unsupported VCS: '${vcs}' for '${uri}' found in input "
            message+="file '${inFile}', aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            ;;
    esac

    print_debug "repoName='${repoName}'"


    if [[ "${selectedOS}" == "${_FRIJA_ANY_OS}" ]] \
           || [[ "${selectedOS}" == "${os^^}" ]]
    then
        outputVersion=$(update_repo_version "${composite}" \
                                            "${version}" \
                                            "${repoName}" \
                                            "${targetComposite}" \
                                            "${targetRepo}" \
                                            "${targetVersion}" \
                                            "${replacementVersion}")
        if [[ "${version}" != "${outputVersion}" ]]; then
            message="${repoName}: Repo version '${version}' "
            message+="=> '${outputVersion}'"
            print_message "${message}"
            processedReposFlag="y"
        fi
        print_debug "outputVersion='${outputVersion}'"

        outputDeps=$(update_dependency "${dependencies}" \
                                       "${targetComposite}" \
                                       "${targetRepo}" \
                                       "${targetVersion}" \
                                       "${replacementVersion}")
        if [[ "${dependencies}" != "${outputDeps}" ]]; then
            message="${repoName}: Repo dependencies '${dependencies}' "
            message+="=> '${outputDeps}'"
            print_message "${message}"
            processedReposFlag="y"
        fi
        print_debug "outputDeps='${outputDeps}'"

        outputToolDeps=$(update_dependency "${toolDependencies}" \
                                           "${targetComposite}" \
                                           "${targetRepo}" \
                                           "${targetVersion}" \
                                           "${replacementVersion}")
        if [[ "${toolDependencies}" != "${outputToolDeps}" ]]; then
            message="${repoName}: Tool dependencies '${toolDependencies}' "
            message+="=> '${outputToolDeps}'"
            print_message "${message}"
            processedReposFlag="y"
        fi
        print_debug "outputToolDeps='${outputToolDeps}'"

        outputExtDeps=$(update_external_dependency "${externalDeps}" \
                                                   "${targetLocaleRepo}" \
                                                   "${targetVersion}" \
                                                   "${replacementVersion}")
        if [[ "${externalDeps}" != "${outputExtDeps}" ]]; then
            message="${repoName}: External dependencies '${externalDeps}' "
            message+="=> '${outputExtDeps}'"
            print_message "${message}"
            processedReposFlag="y"
        fi
        print_debug "outputExtDeps='${outputExtDeps}'"

        outputLine=$(create_output_line "${whitespace[0]}${os}" \
                                        "${whitespace[1]}${vcs}" \
                                        "${whitespace[2]}${composite}" \
                                        "${whitespace[3]}${outputVersion}" \
                                        "${whitespace[4]}${uri}" \
                                        "${whitespace[5]}${repoKind}" \
                                        "${whitespace[6]}${tool}" \
                                        "${whitespace[7]}${outputDeps}" \
                                        "${whitespace[8]}${outputToolDeps}" \
                                        "${whitespace[9]}${locale}" \
                                        "${whitespace[10]}${outputExtDeps}" \
                                        "${whitespace[11]}${rest}")
        print_debug "outputLine='${outputLine}'"
        echo "${outputLine}" >> "${outFile}"
    else
        # Copy line to output
        echo "${line}" >> "${outFile}"
    fi
done < "${inFile}"

if [[ -z "${processedReposFlag}" ]]; then
    print_warning "No repo lines were modified when creating '${outFile}'"
    print_message
else
    print_double_separator
    print_message "New repos file '${BOLD}${outFile}${CLEAR}' created"
    print_message
fi
