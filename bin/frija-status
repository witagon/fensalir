#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")

# Remove shortest suffix matching "/*", i.e. last part of path
_FRIJA_PROGRAM_DIR="${_FRIJA_PROGRAM_PATH%/*}"


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "wai:vhdf:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "wordy,all,input:,verbose,help,debug,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Report repo status for repos listed in given repo-list file.
EOF
}


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            ;;
        -f|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    cat <<EOF
Usage: ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  NOTE: Command require current working directory is within ${BOLD}frija${CLEAR} folder
      structure.

  ${BOLD}Note:${CLEAR} The behavior of the command varies slightly depending on where
        you are in the filesystem. If you are within a repo, then by
        default the operation is applied only to that repo (this can
        be overridden, see below). On the other hand, if you are in
        the frija root folder (for instance the Jira ticket folder)
        then the operation is applied to all repos referenced from the
        input file that are for the current OS.

${BOLD}Options:${CLEAR}
  -w, --wordy           show more verbose progress and status for all repos
  -a, --all                 ${BOLD}when${CLEAR} inside a repo ${BOLD}and${CLEAR} this option is set it will
                              force command to operate on all repos applicable
                              to current OS, ${BOLD}otherwise${CLEAR} it has ${BOLD}no effect${CLEAR}
  -iFILE, --input=FILE  operate on repos listed in FILE
  -v, --verbose         verbose output
  -h, --help            print this message
  -d, --debug           enable debug printouts
                          ${BOLD}Note:${CLEAR} Debug messages are prefixed with "*** LINE"
                                where LINE is current line number.
EOF
    # Print common input file format documentation, see .preamble
    print_file_format_doc

    # Print common exit codes documentation, see .preamble
    print_exit_codes_doc
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${METADATATOOLS_HOME}/.preamble.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


WORDY="n"
VERBOSE="n"
DEBUG="n"
autoInFile=$(auto_locate_repo_file)
allRepos="n"
inFile=""
osOverride=""

# Iterate over options in order and nicely split until we see --
while true; do
    case "$1" in
        -w|--wordy)
            ensure_boolean_option_not_set "Wordy" "${WORDY}"
            WORDY="y"
            shift  # Move to next option
            ;;
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit 0
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -f|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is $1 and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done


# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    OPERATING_SYSTEM="${osOverride}"
fi

# Allow explicit command line to specify inFile and override the
# automatically found inFile. This case is only valid when there is a
# single repo-list file.
inFile="${inFile:-${autoInFile}}"
if [[ -z "${inFile}" ]]; then
    print_error "No input file specified." 2
fi

# Append extension AFTER above check; otherwise we would
# not be able to detect if $inFile is empty
inFile="${inFile}${REPO_LIST_EXTENSION}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    print_error "Command does not support any arguments." 4
fi


if [[ "${DEBUG}" == "y" ]]; then
    echo "*** ${LINENO}  verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}" >&2
fi


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_HOME or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
_frija_locate_frija_home
REPO_SUBPATH=$(cwd_in_frija_repo_folder_p)
cd "${_FRIJA_HOME}"


if [[ "${DEBUG}" == "y" ]]; then
    echo "*** ${LINENO}  verbose: ${VERBOSE}, debug: ${DEBUG}, in: $inFile"
fi


UNTRACKED="untracked"
UNSTAGED="unstaged"
STAGED="staged"
DELETED="deleted"
RENAMED="renamed"


# Status for a git repo
GIT_STATUS=""

function print_status()
{
    local type="${1}"
    local pattern=""

    declare -i count=0

    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** $LINENO  type='${type}'"
    fi

    case "${type}" in
        "${UNTRACKED}")
            pattern="^[?][?]"
            ;;
        "${UNSTAGED}")
            pattern="^ M"
            ;;
        "${STAGED}")
            pattern="^\\(M\\|A\\) "
            ;;
        "${DELETED}")
            pattern="^D "
            ;;
        "${RENAMED}")
            pattern="^R "
            ;;
        *)
            print_error "Internal error; unsupported type '${type}'." 3
            ;;
    esac

    ! count=$(grep -c -e "${pattern}" <<< "${GIT_STATUS}")
    if [[ ${PIPESTATUS[0]} -eq 0 ]]; then
        if (( count > 0 )); then
            plural=$(plural "$count")
            printf "%3s ${type} file${plural}\\n" "${count}"

            # -r make read to not treat backslash character
            # as an escape character
            while IFS= read -r line; do
                if [[ "${line}" =~ ${pattern} ]]; then
                    # shellcheck disable=SC2034
                    while read -r marker file; do
                        echo "    ${file}"
                    done<<<"${line}"
                fi
            done<<<"${GIT_STATUS}"
        fi
    fi
}


########
# Iterate over the lines in the input file and act on each line
# depending on VCS field.

if [[ "${WORDY}" == "n" ]]; then
    print_message "Please wait, reading from ${inFile} and checking if there are any changes..."
else
    print_message "Reading from ${inFile} and checking if there are any changes..."
    print_separator
fi

processedReposFlag=""
declare -a skippedOperatingSystems=()
declare -A uniqueSkippedOperatingSystems=()

# Now read from the input file and clone the repos!
# -r make read to not treat backslash character as an escape character
while read -r os source mg version uri rest; do
    # Strip any carriage returns from the read values
    os=${os//$'\r'}
    source=${source//$'\r'}
    mg=${mg//$'\r'}
    version=${version//$'\r'}
    uri=${uri//$'\r'}
    rest=${rest//$'\r'}

    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** $LINENO  os='${os}', source=${source}, version=${version}, uri=${uri}, rest=${rest}"
    fi

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        skippedOperatingSystems+=("${os}")
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    case ${source} in
        git)
            if [[ "$uri" =~ $GIT_REPO_PATTERN ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination=$(make_destination "${mg}" "${repoName}" "${version}")
            else
                print_error "Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is '${uri}' and pattern is '${GIT_REPO_PATTERN}', aborting." 6
            fi
            ;;
        *)
            print_error "Unsupported SOURCE: '${source}' for '${uri}', aborting." 6
            ;;
    esac


    if [[ -n "${REPO_SUBPATH}" ]] && [[ "${allRepos}" == "n" ]]; then
        # REPO_SUBPATH is set, this means that A) we are somewhere
        # below _FRIJA_HOME and B) we are within a repo.
        #
        # NOTE: If inside a repo and 'wholly' option is set, then it
        # will override this behavior and force all repos to be
        # operated on regardless.
        print_debug "REPO_SUBPATH='${REPO_SUBPATH}'"
        if [[ "${REPO_SUBPATH}" != "${destination}"* ]]; then
            print_debug "destination='${destination}'"
            # In this case we should ONLY operate on repos where
            # REPO_SUBPATH and destination matches, which means that
            # for all other repos we should just skip it and move on
            # to the next one.
            continue;
        fi
    fi


    case ${source} in
        git)
            # Will return exit code 128 if not in a git repo.
            command=(git status "--porcelain=v1")

            print_debug "repoName: ${repoName}"
            print_debug "destination: ${destination}"
            print_debug "command: ${command[*]}"

            if [[ -d "${destination}" ]]; then
                # Save current working directory
                ! pushd "${destination}" &> /dev/null

                if [[ "${VERBOSE}" == "y" ]]; then
                    print_newline_after_dot
                    # Send any stderr output from command to terminal
                    print_separator "${destination}"
                    "${command[@]}"
                    print_separator "${destination}"
                else
                    # Ignore anything sent to stdout and stderr
                    ! GIT_STATUS=$(${command[*]}) 2>/dev/null
                    if [[ ${PIPESTATUS[0]} -ne 128 ]]; then
                        # Get current branch
                        branch=$(git branch --show-current)

                        print_debug "branch='${branch}'"
                        print_debug "GIT_STATUS='${GIT_STATUS}'"

                        if [[ -n "${GIT_STATUS}" ]]; then
                            changeFound="y"
                            if [[ "${WORDY=}" == "n" ]]; then
                                # Only print a newline if at least one
                                # dot has been printed
                                print_newline_after_dot
                            fi

                            print_newline_after_dot
                            echo "${BOLD}${repoName}${CLEAR} ($destination)"
                            if [[ -z "${branch}" ]]; then
                                echo "  ${BOLD}WARNING!${CLEAR} Headless repo is modified"
                                tag="${version}"
                                validate_tag "${tag}"
                                echo "  Repo at ${BOLD}${tag}${CLEAR} (Detached HEAD)"
                            else
                                echo "  ${BOLD}$branch${CLEAR}"
                            fi

                            echo "  ${UNDERLINE_ON}Branch status${UNDERLINE_OFF}"
                            print_debug "GIT_STATUS: '${GIT_STATUS}'"

                            print_status "${UNTRACKED}"
                            print_status "${UNSTAGED}"
                            print_status "${STAGED}"
                            print_status "${DELETED}"
                            print_status "${RENAMED}"

                        elif [[ -z "${branch}" ]]; then
                            # Headless state
                            print_debug "Repo in headless state!"
                            tag="${version}"

                            print_debug "Validating tag '${tag}'..."
                            validate_tag "${tag}"
                            print_debug "Done."

                            if [[ "${WORDY}" == "y" ]]; then
                                print_newline_after_dot
                                echo "${BOLD}${repoName}${CLEAR} ($destination)"
                                echo "  Repo at ${BOLD}${tag}${CLEAR} (Detached HEAD)"
                            else
                                print_dot
                            fi
                        else
                            GIT_STATUS=$(git diff "@{u}" | wc -l)
                            if [[ "${GIT_STATUS}" -eq 0 ]]; then
                                if [[ "${WORDY}" == "y" ]]; then
                                    print_newline_after_dot
                                    echo "${BOLD}${repoName}${CLEAR} ($destination)"
                                    echo "  ${BOLD}$branch${CLEAR}"
                                    echo "  Branch is up to date."
                                else
                                    print_dot
                                fi
                            else
                                changeFound="y"
                                print_newline_after_dot
                                echo "${BOLD}${repoName}${CLEAR} ($destination)"
                                echo "  ${BOLD}$branch${CLEAR}"
                                echo "  Branch contain unpushed commits."
                            fi
                        fi
                    else
                        print_newline_after_dot
                        print_command_failure_status "${PIPESTATUS[0]}" "${command[*]}"
                    fi
                fi

                # Restore current working directory
                ! popd &> /dev/null
            else
                print_newline_after_dot
                echo "   $destination NOT cloned, skipping."
            fi
            ;;
        *)
            print_message "Unsupported SOURCE: '${source}', skipping '${uri}'."
            ;;
    esac
    processedReposFlag="y"
done < "$inFile"

print_newline_after_dot

if [[ "${WORDY}" == "n" && "${processedReposFlag}" == "y" ]] && \
       [[ -z "${changeFound}" ]]; then
    print_newline_after_dot
    if [[ "${allRepos}" == "n" ]]; then
        print_message "Repo is up to date!"
    else
        print_message "All repos are up to date!"
    fi
fi

if [[ -z "${processedReposFlag}" ]]; then
    # Make $skippedOperatingSystems unique by using an associative
    # array (hashmap)
    for i in "${skippedOperatingSystems[@]}"; do
        uniqueSkippedOperatingSystems["${i}"]=1
    done
    print_message ""
    print_message "====================="
    print_message "${BOLD}No repos were processed!${CLEAR}"
    print_message "====================="
    print_message ""
    print_message "Current OS is ${BOLD}${OPERATING_SYSTEM}${CLEAR} and all entries in"
    print_message "  ${BOLD}${inFile}${CLEAR}"
    print_message "required the following operating system$(plural ${#skippedOperatingSystems[@]})${BOLD}"
    printf '  %s\n' "${!uniqueSkippedOperatingSystems[@]}"
    print_message "${CLEAR}"
    print_message "Are you sure you are using an input file designed for your OS?"
fi
