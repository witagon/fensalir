#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "wai:vhdF:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "wordy,all,input:,verbose,help,debug,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Repo status is shown for applicable repos within a workspace.
EOF
}


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            if [[ -z "${result}" ]]; then
                local message="Current Frija Workspace is corrupt; "
                message+="no ${REPO_LIST_EXTENSION} file found"
                _frija_completion_help_message "${message}"
            fi
            ;;
        -F|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

${BOLD}
  Behavior of this command varies slightly depending on where you are
  within generic folder structure shown below${CLEAR}
    WORKSPACE
          |
          +-- COMPOSITE-NAME
                         |
                         +-- REPO

  The basic rule of thumb is that when you are within a REPO then this
  command is ONLY applied to that repo, otherwise it is applied to
  applicable repos listed in the input file.

  This default rule-of-thumb-behavior can be overridden in two ways
  when you are within a REPO. Either you give the -a/--all option or
  you specify which input file to use on the command line. The result
  is the same for both variants, namely that the command is applied to
  all applicable repos listed in the given input file.

  The -a/--all option is only a shortcut for the case when you want to
  just use the default input file and apply this command to all
  applicable repos listed in that file.

${BOLD}Options:${CLEAR}
  -w,                 show more verbose progress and status messages
   --wordy
  -a,                 apply command to all applicable repos listed in input
   --all                file; default or given on the command line via
                        -i/--input option. This option is applied by default
                        when outside of a repo (but still within a workspace).

  -iFILE,             apply operation to repos listed in FILE
   --input=FILE
  -v,                 verbose output
   --verbose
  -h,                 print this message
   --help
  -d,                 enable debug printouts sent to stderr
   --debug
  -FOS,               force command to assume given OS instead of detected OS
   --force=OS

${BOLD}See also:${CLEAR}
  (frija) ${BOLD}clone${CLEAR} and ${BOLD}fetch${CLEAR}

EOF
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${_FENSALIR_HOME}/.preamble.bash"

if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi

################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


# Configure Bash options
_frija_configure_bash


_FRIJA_PRINT_DEBUG=""
#message="modified   ${BOLD}fooobar${CLEAR}"
#print_message "${message}" 2
#message="modified   ${BOLD}gazonk${CLEAR}"
#print_message "${message}" 2
#exit 0

WORDY="n"
VERBOSE="n"
DEBUG="n"
allRepos="n"
inFile=""
osOverride=""

# Iterate over options in order and nicely split until we see --
while true; do
    case "$1" in
        -w|--wordy)
            ensure_boolean_option_not_set "Wordy" "${WORDY}"
            WORDY="y"
            shift  # Move to next option
            ;;
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -F|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is $1 and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done


################################################################################
# Consistency checks
################################################################################

# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    OPERATING_SYSTEM="${osOverride}"
fi

# Ensure we have an input file and that it has a valid extension
inFile=$(ensure_input_file "${inFile}")

# In case user has provided an input file with an explicit search path
# we must remove it in order to obtain the system name from the input
# filename. And also remove $REPO_LIST_EXTENSION from it.
SYS_NAME="${inFile##*/}"
SYS_NAME="${SYS_NAME%%${REPO_LIST_EXTENSION}}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


print_debug "verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}"


# Include generic VCS support.
#
# shellcheck source=./.vcs_functions.bash
source "${_FENSALIR_HOME}/.vcs_functions.bash"


# Check if current working directory is inside a repo located within a
# workspace or not (path to $PWD starts with $_FRIJA_WS_PATH). If that is
# the case then REPO_SUBPATH contain a non-empty string.
_frija_locate_workspace
REPO_SUBPATH=$(cwd_in_workspace_repo_folder_p "")

if [[ -z "${REPO_SUBPATH}" ]]; then
    # Current working directory is not within a repo, this means that
    # implicitly allRepos has been set to 'y'. Set it explicitly as
    # this simplifies code below.
    allRepos="y"
fi

# Enter the workspace folder so we have a common base regardless of
# where the caller of this command was within the workspace folder
# tree
cd "${_FRIJA_WS_PATH}"


########
# Iterate over the lines in the input file and act on each line
# depending on $os and $vcs fields.

message="Reading from ${inFile} and checking if there are any changes..."
print_message "${message}"
print_separator

processedReposFlag=""
foundOperatingSystem=""
changeFound=""
declare -a skippedOperatingSystems=()

dotPrinted=""

# Now read line by line from the input file and build the repos!
#
# The -r flag causes read command to not treat backslash character as
# an escape character
#
# Any leading whitespace is automatically stripped by read command
while read -r line; do
    if [[ -z "${line}" ]]; then
        # Skip to next entry since it is an empty line
        continue
    fi

    if [[ "${line}" == "#"* ]]; then
        # Parse line and assign to global variable if comment contains
        # a known key-value pair
        _frija_parse_repos_file_comment_line "${line}"
        continue
    else
        ensure_all_metafields_set

        # Parse line and assign fields to global variables
        _frija_parse_repos_file_line "${line}"
    fi

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        skippedOperatingSystems+=("${os}")
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    # If we reach this point then there is at least one row that
    # matches current operating system. Save this fact in this
    # variable so an error message can adapt to this situation
    #
    # shellcheck disable=SC2034
    foundOperatingSystem="${os}"

    # shellcheck disable=SC2154
    case ${vcs} in
        git)
            if [[ "$uri" =~ $GIT_REPO_PATTERN ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination=$(make_destination "${composite}" \
                                               "${repoName}" \
                                               "${version}")
            else
                message="Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is "
                message+="'${uri}' and pattern is '${GIT_REPO_PATTERN}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi
            ;;
        *)
            message="Unsupported VCS: '${vcs}' for '${uri}' found in input "
            message+="file '${inFile}', aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            ;;
    esac


    if [[ -n "${REPO_SUBPATH}" ]] && [[ "${allRepos}" == "n" ]]; then
        # REPO_SUBPATH is set, this means that A) we are somewhere
        # below _FRIJA_WS_PATH and B) we are within a repo.
        #
        # NOTE: If inside a repo and '-a/--all' option is set, then it
        # will override this behavior and force all repos to be
        # operated on regardless.
        print_debug "REPO_SUBPATH='${REPO_SUBPATH}'"
        if [[ "${REPO_SUBPATH}" != "${destination}"* ]]; then
            print_debug "destination='${destination}'"
            # In this case we should ONLY operate on repos where
            # REPO_SUBPATH and destination matches, which means that
            # for all other repos we should just skip it and move on
            # to the next one.
            continue;
        fi
    fi


    case ${vcs} in
        git)
            # Do not abort script if non-zero exit code is returned
            # - Allow command to fail with !'s side effect on errexit
            # - Use return value from ${PIPESTATUS[0]}, because ! hosed $?
            ! git_print_dirty_state "${destination}" "${version}"
            result=${PIPESTATUS[0]}
            if (( result > 0 )); then
                changeFound="y"
                print_separator
            fi
            ;;
        *)
            print_message "Unsupported VCS: '${vcs}', skipping '${uri}'."
            ;;
    esac
    processedReposFlag="y"
done < "$inFile"

print_newline_only_after_dot

print_debug "processedReposFlag='${processedReposFlag}'"
print_debug "changeFound='${changeFound}'"
print_debug "allRepos='${allRepos}'"

if [[ -z "${processedReposFlag}" ]]; then
    if [[ "${allRepos}" == "n" ]]; then
        print_no_repo_match_error "${REPO_SUBPATH}" \
                       "${inFile}" \
                       "No repos were processed!"
    else
        print_os_error "skippedOperatingSystems" \
                       "${inFile}" \
                       "No repos were processed!"
    fi
else
    print_double_separator
    if [[ -z "${changeFound}" ]]; then
        if [[ "${allRepos}" == "y" ]]; then
            print_message "${BOLD}NO dirty repos found!${CLEAR}"
        else
            print_message "${BOLD}Repo is NOT dirty!${CLEAR}"
        fi
    else
        if [[ "${allRepos}" == "y" ]]; then
            print_message "${BOLD}Dirty repos found!${CLEAR}"
        else
            print_message "${BOLD}Repo IS dirty!${CLEAR}"
        fi
    fi

    print_separator
fi
