#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")

# Remove shortest suffix matching "/*", i.e. last part of path
_FRIJA_PROGRAM_DIR="${_FRIJA_PROGRAM_PATH%/*}"


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "fb:vqhdi:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "force,branch,verbose,quiet,help,debug,input:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Commit staged files in repos listed in given repo-list file.
EOF
}


function _frija_subcommand_repo_file_list()
{
    declare -a files

    _frija_locate_frija_home

    # Get all files in $_FRIJA_HOME
    declare -a files
    frija_list_files files "${_FRIJA_HOME}" "" "${REPO_LIST_EXTENSION}"

    # Remove below line when Bash 4.3 or newer is used
    files=("${_FRIJA_FILE_LIST[@]}")

    echo "${files[@]}"
}


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    cat <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} [OPTION]... FILE
$(synopsis)

${BOLD}Options:${CLEAR}
  If a repo also contains unstaged files, then the command fails. Unless
  the -f/--force option is given. Optionally only repos on a branch
  starting with the given branch prefix are considered.

  -b, --branch=BRANCH  Only select branches starting with the given BRANCH
                         prefix
  -v, --verbose        verbose output, not possible to combine with quiet output
  -q, --quiet          quiet output, not possible to combine with verbose output
  -h, --help           print this message
  -d, --debug          enable debug printouts
                         NOTE: Debug messages are prefixed with "*** LINE" where
                               LINE is current line number.
  -D, --dry-run        just echo command lines instead of executing them
EOF
    # Print common input file format documentation, see .preamble
    print_file_format_doc

    # Print common exit codes documentation, see .preamble
    print_exit_codes_doc
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${METADATATOOLS_HOME}/.preamble.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


BRANCH=""
VERBOSE="n"
DEBUG="n"
DRY_RUN="n"

# Iterate over options in order and nicely split until we see --
while true; do
    case "$1" in
        -b|--branch)
            shift  # Move to option argument
            BRANCH="${1}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit 0
            ;;
        -d|--debug)
            DEBUG="y"
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is $1 and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done

# handle non-option argument
if [[ $# -ne 1 ]]; then
    print_error "A single input file is required." 4
fi
inFile="${1}"

if [[ "${DEBUG}" == "y" ]]; then
    echo "*** ${LINENO}  verbose: ${VERBOSE}, debug: ${DEBUG}, in: $inFile"
fi
# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
locate_frija_home
cd "${_FRIJA_HOME}"


bold=$(tput smso)     # Get begin stand-out mode sequence
offbold=$(tput rmso)  # Get end stand-out mode sequence

UNTRACKED="untracked"
UNSTAGED="unstaged"
STAGED="staged"


# Status for a git repo
GIT_STATUS=""

function print_status()
{
    local type="${1}"
    local count=""
    local pattern=""

    case "${type}" in
        $UNTRACKED)
            pattern="^??"
            ;;
        $UNSTAGED)
            pattern="^ M"
            ;;
        $STAGED)
            pattern="^M "
            ;;
        *)
            echo "Internal error; unsupported type '${type}'."
            exit 3
            ;;
    esac

    ! count=$(grep -c "${pattern}" <<< "${GIT_STATUS}")
    if [[ ${PIPESTATUS[0]} -eq 0 ]]; then
        plural=$(plural "$count")
        printf "%3s ${type} file${plural}.\\n" "${count}"

        # -r make read to not treat backslash character
        # as an escape character
        while IFS= read -r line; do
            if [[ "${line}" =~ ${pattern} ]]; then
                # shellcheck disable=SC2034
                while read -r marker file; do
                    echo "    ${file}"
                done<<<"${line}"
            fi
        done<<<"${GIT_STATUS}"
    fi
}


function process_repo()
{
    # Loop until there are no unstaged or untracked files, or user
    # either commits anyway, skips this repo or exit.
    while true; do
        # Will return exit code 128 if not in a git repo.
        command=(git status "--porcelain=v1")

        # Capture what is sent to stdout, fail on error
        GIT_STATUS=$(${command[*]})
        if [[ -n "$GIT_STATUS" ]]; then
            if [[ "$DEBUG" == "y" ]]; then
                echo "*** $LINENO  GIT_STATUS: $GIT_STATUS"
            fi

            unset untracked
            ! untracked=$(grep -c "^??" <<< "$GIT_STATUS")
            untracked="${untracked:=0}"

            unset unstaged
            ! unstaged=$(grep -c "^ M" <<< "$GIT_STATUS")
            unstaged="${unstaged:=0}"

            unset staged
            ! staged=$(grep -c "^M " <<< "$GIT_STATUS")
            staged="${staged:=0}"

            echo "staged=${staged}"
            if  (( "$staged" > 0 )); then
                if  (( ("${unstaged}" > 0) || ("${untracked}" > 0) )); then
                    echo "Repo contains unstaged files:"
                    print_status "${UNSTAGED}"
                    while true; do
                        # Read from saved stdin (FD #3)
                        # -p         PROMPT
                        # -n number  Number of chars to read
                        # -r         Treat backslash literally
                        read -p "Add files, Commit, Reuse message in commit, Skip repo, or Exit? [acrsE] " -n 1 -r <&3
                        case "${REPLY}" in
                            a|A)
                                echo "Add some files!"
                                git add --interactive

                                # Continue outer while loop
                                continue 2
                                ;;
                            s|S)
                                echo "I'll do it another time!"
                                # Break outer while loop
                                break 2
                                ;;
                            c|C)
                                echo "Do commit!"
                                break
                                ;;
                            e|E)
                                exit
                                ;;
                            *)
                                ;;
                        esac
                    done
                else

                    echo "git commit -v -v "
                fi
            fi

            echo ""
        else
            print_command_failure_status "${PIPESTATUS[0]}" "${command[*]}"
        fi
    done
}


########
# Iterate over the lines in the input file and act on each line
# depending on SOURCE field.

# Create a new file handle based off the original stdin since it is
# connected to the file in the while loop below.
exec 3<&0

# Now read from the input file and clone the repos!
# -r make read to not treat backslash character as an escape character
while read -r os source mg version uri rest; do
    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** $LINENO  os='${os}', source: ${source}, version: ${version}, uri: ${uri}, rest: ${rest}"
    fi

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    case ${source} in
        git)
            if [[ "$uri" =~ $GIT_REPO_PATTERN ]]; then
               repoName="${BASH_REMATCH[1]}"
               repoFolder="${mg}/${repoName}/${version}"
            else
                print_error "Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is '${uri}' and pattern is '${GIT_REPO_PATTERN}', aborting." 6
            fi

            if [[ "${DEBUG}" == "y" ]]; then
                echo "*** $LINENO  repoName: ${repoName}"
                echo "*** $LINENO  repoFolder: ${repoFolder}"
                echo "*** $LINENO  command: ${command[*]}"
            fi

            if [[ -d "${repoFolder}" ]]; then
                # Save current working directory
                ! pushd "${repoFolder}" >/dev/null

                print_separator "${repoFolder}"
                # Get current branch
                branch=$(git branch | grep "[*]")

                # Strip initial 2 characters ('* ')
                branch=${branch:2}
                if [[ -n "${BRANCH}" ]]; then
                    if [[ ("${branch}" != "${BRANCH}"*) ]]; then
                        # Branch does not match, continue with next repo
                        continue
                    fi
                fi

                echo "$repoFolder: Current branch"
                echo "  ${bold}$branch${offbold}"
                process_repo "${branch}"
                print_separator "${repoFolder}"

                # Restore current working directory
                ! popd >/dev/null
            else
                echo "   $repoFolder NOT cloned, skipping."
                echo ""
            fi
            ;;
        *)
            echo "Unsupported SOURCE: \"$source\", skipping $uri"
            ;;
    esac
done < "$inFile"
