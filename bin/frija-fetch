#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e "${0}")


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "uwai:vhdDF:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "update,wordy,all,input:,verbose,help,debug,dry-run,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Fetch updates for repos listed in given repo-list file.
EOF
}


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            if [[ -z "${result}" ]]; then
                local message="Current Frija Workspace is corrupt; "
                message+="no ${REPO_LIST_EXTENSION} file found"
                _frija_completion_help_message "${message}"
            fi
            ;;
        -F|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} [OPTION]... FILE
$(synopsis)

  Optionally all local branches (that can be fast forwarded) can be
  updated as well using the update option.

  ${BOLD}Note:${CLEAR} The behavior of the command varies slightly depending on where
        you are in the filesystem. If you are within a repo, then by
        default the operation is applied only to that repo (this can
        be overridden, see below). On the other hand, if you are in
        the frija workspace folder then the operation is applied to
        all repos referenced from the input file that are for the
        current OS.

${BOLD}Options:${CLEAR}
  -f, --fast-forward  fast-farward ${BOLD}all${CLEAR} local branches that can be fast-forwarded

  -w, --wordy         show information for all repos, not just those where
                        changes are found

  -a,                 ${BOLD}when${CLEAR} inside a repo ${BOLD}and${CLEAR} this option is used it will force
   --all                command to work as if standing in the workspace folder,
                        ${BOLD}otherwise${CLEAR} this option has ${BOLD}no effect${CLEAR}

  -iFILE,             apply operation to repos listed in FILE
   --input=FILE
  -v,                 verbose output
   --verbose
  -h,                 print this message
   --help
  -d,                 enable debug printouts sent to stderr
   --debug
  -D,                 do not execute commands with side effects, just echo them
   --dry-run
  -FOS,               force command to assume given OS instead of detected OS
   --force=OS

${BOLD}See also:${CLEAR}
  (frija) ${BOLD}clone${CLEAR} and ${BOLD}status${CLEAR}

EOF
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${REPO_TOOLS_HOME}/.preamble.bash"

# Include generic VCS support.
#
# shellcheck source=./.vcs_functions.bash
source "${REPO_TOOLS_HOME}/.vcs_functions.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


DRY_RUN="n"
UPDATE="n"
WORDY="n"
VERBOSE="n"
DEBUG="n"
allRepos="n"
inFile=""
osOverride=""

# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -u|--update)
            ensure_boolean_option_not_set "Update" "${UPDATE}"
            UPDATE="y"
            shift  # Move to next option
            ;;
        -w|--wordy)
            ensure_boolean_option_not_set "Wordy" "${WORDY}"
            WORDY="y"
            shift  # Move to next option
            ;;
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        -F|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is ${1} and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done


################################################################################
# Consistency checks
################################################################################

# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    OPERATING_SYSTEM="${osOverride}"
fi


# Ensure we have an input file and that it has a valid extension
inFile=$(ensure_input_file "${inFile}")

# In case user has provided an input file with an explicit search path
# we must remove it in order to obtain the system name from the input
# filename. And also remove $REPO_LIST_EXTENSION from it.
SYS_NAME="${inFile##*/}"
SYS_NAME="${SYS_NAME%%${REPO_LIST_EXTENSION}}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


print_debug "verbose: ${VERBOSE=}, debug: ${DEBUG}, in: ${inFile}"


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_HOME or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
_frija_locate_frija_home
REPO_SUBPATH=$(cwd_in_workspace_repo_folder_p)
cd "${_FRIJA_HOME}"


# vcs: Type of service to use when replicating, e.g. git
#
# uri: From where to obtain the data
#
# composite: Composite name [optional]
#
# version: Version identifier to use, e.g. "x.y.z" [optional]
#
# NOTE: Name of destination folder is derived from uri, composite, and
# version using the function make_destination().
function fetch_data()
{
    local vcs="${1}"
    local uri="${2}"
    # Make $3 optional by having default value be an empty string
    local composite="${3:-}"
    # Make $4 optional by having default value be an empty string
    local version="${4:-}"

    local destination=""
    local message=""
    local name=""

    local mode=""
    if [[ "${UPDATE}" == "n" ]]; then
        mode="${SINGLE}"
    else
        mode="${FIRST}"
    fi

    local updateRepoFunction=""

    case "${vcs}" in
        git)
            if [[ "$uri" =~ $GIT_REPO_PATTERN ]]; then
                name="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination=$(make_destination "${composite}" \
                                               "${name}" \
                                               "${version}")

                if [[ ! "${WORDY}" == "n" ]]; then
                    message="Fetching ${destination}"
                fi

                updateRepoFunction="update_git_repo"
            else
                message="Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is "
                message+="'${uri}' and pattern is '${GIT_REPO_PATTERN}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi
            ;;
        *)
            message="Unsupported VCS: '${vcs}' for '${uri}' found in input "
            message+="file '${inFile}', aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            ;;
    esac


    print_debug "name: $name"
    print_debug "destination: $destination"

    if [[ -n "${message}" ]]; then
        print_newline_only_after_dot
        echo "${message}"
    elif [[ "${VERBOSE}" == "n" ]]; then
        print_dot
    fi

    if [[ -d "$destination" ]]; then
        # Enter repo
        pushd "${destination}" &>/dev/null

        # Indirect call to function named in $updateRepoFunction
        "${updateRepoFunction}" "${destination}" "${FIRST}" "${UPDATE}"

        # Leave repo
        popd &>/dev/null
    else
        print_newline_only_after_dot
        print_message "   ${destination} does not exist, please run ${BOLD}frija clone ${inFile}${CLEAR} to replicate missing repo."
        echo ""
    fi
}


########
# Iterate over the lines in the input file and act on each line
# depending on $os and $vcs fields.

if [[ "${WORDY}" == "n" ]]; then
    print_message "Please wait, reading from ${inFile} and checking if any repos need to be updated..."
else
    print_message "Reading from ${inFile} and fetching repos..."
    print_separator
fi

fetchedReposFlag=""
declare -a skippedOperatingSystems=()

# Now read from the input file and clone the repos!
# -r make read to not treat backslash character as an escape character
while read -r os vcs composite version uri rest; do
    # Strip any carriage returns from the read values
    os=${os//$'\r'}
    vcs=${vcs//$'\r'}
    composite=${composite//$'\r'}
    version=${version//$'\r'}
    uri=${uri//$'\r'}
    rest=${rest//$'\r'}

    print_debug "os='${os}', " \
                "vcs=${vcs}, " \
                "version=${version}, " \
                "uri=${uri}, " \
                "rest=${rest}"

    if [[ "${os}" == "#"* ]] || [[ -z "${os}" ]]; then
        # Skip to next entry since it is a commented or empty line
        continue
    fi

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        skippedOperatingSystems+=("${os}")
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    case ${vcs} in
        git)
            if [[ "$uri" =~ $GIT_REPO_PATTERN ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination=$(make_destination "${composite}" \
                                               "${repoName}" \
                                               "${version}")
            else
                message="Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is "
                message+="'${uri}' and pattern is '${GIT_REPO_PATTERN}', "
                message+="aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            fi
            ;;
        *)
            message="Unsupported VCS: '${vcs}' for '${uri}' found in input "
            message+="file '${inFile}', aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
            ;;
    esac


    if [[ -n "${REPO_SUBPATH}" ]] && [[ "${allRepos}" == "n" ]]; then
        # REPO_SUBPATH is set, this means that A) we are somewhere
        # below _FRIJA_HOME and B) we are within a repo.
        #
        # NOTE: If inside a repo and '-a'/'-all' option is set, then
        # it will override this behavior and force all repos to be
        # operated on regardless.
        print_debug "REPO_SUBPATH='${REPO_SUBPATH}'"
        if [[ "${REPO_SUBPATH}" != "${destination}"* ]]; then
            print_debug "destination='${destination}'"
            # In this case we should ONLY operate on repos where
            # REPO_SUBPATH and destination matches, which means that
            # for all other repos we should just skip it and move on
            # to the next one.
            continue;
        fi
    fi


    fetch_data "${vcs}" "${uri}" "${composite}" "${version}"
    fetchedReposFlag="y"
done < "${inFile}"

print_newline_only_after_dot

if [[ -z "${fetchedReposFlag}" ]]; then
    print_os_error "skippedOperatingSystems" \
                   "${inFile}" \
                   "No repos were fetched!"
fi
