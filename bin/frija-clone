#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e "${0}")

# Remove shortest suffix matching "/*", i.e. last part of path
_FRIJA_PROGRAM_DIR="${_FRIJA_PROGRAM_PATH%/*}"


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "wi:vqhdDf:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "wordy,input:,verbose,quiet,help,debug,dry-run,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Clone repos listed in given repo-list file.
EOF
}


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            ;;
        -f|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    cat <<EOF
Usage: ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  For each cloned repo that has version "${NON_VERSION}" in the input file will have
  its current branch switched to the feature branch corresponding to the JIRA
  issue ID, otherwise the tag matching the selected version will be checked out
  in the repo (that is, it is in a Detached HEAD siutation).

  ${BOLD}Note:${CLEAR} Repos that have a version (and not "${NON_VERSION}") in the input
        file (and it is posible to switch to the commit identified by the tag)
        will be made into read-only repos. That is it is not possible to make
        commits to them nor push them to remote.

  ${BOLD}Note:${CLEAR} Tags that identify versions are assumed to follow a
        specific format where square brackets ([ and ]) signify optional parts

        N.N.N[-RC][+CC_SS_DD]__@HHHHHH

        where
          N  = Version number (major, minor, and correction)
          RC = Release candidate number starting on 1 (one)
          CC = Country code according to ISO 3166-1 alpha-2
          SS = Site identification code, e.g. TN for Tannefors
          DD = Domain, e.g. LKP, Gride, ...
           H = Hex digit from 6-digit short SHA-1

  If there are no matching feature branch nor tag found, the develop branch is
  instead checked out. And if there is no develop branch the master branch is
  checked out. For these error-like conditions a message will be echoed to the
  terminal notifying about this.

  Repos that are already cloned are skipped and the branch selected for
  the cloned repos is the default branch for the repo, usually "develop".

${BOLD}Options:${CLEAR}
  -w, --wordy           show more verbose progress and status for all repos
  -iFILE,--input=FILE   clone repos listed in FILE

  -v, --verbose         verbose output, not possible to combine with quiet
                          output
  -h, --help            print this message
  -d, --debug           enable debug printouts
                          ${BOLD}Note:${CLEAR} Debug messages are prefixed with "*** LINE" where
                                LINE is current line number.
  -D, --dry-run         just echo command lines instead of executing them
  -fOS, --force=OS      force command to assume given OS instead of detected OS
EOF
    # Print common input file format documentation, see .preamble
    print_file_format_doc

    # Print common exit codes documentation, see .preamble
    print_exit_codes_doc
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${METADATATOOLS_HOME}/.preamble.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


WORDY="n"
DRY_RUN="n"
VERBOSE="n"
DEBUG="n"
autoInFile=$(auto_locate_repo_file)
inFile=""
osOverride=""

# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -w|--wordy)
            ensure_boolean_option_not_set "Wordy" "${WORDY}"
            WORDY="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit 0
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        -f|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is ${1} and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done


# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    OPERATING_SYSTEM="${osOverride}"
fi

# Allow explicit command line to specify inFile and override the
# automatically found inFile. This case is only valid when there is a
# single repo-list file.
inFile="${inFile:-${autoInFile}}"
if [[ -z "${inFile}" ]]; then
    print_error "No input file specified." 2
fi

# Append extension AFTER above check; otherwise we would
# not be able to detect if $inFile is empty
inFile="${inFile}${REPO_LIST_EXTENSION}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    print_error "Command does not support any arguments." 4
fi


if [[ "${DEBUG}" == "y" ]]; then
    echo "*** ${LINENO}  verbose: ${VERBOSE=}, debug: ${DEBUG}, in: ${inFile}"
fi


# Ensure we are within frija folder structure and if so change
# directory to FRIJA_HOME, otherwise exit with an error message
_frija_locate_frija_home
cd "${_FRIJA_HOME}"


########
# Iterate over the lines in the input file and act on each line
# depending on VCS field.

print_message "Reading from ${inFile} and cloning repos..."
print_separator

clonedReposFlag=""
declare -a skippedOperatingSystems=()
declare -A uniqueSkippedOperatingSystems=()

# Now read from the input file and clone the repos!
# -r make read to not treat backslash character as an escape character
while read -r os source mg version uri rest; do
    # Strip any carriage returns from the read values
    os=${os//$'\r'}
    source=${source//$'\r'}
    mg=${mg//$'\r'}
    version=${version//$'\r'}
    uri=${uri//$'\r'}
    rest=${rest//$'\r'}

    print_debug "os='${os}', " \
                "source: '${source}', " \
                "version: '${version}', " \
                "uri: '${uri}', " \
                "rest: '${rest}'"

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        skippedOperatingSystems+=("${os}")
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    replicate_data "${source}" "${uri}" "${mg}" "${version}"
    clonedReposFlag="y"
done < "${inFile}"

print_newline_only_after_dot

if [[ -z "${clonedReposFlag}" ]]; then
    # Make $skippedOperatingSystems unique by using an associative
    # array (hashmap)
    for i in "${skippedOperatingSystems[@]}"; do
        uniqueSkippedOperatingSystems["${i}"]=1
    done
    print_message ""
    print_message "====================="
    print_message "${BOLD}No repos were cloned!${CLEAR}"
    print_message "====================="
    print_message ""
    print_message "Current OS is ${BOLD}${OPERATING_SYSTEM}${CLEAR} and all entries in"
    print_message "  ${BOLD}${inFile}${CLEAR}"
    print_message "required the following operating system$(plural ${#skippedOperatingSystems[@]})${BOLD}"
    printf '  %s\n' "${!uniqueSkippedOperatingSystems[@]}"
    print_message "${CLEAR}"
    print_message "Are you sure you are using an input file designed for your OS?"
fi
