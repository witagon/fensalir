#!/bin/bash
# Path to this script
_FRIJA_PROGRAM_PATH=$(readlink -e "${0}")


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "F:f:j:d:r:n:R:h"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "fensalirenv:,feature:,jira:,develop:,released:,name:,reposfile:,help,update,verbose,trace,debug,dry-run"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)



function synopsis()
{
    cat <<EOF
  Create and initialize ${BOLD}frija${CLEAR} workspaces.
EOF
}


LATEST="LATEST"
VERSION="VERSION"


function _frija_subcommand_option_values()
{
    print_debug_enter

    # RETURN trap is executed before execution resumes after a shell
    # function returns. This RETURN trap restores the extglob
    # (extended pattern matching for globbing expressions)
    # shellcheck disable=SC2064
    trap "$(shopt -p extglob)" RETURN
    shopt -s extglob

    local optionName="${1}"
    local optionValue="${2:-}"
    local result=""

    # Collapse any repeated slashes into single slashes in $optionValue
    optionValue="${optionValue///*(/)//}"
    # Trim any trailing slash from $optionValue
    optionValue="${optionValue%/}"

    # Regex for extracting any environment from the command
    # line
    declare -r ENV_PATTERN="^.*[^-]*(-l|--fensalirenv) = ([^ ]*).*$"
    print_debug "ENV_PATTERN=${ENV_PATTERN}"

    # Regex for extracting any update option from the command
    # line
    declare -r UPDATE_PATTERN="^.*[^-]*(--update).*$"
    print_debug "UPDATE_PATTERN=${UPDATE_PATTERN}"

    # Regex for extracting any Feature ID from the command
    # line
    declare -r FEATURE_PATTERN="^.*[^-]*(-f|--feature|-j|--jira) = ([^ ]*).*$"
    print_debug "FEATURE_PATTERN=${FEATURE_PATTERN}"

    case "${optionName}" in
        -F|--fensalirenv)
            # What is on the command line
            local currentItems
            currentItems="${COMP_WORDS[*]:1}"
            print_debug "currentItems='${currentItems}'"

            # Check if we can find '--update'
            local updateOption=""
            if [[ "${currentItems}" =~ ${UPDATE_PATTERN} ]]; then
                updateOption="${BASH_REMATCH[1]}"
            fi
            print_debug "updateOption='${updateOption}'"

            if [[ -z "${updateOption}" ]]; then
                declare -a environments
                frija_list_environments environments

                # Remove below line when Bash 4.3 or newer is used
                environments=("${_FRIJA_FILE_LIST[@]}")

                result="${environments[*]}"
                if [[ -z "${result}" ]]; then
                    local message="No Fensalir Environment repo found; please "
                    message+="install one using ${BOLD}fensalir fetch${CLEAR} "
                    message+="command and try again"
                    _frija_completion_help_message "${message}"
                fi
            else
                local message="Options ${BOLD}${optionName}${CLEAR} and "
                message+="${BOLD}${updateOption}${CLEAR} must not be combined"
                _frija_completion_help_message "${message}"
            fi
            ;;
        -f|--feature)
            local message="Please provide a feature ID, "
            message+="i.e. something like ABCD-1234"
            _frija_completion_help_message "${message}"
            ;;
        -j|--jira)
            local message="Please provide a Jira ID, "
            message+="i.e. something like ABCD-1234"
            _frija_completion_help_message "${message}"
            ;;
        -d|--develop)
            result="${LATEST} ${VERSION}"
            ;;
        -r|--released)
            result="${LATEST} ${VERSION}"
            ;;
        -n|--name)
            # What is on the command line
            local currentItems
            currentItems="${COMP_WORDS[*]:1}"
            print_debug "currentItems='${currentItems}'"

            # Check if we can find '--update'
            local updateOption=""
            if [[ "${currentItems}" =~ ${UPDATE_PATTERN} ]]; then
                updateOption="${BASH_REMATCH[1]}"
            fi
            print_debug "updateOption='${updateOption}'"

            if [[ -z "${updateOption}" ]]; then
                local message="Please provide a name for the new Workspace"
                _frija_completion_help_message "${message}"
            else
                result=$(_frija_workspace_list)
            fi
            ;;
        -R|--reposfile)
            print_debug "--reposfile option detected"
            # What is on the command line
            local currentItems
            currentItems="${COMP_WORDS[*]:1}"
            print_debug "currentItems='${currentItems}'"

            local envValue=""
            local envOption=""
            if [[ "${currentItems}" =~ ${ENV_PATTERN} ]]; then
                envOption="${BASH_REMATCH[1]}"
                envValue="${BASH_REMATCH[2]}"
            fi
            print_debug "envOption='${envOption}'"
            print_debug "envValue='${envValue}'"

            local updateOption=""
            if [[ "${currentItems}" =~ ${UPDATE_PATTERN} ]]; then
                updateOption="${BASH_REMATCH[1]}"
            fi
            print_debug "updateOption='${updateOption}'"

            local vollaname=""
            if [[ -n "${envValue}" ]] && [[ -n "${updateOption}" ]]; then
                local message="Options ${BOLD}${envOption}${CLEAR} and "
                message+="${BOLD}${updateOption}${CLEAR} must not be combined"
                _frija_completion_help_message "${message}"
            else
                if [[ -n "${updateOption}" ]]; then
                    # Regex for extracting any Workspace name from the command
                    # line
                    declare -r NAME_PATTERN="^.*[^-]*(-n|--name) = ([^ ]*).*$"
                    print_debug "NAME_PATTERN=${NAME_PATTERN}"

                    local nameOption=""
                    local nameValue=""
                    if [[ "${currentItems}" =~ ${NAME_PATTERN} ]]; then
                        nameOption="${BASH_REMATCH[1]}"
                        nameValue="${BASH_REMATCH[2]}"
                    fi
                    print_debug "nameOption='${nameOption}'"
                    print_debug "nameValue='${nameValue}'"

                    local featureOption=""
                    local featureValue=""
                    if [[ "${currentItems}" =~ ${FEATURE_PATTERN} ]]; then
                        featureOption="${BASH_REMATCH[1]}"
                        featureValue="${BASH_REMATCH[2]}"
                    fi
                    print_debug "featureOption='${featureOption}'"
                    print_debug "featureValue='${featureValue}'"

                    if [[ -n "${nameOption}" ]] && [[ -n "${featureOption}" ]]
                    then
                        local message="Options ${BOLD}${nameOption}${CLEAR} "
                        message+="and ${BOLD}${featureOption}${CLEAR} must "
                        message+="not be combined"
                        _frija_completion_help_message "${message}"
                    else
                        envValue=$(frija_retrieve_environment_name \
                                          "${nameValue:-${featureValue}}")
                    fi
                fi

                local envPath="${_VOLLA_PATH}/${envValue}"
                print_debug "envPath='${envPath}'"
                vollaname=$(frija_retrieve_volla_name "${envPath}")
                print_debug "vollaname='${vollaname}'"

                # TODO: Also follow DependencyPointer files if any?
                #
                # Get all repo files in $vollaname
                declare -a files=()
                local vollaRepoPath="${_VOLLA_PATH}/${vollaname}"
                print_debug "vollaRepoPath=${vollaRepoPath}"
                frija_list_files files \
                                 "${vollaRepoPath}" \
                                 "" \
                                 "" \
                                 "${REPO_LIST_EXTENSION}"
                print_debug_array "_FRIJA_FILE_LIST"

                # Remove below line when Bash 4.3 or newer is used
                files=("${_FRIJA_FILE_LIST[@]}")
                print_debug "files=${files[*]}"

                # Remove suffix ${REPO_LIST_EXTENSION} from file list
                files=("${files[@]%${REPO_LIST_EXTENSION}}")
                print_debug "files=${files[*]}"

                result="${files[*]}"
            fi
            print_debug "result=${result[*]}"
            ;;
    esac

    print_debug_exit "${result}"
    echo "${result}"
}


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...

$(synopsis)

  Workspaces are where repos may be cloned and operated on using other
  Frija commands and the core idea behind Frija is that one workspace
  is used for a specific task (e.g. a feature).

  ${BOLD}That is, the assumption is that when working on multiple features
  there is one dedicated workspace per feature.${CLEAR}

  When creating a workspace a name may be assigned to it. If no name
  is given the feature ID is simply used as the workspace name.

  Frija is based on the premise of a workspace containing all repos
  that are necessary to build a system or subsystem or subsystem of a
  sybsystem and so on. Furthermore the build result of each repo is
  expected to be stored in a Build folder in the root of each repo.
  Depending on build system used within a repo a Build Result folder
  might also be used.

  References between repos are provided by Frija via the repos file
  and the frija generate command which generates a file in each repo
  participating in the build. This file is then read by the
  corresponding build scripts (Makefile, CMakeLists.txt, .sln,
  .csproj, .csproj, ...) and used for obtaining dependencies needed
  when building a specific repo.

  More information about this can be found in the documentation for
  the frija build command.

  The repos file (which is intended to be generated) describe the
  build dependencies between repos forming a system/subsystem in
  conjunction with an instantiation of a SECI. This data obtained via
  a Fensalir Environment repo that in turn reference a Volla repo
  (where repos file comes from) and Frija Build Environment repo
  (where SECI-instantiation is found); ${BOLD}fensalir fetch${CLEAR} command is used
  for cloning and updating such repos.


  The list of repos to work on is stored in a ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file which is
  copied to the workspace when a workspace is created or updated. This
  file is derived from information stored in one or more Volla repos
  (which may have dependencies between them). The Volla tool is used
  for managing the subsystem repo information as well as exporting
  ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} files.

  ${BOLD}Note:${CLEAR} There is a variant where the feature ID is not used as the
        default workspace name and this variant is solely designed for
        the use-case of daily/nightly builds etc. In this case the
        name of the folder is implicitly given by the name of the
        system/subsystem, version, and so on in order to guarantee a
        unique workspace name. This means that in this mode there is
        no support given by the Frija commands for switching to a
        feature branch, updating repos, pushing repos, and so on.

  The ${BOLD}frija${CLEAR} command provides the convenience option ${BOLD}--switch${CLEAR} for an
  easy way of getting to a workspace as well as switching between
  them. It is based on the bash built-ins ${BOLD}pushd${CLEAR} and ${BOLD}popd${CLEAR} (which thus
  can also be used for switching between other folders as well).

${BOLD}Options:${CLEAR}
  -FENV,              already cloned Fensalir Environment repo ENV to operate
   --fensalirenv=ENV  on; this is from where the REPOS file is found

  -fID,               ID identifying preferred feature branch to use when no
   --feature=ID       explicit version is set in used ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file, e.g. ID set
                      to ${BOLD}ABCD-1234${CLEAR} then the feature branch name is assumed to
                      start with
                        feature/${BOLD}ABCD-1234${CLEAR}
                        ${BOLD}Note:${CLEAR} When no default workspace NAME is provided the
                              given feature ID is also used as the default
                              workspace NAME

  -jJIRA,             alias for -f/--feature where JIRA is the same as ID
   --jira=JIRA

  -dTYPE,             develop branch set as preferred branch when no explicit
   --develop=TYPE     version is set in used ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file, actual commit
                      selected depend on TYPE
                        - TYPE "${LATEST}" means track latest commit on branch
                        - TYPE "${VERSION}" means latest commit on branch
                          with a valid version tag; either a version in
                          development or a released version depending on
                          which tag is newer

  -rTYPE,             release branch (e.g. master brach) set as preferred branch
                        when no explicit version is set in used ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file,
   --released=TYPE      actual commit selected depend on TYPE
                          - TYPE "${LATEST}" means track latest commit on branch
                          - TYPE "${VERSION}" means latest commit on branch
                            with a valid released version tag; that is a
                            version tag ${BOLD}without${CLEAR} any release candidate number

  -nNAME,             name NAME for the workspace; if a feature ID is provided
   --name=NAME          then it will be used as the default value

  -RREPOS,            name of ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file sans extension to use when resolving
   --reposfile=REPOS  dependencies

  -h,                 print this message
   --help

  --update            update repos file in existing workspace

  --verbose           verbose output

  --trace             trace output

  --debug             enable debug printouts sent to stderr

  --dry-run           do not execute commands with side effects, just echo them

${BOLD}Examples:${CLEAR}
  ${BOLD}$ ${_FRIJA_USAGE_NAME} --fensalirenv=foo-fensalir-env-repo --reposfile=Bar --feature=ABCD-1234${CLEAR}
  This command will create the folders
    ${UNDERLINE_ON}${PWA}/${_FRIJA_HOME_FOLDER}/ABCD-1234${UNDERLINE_OFF}
    ${UNDERLINE_ON}${PWA}/${_FRIJA_HOME_FOLDER}/ABCD-1234/${_FRIJA_CONFIG_FOLDER_NAME}${UNDERLINE_OFF}

  and pupulate the configuration folder with the files
    - ${UNDERLINE_ON}${_FRIJA_WS_BRANCH_STRATEGY_FILE}${UNDERLINE_OFF}
    - ${UNDERLINE_ON}${_FRIJA_WS_CONFIG_FILE}${UNDERLINE_OFF}

  as well as copy repos file ${BOLD}Bar${CLEAR} (${BOLD}Bar${REPO_LIST_EXTENSION}${CLEAR}) that is stored in workspace
  folder ${BOLD}ABCD-1234${CLEAR}.

  ${BOLD}Note:${CLEAR} The Fensalir Environment (${BOLD}foo-fensalir-env-repo${CLEAR} in above example)

        resolve the entity with precedence; that is the first Volla
        repo it finds with an repos file named ${BOLD}Bar${CLEAR} is assumed to be the
        expected repos file.


  ${BOLD}$ ${_FRIJA_USAGE_NAME} --update${CLEAR}
  This command will update the .repos files found in the workspace
  whos name matches names of .repos files found in the linked Volla
  repo located in the volla folder (the link is established when the
  Workspace is created).

  ${BOLD}Note:${CLEAR} Backups of updated .repos files in the Workspace are automatically made by the
        command.

${BOLD}See also:${CLEAR}
  ${BOLD}fensalir fetch${CLEAR}

EOF
}


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi

# Include core command line parsing support, common settings and
# utility functions.
# shellcheck source=./.preamble.bash
source "${_FENSALIR_HOME}/.preamble.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]] && [[ -z "${_BOOTSTRAP_PATH}" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This check is ONLY valid when we are not sourced from the
    # bootstrap script. Since it reuses some of the functions defined
    # in this script.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


# Configure Bash options
_frija_configure_bash


UPDATE="n"
DRY_RUN="n"
VERBOSE="n"
TRACE="n"
DEBUG="n"

ENVIRONMENT=""
COMMIT_TYPE=""

# How to select default branch across repos when $REPO_LIST_EXTENSION
# file says "floating". Note that it is also possible to say "latest
# stable" version.
BRANCH_STRATEGY=""

TEMP_FILE_EXTENSION=".frija_workspace_temp"
workspaceName=""
reposFile=""

# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -F|--fensalirenv)
            shift  # Move to option argument
            ENVIRONMENT="${1:-}"
            ensure_option_argument_set "Fensalir Environment" "${ENVIRONMENT}"
            shift  # Move to next option
            ;;
        -f|--feature)
            ensure_option_not_set "Commit type" "${COMMIT_TYPE}"
            COMMIT_TYPE="${_FRIJA_FEATURE}"
            shift  # Move to option argument
            BRANCH_STRATEGY="${1}"
            ensure_option_argument_set "Feature ID" "${BRANCH_STRATEGY}"
            shift  # Move to next option
            ;;
        -j|--jira)
            ensure_option_not_set "Commit type" "${COMMIT_TYPE}"
            COMMIT_TYPE="${_FRIJA_FEATURE}"
            shift  # Move to option argument
            BRANCH_STRATEGY="${1}"
            ensure_option_argument_set "Jira ID" "${BRANCH_STRATEGY}"
            shift  # Move to next option
            ;;
        -d|--develop)
            ensure_option_not_set "Commit type" "${COMMIT_TYPE}"
            COMMIT_TYPE="${_FRIJA_DEVELOP}"
            shift  # Move to option argument
            BRANCH_STRATEGY="${1}"
            ensure_option_argument_set "Default branch strategy" \
                                       "${BRANCH_STRATEGY}"
            shift  # Move to next option
            ;;
        -r|--released)
            ensure_option_not_set "Commit type" "${COMMIT_TYPE}"
            COMMIT_TYPE="${_FRIJA_RELEASE}"
            shift  # Move to option argument
            BRANCH_STRATEGY="${1}"
            ensure_option_argument_set "Default branch strategy" \
                                       "${BRANCH_STRATEGY}"
            shift  # Move to next option
            ;;
        -n|--name)
            ensure_option_not_set "Workspace name" "${workspaceName}"
            # Move to required option argument
            shift
            workspaceName="${1}"
            ensure_option_argument_set "Workspace name" "${workspaceName}"
            shift  # Move to next option
            ;;
        -R|--reposfile)
            ensure_option_not_set "Repos file" "${reposFile}"
            # Move to required option argument
            shift
            reposFile="${1}"

            ensure_option_argument_set "Repos file" "${reposFile}"

            # Append extension AFTER above check; otherwise we would
            # not be able to detect if $1 is empty
            if [[ "${reposFile}" != *"${REPO_LIST_EXTENSION}" ]]; then
                reposFile+="${REPO_LIST_EXTENSION}"
            fi

            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        --update)
            ensure_boolean_option_not_set "Update" "${UPDATE}"
            if [[ -n "${ENVIRONMENT}" ]]; then
                message="The options ${BOLD}--update${CLEAR} and "
                message+="${BOLD}-F${CLEAR}/${BOLD}--fensalirenv${CLEAR} are "
                message+="mutually exclusive!"
                print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
            fi
            UPDATE="y"
            shift  # Move to next option
            ;;
        --verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        --trace)
            ensure_boolean_option_not_set "Trace" "${TRACE}"
            TRACE="y"
            shift  # Move to next option
            ;;
        --debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        --dry-run)
            # See .core_preamble.bash for more information
            set_dry_run
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


message=""



function copy_repos_file()
{
    print_debug_enter "$@"

    local workspacePath="${1}"
    local reposFile="${2}"
    local vollaName="${3:-}"

    declare -i returnCode=0

    print_debug "vollaName='${vollaName}'"
    local tempExtension="${TEMP_FILE_EXTENSION}"

    if [[ -z "${vollaName}" ]]; then
        # In this case a Volla repo is create and thus there is no
        # need to use temporary file name extension to ensure atomic
        # operation.
        tempExtension=""

        # Get path to Volla database repo via given Fensalir Environment repo
        local envPath="${_VOLLA_PATH}/${ENVIRONMENT}"
        vollaName=$(frija_retrieve_volla_name "${envPath}")

        if [[ -z "${vollaName}" ]]; then
            message="Unable to find any Volla repo for Fensalir Environment "
            message+="'${ENVIRONMENT}'; is Fensalir Environment repo "
            message+="correctly configured?"
            print_warning "${message}"
            returnCode=1
        fi
    fi
    print_debug "vollaName='${vollaName}'"

    local sourceFile="${_VOLLA_PATH}/${vollaName}/${reposFile}"
    local targetFile="${workspacePath}/${reposFile}"
    print_debug "sourceFile='${sourceFile}'"
    print_debug "targetFile='${targetFile}'"

    if [[ -r "${sourceFile}" ]]; then
        # Note that Solaris diff does not support -q/--quiet flag...
        ! diff "${sourceFile}" "${targetFile}" >/dev/null 2>&1
        declare -i diffresult="${PIPESTATUS[0]}"

        if [[ ! -e "${targetFile}" ]] || (( diffresult == 1 ))
        then
            declare -a command=()

            # Copy $REPO_LIST_EXTENSION file to the new workspace folder
            print_message
            message="Copying ${REPO_LIST_EXTENSION} file "
            message+="${sourceFile#${_VOLLA_PATH}/}"
            command=("${SINGLE}" "${message}" cp \
                                 "--backup=numbered" \
                                 "--force" \
                                 "${sourceFile}" \
                                 "${targetFile}${tempExtension}")
            run "${command[@]}"
        elif (( diffresult > 1 ))
        then
            message="Something went wrong when comparing '${sourceFile}' "
            message+="to '${targetFile}'."
            print_warning "${message}"
            returnCode=1
        else
            message="Nothing changed in ${REPO_LIST_EXTENSION} file "
            message+="${BOLD}${reposFile}${CLEAR}"
            print_message "${message}" 2
        fi
    else
        # Potential partial update; remove any remnants from previous
        # copy operations
        rm -f "${workspacePath}/"*"${REPO_LIST_EXTENSION}${TEMP_FILE_EXTENSION}"

        message="Repos file ${BOLD}${reposFile}${CLEAR} ('${sourceFile}') "
        message+="does not exist, aborting."
        print_warning "${message}"
        returnCode=1
    fi

    print_debug_exit
    return ${returnCode}
}


function create_workspace()
{
    print_debug_enter

    local workspacePath="${_FRIJA_PATH}/${workspaceName}"
    local workspaceConfigPath="${workspacePath}/${_FRIJA_CONFIG_FOLDER_NAME}"

    local message=""

    # ##########################################################################
    # Sanity checks
    if [[ -z "${ENVIRONMENT}" ]]; then
        message="A Fensalir Environment ${BOLD}must${CLEAR} be specified "
        message+="on the command line, aborting."
        print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
    fi

    if [[ -z "${reposFile}" ]]; then
        message="A ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file (sans extension) "
        message+="must be given on the command line, aborting."
        print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
    fi

    if [[ -d "${workspaceConfigPath}" ]]; then
        message="Workspace '${BOLD}${workspaceName}${CLEAR}' already exists; "
        message+="please either remove or rename it and try again."
        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    fi
    # End of sanity checks
    ############################################################################

    # Create Workspace folder and config folder in one go
    message="Creating Workspace '${workspaceName}'"
    command=("${SINGLE}" "${message}" mkdir \
                         "--parents" \
                         "${workspaceConfigPath}")
    run "${command[@]}"

    ############################################################################
    # Save Workspace branch strategy configuration persistently
    print_message "- Saving configured default branch strategy" 2
    print_message "${BOLD}${COMMIT_TYPE}${CLEAR}" 6
    print_message "${BOLD}${BRANCH_STRATEGY}${CLEAR}" 6

    {
        echo "${COMMIT_TYPE} ${BRANCH_STRATEGY}"
    } >| "${workspaceConfigPath}/${_FRIJA_WS_BRANCH_STRATEGY_FILE}"

    ############################################################################
    # Save Workspace Fensalir Environment configuration persistently
    print_message
    print_message "- Saving configured Fensalir Environment" 2
    print_message "${BOLD}${ENVIRONMENT}${CLEAR}" 6

    {
        echo "${_FRIJA_WS_ENVIRONMENT_FIELD} ${ENVIRONMENT}"
    } >| "${workspaceConfigPath}/${_FRIJA_WS_CONFIG_FILE}"


    ############################################################################
    # Finally copy repos file to Workspace root
    ! copy_repos_file "${workspacePath}" "${reposFile}"
    if (( PIPESTATUS[0] > 0 )); then
        # Remove partially created Workspace
        rm -fr "${workspacePath}"
        message="Unrecoverable errors occurred, aborting."
        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    fi

    print_debug_exit "${workspacePath}"
    echo "${workspacePath}"
}


function update_workspace()
{
    print_debug_enter

    local workspacePath=""

    if [[ -z "${workspaceName}" ]]; then
        # Ensure we are within a Workspace and as a side effect update
        # $_FRIJA_WS_PATH to the root of the Workspace.
        _frija_locate_workspace
        workspacePath="${_FRIJA_WS_PATH}"
    else
        workspacePath="${_FRIJA_PATH}/${workspaceName}"
    fi

    # Array with repos files to update
    declare -a files

    if [[ -z "${reposFile}" ]]; then
        # Get all files in $workspacePath
        frija_list_files files "${workspacePath}" "" "" "${REPO_LIST_EXTENSION}"

        # Remove below line when Bash 4.3 or newer is used
        files=("${_FRIJA_FILE_LIST[@]}")
    else
        # User has provided repos file to update
        files=("${reposFile}")
    fi

    local message="Updating Workspace '${workspacePath##*/}'"
    print_message "${message}"

    local extension="${REPO_LIST_EXTENSION}${TEMP_FILE_EXTENSION}"

    local reposFile=""
    # Iterate over all repos files found
    for reposFile in "${files[@]}"; do
        # Ensure each processed file starts from a clean slate with
        # respect to the meta data field _FRIJA_VOLLA_REPO that is
        # extracted from the file
        #
        # shellcheck disable=SC2034
        _FRIJA_VOLLA_REPO=""

        # Extract metadata field "Volla Repo:"; we are interested in
        # $_FRIJA_VOLLA_REPO as this gives which Volla repo to update
        # $reposFile from if they differ.
        local line=""
        while read -r line; do
            if [[ -z "${line}" ]]; then
                # Skip to next entry since it is an empty line
                continue
            fi

            if [[ "${line}" == "#"* ]]; then
                # Parse line and assign to global variable if comment contains
                # a known key-value pair
                _frija_parse_repos_file_comment_line "${line}"
                continue
            fi
        done < "${reposFile}"

        if [[ -z "${_FRIJA_VOLLA_REPO}" ]]; then
            message="Corrupt repos file '${reposFile}'; missing or empty field "
            message+="${_FRIJA_VOLLA_REPO_FIELD}, skipping."
            print_warning "${message}"
        elif [[ -r "${workspacePath}/${reposFile}" ]]; then
            ! copy_repos_file "${workspacePath}" \
                              "${reposFile}" \
                              "${_FRIJA_VOLLA_REPO}"
            if (( PIPESTATUS[0] > 0 )); then
                # Remove partially updated files in Workspace
                rm -fr "${workspacePath}"*"${extension}"
                message="Unrecoverable errors occurred, aborting."
                print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
            fi
        else
            message="Missing repos file '${reposFile}', skipping."
            print_warning "${message}"
        fi
    done

    if [[ -z "${reposFile}" ]]; then
        message="Unable to find any repos files to update; please install "
        message+="one first using this command, aborting."
        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    else
        # Iterate over all copied files and replace the files that
        # should be updated with the temporary copied ones
        for tempReposFile in "${workspacePath}/"*"${extension}"; do
            # First copy the temporary file to the actual file and
            # while doing so create a backup copy of it...
            cp "--backup=numbered" "--force" \
                "${tempReposFile}" "${tempReposFile%${TEMP_FILE_EXTENSION}}"

            #...and then remove the temporary file
            rm -f "${tempReposFile}"
        done
    fi

    print_debug_exit "${workspacePath}"
    echo "${workspacePath}"
}



################################################################################
# Updating or creating and initializing Workspace folder?
################################################################################

workspacePath=""
if [[ "${UPDATE}" == "y" ]]; then
    workspacePath=$(update_workspace)
    workspaceName="${workspacePath##*/}"
    operationPerformed="updated"
else
    # ##########################################################################
    # Sanity checks
    #
    # Ensure user has set a default branch strategy
    if [[ -z "${COMMIT_TYPE}" ]]; then
        message="One of Feature, Develop, or Released must be specified, "
        message+="aborting."
        print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
    fi

    # Note that when $COMMIT_TYPE is non-empty then $_FRIJA_FEATURE is
    # also non-empty at the same time.
    case "${COMMIT_TYPE}" in
        "${_FRIJA_FEATURE}")
            # When $workspaceName is unset assign $BRANCH_STRATEGY
            # (feature ID) to it as the default name of the workspace.
            workspaceName="${workspaceName:-${BRANCH_STRATEGY}}"
            ;;
        "${_FRIJA_DEVELOP}"|"${_FRIJA_RELEASE}")
            if [[ -z "${workspaceName}" ]]; then
                message="No explicit workspace name has been given, aborting."
                print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
            fi
            ;;
        *)
            message="Unknown value '${COMMIT_TYPE}' assigned to COMMIT_TYPE."
            print_error "${message}" $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
    # End of sanity checks
    ############################################################################

    workspacePath=$(create_workspace)
    operationPerformed="created"
fi


if [[ -z "${_FRIJA_SCRIPTED_BUILD:-}" ]]; then
    print_message
    print_double_separator
    message="Successfully ${operationPerformed} Workspace "
    message+="'${BOLD}${workspaceName}${CLEAR}' (${workspacePath})"
    print_message "${message}"
    print_separator

    if [[ "${PWD}" != "${workspacePath}"* ]]; then
        cat <<EOF
Switch to your new Workspace Folder and clone the repos
  ${BOLD}frija --switch=${workspaceName}${CLEAR}
  ${BOLD}frija clone --verbose${CLEAR}

EOF
    fi

    message="If there are multiple ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} "
    message+="files in your Workspace folder many Frija commands require "
    message+="that you select which to operate on using the commands "
    message+="${BOLD}--input${CLEAR} flag."
    print_note "${message}"
    print_message
fi
