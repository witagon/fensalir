#!/bin/bash
# Path to this script
_FRIJA_PROGRAM_PATH=$(readlink -e "${0}")


# How to select default branch across repos when $REPO_LIST_EXTENSION
# file says "floating". Note that it is also possible to say "latest
# stable" version.
defaultBranchStrategy=""


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "l:f:j:e:r:w:S:E:vhdD"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "locale:,feature:,jira:,develop:,released:,workspace:,system:,entity:,verbose,help,debug,dry-run"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)



function synopsis()
{
    cat <<EOF
  Create and initialize ${BOLD}frija${CLEAR} workspaces.
EOF
}


LATEST="LATEST"
VERSION="VERSION"


function _frija_subcommand_option_values()
{
    print_debug_enter

    # RETURN trap is executed before execution resumes after a shell
    # function returns. This RETURN trap restores the extglob
    # (extended pattern matching for globbing expressions)
    # shellcheck disable=SC2064
    trap "$(shopt -p extglob)" RETURN
    shopt -s extglob

    local optionName="${1}"
    local optionValue="${2:-}"
    local result=""

    # Collapse any repeated slashes into single slashes in $optionValue
    optionValue="${optionValue///*(/)//}"
    # Trim any trailing slash from $optionValue
    optionValue="${optionValue%/}"

    case "${optionName}" in
        -l|--locale)
            declare -a locales
            frija_list_locales locales

            # Remove below line when Bash 4.3 or newer is used
            locales=("${_FRIJA_FILE_LIST[@]}")

            result="${locales[*]}"
            if [[ -z "${result}" ]]; then
                local message="No Frija locale repo found; please install "
                message+="one using ${BOLD}frija locale${CLEAR} command "
                message+="and try again"
                _frija_completion_help_message "${message}"
            fi
            ;;
        -f|--feature)
            local message="Please provide a feature ID, "
            message+="i.e. something like ABCD-1234"
            _frija_completion_help_message "${message}"
            ;;
        -j|--jira)
            local message="Please provide a Jira ID, "
            message+="i.e. something like ABCD-1234"
            _frija_completion_help_message "${message}"
            ;;
        -e|--develop)
            result="${LATEST} ${VERSION}"
            ;;
        -r|--released)
            result="${LATEST} ${VERSION}"
            ;;
        -w|--workspace)
            local message="Please provide a name for the new Workspace"
            _frija_completion_help_message "${message}"
            ;;
        -S|--system)
            local message="(PLACEHOLDER) Please provide a System name"
            _frija_completion_help_message "${message}"
            ;;
        -E|--entity)
            print_debug "--entity option detected"
            # Regex for extracting any locale from the command
            # line
            declare -r LOCALE_PATTERN="^[^-]*-(l|-locale = )([^ ]*).*$"
            print_debug "LOCALE_PATTERN=${LOCALE_PATTERN}"

            # What is on the command line
            local currentItems
            currentItems="${COMP_WORDS[*]:1}"
            print_debug "currentItems='${currentItems}'"

            local selectedLocale=""
            if [[ "${currentItems}" =~ ${LOCALE_PATTERN} ]]; then
                selectedLocale="${BASH_REMATCH[2]}"
            fi
            print_debug "selectedLocale='${selectedLocale}'"

            local subsystemname=""
            if [[ -n "${selectedLocale}" ]]; then
                local localePath="${_VOLLA_PATH}/${selectedLocale}"
                subsystemname=$(frija_retrieve_subsystem_name "${localePath}")
            fi
            print_debug "subsystemname='${subsystemname}'"

            # Get all repo files in $subsystemname
            declare -a files
            local ssrPath="${_VOLLA_PATH}/${subsystemname}"
            print_debug "ssrPath=${ssrPath}"
            frija_list_files files "${ssrPath}" "" "${REPO_LIST_EXTENSION}"
            print_debug "_FRIJA_FILE_LIST=${_FRIJA_FILE_LIST[*]}"

            # Remove below line when Bash 4.3 or newer is used
            files=("${_FRIJA_FILE_LIST[@]}")
            print_debug "files=${files[*]}"

            # Remove suffix ${REPO_LIST_EXTENSION} from file list
            files=("${files[@]%${REPO_LIST_EXTENSION}}")
            print_debug "files=${files[*]}"

            result="${files[*]}"
            print_debug "result=${result[*]}"
            ;;
    esac

    print_debug_exit "${result}"
    echo "${result}"
}


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} -u/--uri=URI -e/--entity -j/--jira=JIRA

$(synopsis)

  Workspaces are where repos may be cloned and operated on using other
  frija commands and the core idea behind Frija is that one workspace
  is used for a specific task (e.g. a feature).

  ${BOLD}That is the assumption is that when working on multiple features
  there is one dedicated workspace per feature.${CLEAR}

  When creating a workspace a name may be assigned to it. If no name
  is given the feature ID is simply used as the workspace name.

  Frija is based on the premise of a workspace containing all repos
  that are necessary to build a system or subsystem or subsystem of
  a sybsystem and so on. Furthermore the build result of each repo is
  expected to be stored in a Build folder in the root of each repo.
  References between repos are provided by Frija via the frija build
  command and the corresponding build scripts (Makefile,
  CMakeLists.txt, .sln, .csproj, .csproj, ...) are injected with this
  information by Frija.

  More information about this can be found in the frija build command.

  The system/subsystem structure is found via a locale; ${BOLD}frija locale${CLEAR}
  command is used for cloning and updating such repos.

  The list of repos to work on is stored in a .repos file; this
  command can be used for doing that, for instance when the workspace
  is created. This file is derived from information stored in one or
  more subsystem repos (which may have dependencies between them). The
  Volla tool used for managing the subsystem repo information.

  ${BOLD}Note:${CLEAR} There is a variant where the feature ID is not used as the
        default workspace name and this variant is solely designed for
        the use-case of daily/nightly builds etc. In this case the
        name of the folder is implicitly given by the name of the
        system/subsystem, version, and so on in order to guarantee a
        unique workspace name. This means that in this mode there is
        no support given by the Frija commands for switching to a
        feature branch, updating repos, pushing repos, and so on.

  The ${BOLD}frija${CLEAR} command provides the convenience option ${BOLD}--switch${CLEAR} for an
  easy way of getting to a workspace as well as switching between
  them. It is based on the bash built-ins ${BOLD}pushd${CLEAR} and ${BOLD}popd${CLEAR} (which thus
  can also be used for switching between other folders as well).

${BOLD}Options:${CLEAR}
  -lLOCALE,           already cloned locale repo LOCALE to operate on; this is
   --locale=LOCALE      from where ENTITY within SYSTEM is found

  -fID,               ID identifying preferred feature branch to use when no
   --feature=ID         explicit version is set in used ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file, e.g. ID set
                        to ${BOLD}ABCD-1234${CLEAR} then the feature branch name is assumed to
                        start with
                          feature/${BOLD}ABCD-1234${CLEAR}
                          ${BOLD}Note:${CLEAR} When no default workspace NAME is provided the
                                given feature ID is also used as the default
                                workspace NAME

  -jJIRA,             alias for -f/--feature where JIRA is the same as ID
   --jira=JIRA
  -eTYPE,             develop branch set as preferred branch when no explicit
   --develop=TYPE       version is set in used ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file, actual commit
                        selected depend on TYPE
                          - TYPE "${LATEST}" means track latest commit on branch
                          - TYPE "${VERSION}" means latest commit on branch
                            with a valid version tag; either a version in
                            development or a released version depending on
                            which tag is newer

  -rTYPE,             release branch (e.g. master brach) set as preferred branch
                        when no explicit version is set in used ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file,
   --released=TYPE      actual commit selected depend on TYPE
                          - TYPE "${LATEST}" means track latest commit on branch
                          - TYPE "${VERSION}" means latest commit on branch
                            with a valid released version tag; that is a
                            version tag ${BOLD}without${CLEAR} any release candidate number

  -wNAME,             name NAME for the workspace; if a feature ID is provided
   --workspace=NAME     then it will be used as the default value

  -SSYSTEM,           name of system entity to use when resolving dependencies;
   --system=SYSTEM      the system level allows for defining overrides regarding
                        from where an entity is obtained (PLACEHOLDER)

  -ENAME,             name of entity to export a dependency list file for
   --entity=ENTITY      (extension ${BOLD}${REPO_LIST_EXTENSION}${CLEAR}); used by other ${BOLD}frija${CLEAR} commands and
                        placed in the root of the workspace folder

  -v,                 verbose output
   --verbose
  -h,                 print this message
   --help
  -d,                 enable debug printouts sent to stderr
   --debug
  -D,                 do not execute commands with side effects, just echo them
   --dry-run

${BOLD}Examples:${CLEAR}
  ${BOLD}$ ${_FRIJA_USAGE_NAME} --locale=foo-subsystem-repo_37 --entity=Bar_07 --feature=ABCD-1234${CLEAR}
  This command will create the folders
    ${UNDERLINE_ON}${PWA}/${_FRIJA_HOME_FOLDER}/ABCD-1234${UNDERLINE_OFF}
    ${UNDERLINE_ON}${PWA}/${_FRIJA_HOME_FOLDER}/ABCD-1234/${_FRIJA_CONFIG_FOLDER_NAME}${UNDERLINE_OFF}

  and pupulate the configuration folder with the files
    - ${UNDERLINE_ON}${BRANCH_STRATEGY}${UNDERLINE_OFF}
    - ${UNDERLINE_ON}${CONFIGURED_LOCALE}${UNDERLINE_OFF}

  as well as generate a repolist file for entity ${BOLD}Bar_07${CLEAR} (${BOLD}Bar_07${REPO_LIST_EXTENSION}${CLEAR}) that is
  stored in workspace folder ${BOLD}ABCD-1234${CLEAR}.

  ${BOLD}Note:${CLEAR} The locale repo (${BOLD}foo-subsystem-repo_37${CLEAR} in above example) resolve the
        entity with precedence; that is the first subsystem-repo it finds with
        an entity named ${BOLD}Bar_07${CLEAR} is assumed to be the expected
        entity.

  ${BOLD}Note:${CLEAR} The idea is that also system name (via the placeholder option
        -S/--system) must be given, since a subsystem-repo repo can define
        multiple systems where each of them point to an entity within
        a DAG. Due to that Volla interface to such DAGs as well as the
        DAG data structure is not completed this is an area that will
        evolve over time.

EOF
}


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi

# Include core command line parsing support, common settings and
# utility functions.
# shellcheck source=./.preamble.bash
source "${_FENSALIR_HOME}/.preamble.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]] && [[ -z "${_BOOTSTRAP_PATH}" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This check is ONLY valid when we are not sourced from the
    # bootstrap script. Since it reuses some of the functions defined
    # in this script.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...

DRY_RUN="n"
VERBOSE="n"
DEBUG="n"

localeValue=""
commitType=""
defaultBranchStrategy=""
workspaceName=""
entityName=""
systemName=""

# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -l|--locale)
            shift  # Move to option argument
            localeValue="${1:-}"
            ensure_option_argument_set "Locale" "${localeValue}"
            shift  # Move to next option
            ;;
        -f|--feature)
            ensure_option_not_set "Commit type" "${commitType}"
            commitType="${_FRIJA_FEATURE}"
            shift  # Move to option argument
            defaultBranchStrategy="${1}"
            ensure_option_argument_set "Feature ID" "${defaultBranchStrategy}"
            shift  # Move to next option
            ;;
        -j|--jira)
            ensure_option_not_set "Commit type" "${commitType}"
            commitType="${_FRIJA_FEATURE}"
            shift  # Move to option argument
            defaultBranchStrategy="${1}"
            ensure_option_argument_set "Jira ID" "${defaultBranchStrategy}"
            shift  # Move to next option
            ;;
        -e|--develop)
            ensure_option_not_set "Commit type" "${commitType}"
            commitType="${_FRIJA_DEVELOP}"
            shift  # Move to option argument
            defaultBranchStrategy="${1}"
            ensure_option_argument_set "Default branch strategy" \
                                       "${defaultBranchStrategy}"
            shift  # Move to next option
            ;;
        -r|--released)
            ensure_option_not_set "Commit type" "${commitType}"
            commitType="${_FRIJA_RELEASE}"
            shift  # Move to option argument
            defaultBranchStrategy="${1}"
            ensure_option_argument_set "Default branch strategy" \
                                       "${defaultBranchStrategy}"
            shift  # Move to next option
            ;;
        -w|--workspace)
            ensure_option_not_set "Workspace name" "${workspaceName}"
            # Move to required option argument
            shift
            workspaceName="${1}"
            ensure_option_argument_set "Workspace name" "${workspaceName}"
            shift  # Move to next option
            ;;
        -S|--system)
            ensure_option_not_set "System" "${systemName}"
            # Move to required option argument
            shift
            systemName="${1}"
            ensure_option_argument_set "System" "${systemName}"

            # Append extension AFTER above check; otherwise we would
            # not be able to detect if $1 is empty
            systemName="${systemName}${REPO_LIST_EXTENSION}"

            shift  # Move to next option
            ;;
        -E|--entity)
            ensure_option_not_set "Entity" "${entityName}"
            # Move to required option argument
            shift
            entityName="${1}"
            ensure_option_argument_set "Entity" "${entityName}"

            # Append extension AFTER above check; otherwise we would
            # not be able to detect if $1 is empty
            entityName="${entityName}${REPO_LIST_EXTENSION}"

            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .core_preamble.bash for more information
            set_dry_run
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


message=""

# Ensure user has set a default branch strategy
if [[ -z "${commitType}" ]]; then
    message="One of Feature, Develop, or Released must be specified, aborting."
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi

case "${commitType}" in
    "${_FRIJA_FEATURE}")
        # When $workspaceName is unset assign $defaultBranchStrategy
        # (feature ID) to it as the default name of the workspace.
        workspaceName="${workspaceName:-${defaultBranchStrategy}}"
        ;;
    "${_FRIJA_DEVELOP}"|"${_FRIJA_RELEASE}")
        if [[ -z "${workspaceName}" ]]; then
            message="No explicit workspace name has been given, aborting."
            print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
        fi
        ;;
    *)
        message="Unknown value '${commitType}' assigned to commitType."
        print_error "${message}" $_FRIJA_EXIT_INTERNAL_ERROR
        ;;
esac


if [[ -z "${localeValue}" ]]; then
    message="A locale must be specified on the command line, aborting."
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi


# Get path to subsystem repo via configured locale
localePath="${_VOLLA_PATH}/${localeValue}"
subsystemName=""
subsystemName=$(frija_retrieve_subsystem_name "${localePath}")

if [[ -z "${subsystemName}" ]]; then
    message="Unable to find any subsystem repo for locale '${localeValue}'; "
    message+="is locale repo correctly configured?"
    print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
fi


if [[ -n "${systemName}" ]] && [[ -z "${entityName}" ]]; then
    message="Only ${BOLD}System${CLEAR} is not yet supported."
    print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
fi

if [[ -n "${systemName}" ]] && [[ -n "${entityName}" ]]; then
    message="${BOLD}Entity${CLEAR} in combination with ${BOLD}System${CLEAR} "
    message+="is not yet supported."
    print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
fi

if [[ -z "${systemName}" ]] && [[ -z "${entityName}" ]]; then
    message="Jira option must be combined with ${BOLD}at least${CLEAR} one of "
    message+="System or Entity."
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi



################################################################################
# Creating and initializing workspace folder
################################################################################
workspacePath="${_FRIJA_PATH}/${workspaceName}"
workspaceConfigPath="${workspacePath}/${_FRIJA_CONFIG_FOLDER_NAME}"

if [[ -d "${workspaceConfigPath}" ]]; then
    message="Workspace '${workspaceName}' already exist; please either "
    message+="remove or rename it and try again."
    print_error "${message}" _FRIJA_EXIT_OTHER_PROBLEM
fi


################################################################################
# TO BE REMOVED: Placeholder implementation until volla command has
#                been implemented.
################################################################################
# START
#

# (Re)Construct path to where the configured $REPO_LIST_EXTENSION file
# is located
metadataFile="${entityName}"
metadataFilePath="${_VOLLA_PATH}/${subsystemName}/${metadataFile}"

if [[ ! -r "${metadataFilePath}" ]]; then
    message="Entity file '${metadataFile}' does not exist, aborting."
    print_error "${message}" _FRIJA_EXIT_OTHER_PROBLEM
fi

################################################################################
# END (of placeholder implementation)
################################################################################


print_separator
print_message "Creating workspace ${BOLD}${workspaceName}${CLEAR}"
print_separator
print_message ""

# Create workspace with configuration folder in one go
message="Creating workspace configuration folder"
command=("${SINGLE}" "${message}" mkdir --parents "${workspaceConfigPath}")
run "${command[@]}"



################################################################################
# Saving workspace configuration persistently
#

# Save configured default branch strategy
print_message "Saving configured default branch strategy"
{
    echo "${commitType} ${defaultBranchStrategy}"
} >> "${workspaceConfigPath}/${BRANCH_STRATEGY}"

# Save configured locale
print_message "Saving configured locale"
{
    echo "${LOCALE_FIELD_NAME} ${localeValue}"
    # TODO: Keep or remove? If keep, then what is LOCALE_ID and
    # LOCALE_ID_FIELD_NAME?
    #
    # echo "${LOCALE_ID_FIELD_NAME} ${localeID}"
} >> "${workspaceConfigPath}/${CONFIGURED_LOCALE}"

# Configuration saved
################################################################################


################################################################################
# TO BE REMOVED: Placeholder implementation until volla command has
#                been implemented.
################################################################################
# START
#

# Copy $REPO_LIST_EXTENSION file to the new workspace folder
message="Copying ${REPO_LIST_EXTENSION} file"
command=("${SINGLE}" "${message}" cp "${metadataFilePath}" "${workspacePath}")
run "${command[@]}"

sed -i 's%\(Branch Name: feature/\).*%\1'"${defaultBranchStrategy}"'%' \
    "${workspacePath}/${metadataFile}"
################################################################################
# END (of placeholder implementation)
################################################################################

print_message "Workspace '${workspaceName}' created successfully."
if [[ -z "${_FRIJA_SCRIPTED_BUILD:-}" ]]; then
    print_message
    print_double_separator
    print_message "Now go to ${BOLD}${workspacePath}${CLEAR} using command"
    print_message "  ${BOLD}frija --switch=${workspaceName}${CLEAR}"
    print_message "and then do"
    print_message "  ${BOLD}frija clone --verbose${CLEAR}"
    print_message "to clone the corresponding repos."
    message="(If you have multiple .repos-files in the workspace then you "
    message+="must choose which to use using '--input' flag)"
    print_message "${message}"
    print_message
fi
