#!/bin/bash
PROGRAM_PATH=$(realpath -e "${0}")

# Remove shortest suffix matching "/*"
PROGRAM_DIR="${PROGRAM_PATH%/*}"

# Base path is the search path to the metadata tools repo containing
# this command. That is the name of the command is removed and the
# folder containing the command from the path. What remains is the
# BASE_PATH.
#
# Remove shortest suffix matching "/*/*", i.e. last and 2nd last part of path
BASE_PATH="${PROGRAM_PATH%/*/*}"

# Remove everything before last part of path, i.e. repo name
BASE_FOLDER="${BASE_PATH##*/}"


# - Option followed by : indicate a required argument to option
# - Option followed by :: indicate an optional argument to option
# - Comma (,) separates multiple long options
OPTIONS="i:j:m:s:e:vhdD"
LONGOPTS="initialize:,jira:,material-group:,system:,entity:,goto-jira-folder;verbose,help,debug,dry-run"


function synopsis()
{
    cat <<EOF
  Create and initialize ${BOLD}volla${CLEAR} and ${BOLD}frija${CLEAR} home folders.
EOF
}


function usage()
{
    cat <<EOF
${BOLD}Usage:${CLEAR} ${NAME} -i/--initialize=MG INITFILE
${BOLD}  or:${CLEAR}  ${NAME} [OPTION]
$(synopsis)

  The first variant is mainly for the very first installation of the
  metadata tools and the second variant is for subsequent invocations
  of the tools per Jira-ticket.

  The second variant is used for generating a file that is used as input
  to other ${BOLD}frija${CLEAR} commands; it lists repos to operate on. Such files are
  placed in a folder named after the Jira-ticket. It is this folder that
  for instance any cloned repos are placed in when running the
  corresponding ${BOLD}frija${CLEAR} commands.

  -i MG, --initialize=MG      initialize ${BOLD}volla${CLEAR} and ${BOLD}frija${CLEAR} home folders and set
                                default Material Group for subsequent ${BOLD}frija${CLEAR}
                                commands.
                                NOTE: May not be combined with any other option.
  -j JIRA, --jira=JIRA        Jira ticket ID to use when creating folder to host
                                generated repo file list file
                                NOTE: Required option unless initialize is given
  -m MG, --material-group=MG  override default material group ('${MG}')
  -s SYSTEM, --system=NAME    name of system entity to use when resolving
                                dependencies; the system level allows for
                                defining overrides regarding from where an
                                entity is obtained
  -e NAME, --entity=NAME      name of entity to export a dependency list file
                                for; dependency list is used by other ${BOLD}frija${CLEAR}
                                commands
  -v, --verbose               verbose output
  -h, --help                  print this message
  -d, --debug                 enable debug printouts
                                NOTE: Debug messages are prefixed with
                                      "*** LINE  " where LINE is current line
                                      number and written to stderr.
  -D, --dry-run               just echo command lines instead of executing them

  NOTE: When using Jira option, at least one of system and entity options must
        also be given.
EOF
    # Print common input file format documentation, see .preamble
    print_initfile_format_doc

    cat <<EOF


${BOLD}Examples:${CLEAR}
  ${BOLD}$ ${NAME} --initialize=97-60 metadata.init${CLEAR}
  This command will ensure that ${UNDERLINE_ON}${PWA}/volla${UNDERLINE_OFF} exist and move
  ${UNDERLINE_ON}${BASE_FOLDER}${UNDERLINE_OFF} to this folder (if not already there). It will also
  clone (or download corresponding files from a file archive like
  Artifactory) the metadata repos listed in ${BOLD}metadata.init${CLEAR} and configure the
  default metadata-repo to be ${UNDERLINE_ON}mg97-60-metadata${UNDERLINE_OFF}.

  ${BOLD}$ ${NAME} --jira=FLTS-1234 --system=Foo_01 --entity=PilotStation_01${CLEAR}
  This command will create
  ${UNDERLINE_ON}${PWA}/frija/FLTS-1234${UNDERLINE_OFF}
      Frija home folder for Jira issue FLTS-1234; for instance cloned
      repos are placed here
  ${UNDERLINE_ON}${PWA}/frija/FLTS-1234/PilotStation_01.repos${UNDERLINE_OFF}
      File containing list of repos to clone (or download corresponding
      files from a file archive like Artifactory) to be able to build
      entity ${BOLD}PilotStation_01${CLEAR}.


${BOLD}Files:${CLEAR}
  ${UNDERLINE_ON}${PWA}/volla${UNDERLINE_OFF}
      Volla home folder containing
  ${UNDERLINE_ON}${PWA}/volla/mg<MG-name>_metadata${UNDERLINE_OFF}
      Repo containing metadata files for MG <MG-name>
  ${UNDERLINE_ON}${PWA}/volla/${BASE_FOLDER}${UNDERLINE_OFF}
      Repo containing metadata tools ${BOLD}volla${CLEAR} and ${BOLD}frija${CLEAR}
  ${UNDERLINE_ON}${PWA}/volla/bin${UNDERLINE_OFF}
      bin folder with links to volla and frija commands
  ${UNDERLINE_ON}${PWA}/volla/.frija_config${UNDERLINE_OFF}
      Config file for ${BOLD}frija${CLEAR}
  ${UNDERLINE_ON}${PWA}/frija/<Jira issue ID>${UNDERLINE_OFF}
      Home folder for ${BOLD}frija${CLEAR} per Jira issue
  ${UNDERLINE_ON}${PWA}/frija/<Jira issue ID>/${FRIJA_FOLDER_NAME}${UNDERLINE_OFF}
      Folder containing per-Jira issue specific temporary files for
      ${BOLD}frija${CLEAR}
  ${UNDERLINE_ON}${PWA}/frija/FLTS-1234/*.repos${UNDERLINE_OFF}
      Per enity files containing lists of repos used by ${BOLD}frija${CLEAR} to
      operate on repos (clone, build, and so on) for corresponding
      entity. May also contain references to items  stored in a file
      archive like Artifactory.
EOF

    # Print common exit codes documentation, see .preamble
    print_exit_codes_doc
}


# Include core command line parsing support, common settings and
# utility functions.
# shellcheck source=./.core_preamble.bash
source "${PROGRAM_DIR}/.core_preamble.bash"

# Default value in help message for MG in case Frija config file does
# not yet exist
UNDEFINED_MG="Undefined"

# Read configured material group configuration so we can print its
# value in help message.
#
# shellcheck source=../../.frija_config
if [[ -f "${FRIJA_CONFIG_PATH}" ]]; then
    source "${FRIJA_CONFIG_PATH}"
fi


MG=""
JIRA=""
SYSTEM=""
ENTITY=""
DRY_RUN="n"
VERBOSE="n"
DEBUG="n"

INIT_MODE="Initialize"
JIRA_MODE="Jira"
MODE=""

# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -i|--initialize)
            ensure_mode_not_set "${INIT_MODE}" "${MODE}"
            MODE=${INIT_MODE}
            # Move to required option argument
            shift
            MG="${1}"
            ensure_option_argument_set "Material Group" "${MG}"
            # Move to next option
            shift
            ;;
        -j|--jira)
            ensure_mode_not_set "${JIRA_MODE}" "${MODE}"
            MODE=${JIRA_MODE}
            # Move to required option argument
            shift
            JIRA="${1}"
            ensure_option_argument_set "Jira" "${JIRA}"
            # Move to next option
            shift
            ;;
        -m|--material-group)
            ensure_mode_set "${JIRA_MODE}" "${MODE}" "Material Group"
            ensure_option_not_set "Material Group" "${MG}"
            # Move to required option argument
            shift
            MG="${1}"
            ensure_option_argument_set "Material Group" "${MG}"
            # Move to next option
            shift
            ;;
        -s|--system)
            ensure_mode_set "${JIRA_MODE}" "${MODE}" "System"
            ensure_option_not_set "System" "${SYSTEM}"
            # Move to required option argument
            shift
            SYSTEM="${1}"
            ensure_option_argument_set "System" "${SYSTEM}"
            # Move to next option
            shift
            ;;
        -e|--entity)
            ensure_mode_set "${JIRA_MODE}" "${MODE}" "Entity"
            ensure_option_not_set "Entity" "${ENTITY}"
            # Move to required option argument
            shift
            ENTITY="${1}"
            ensure_option_argument_set "Entity" "${ENTITY}"
            # Move to next option
            shift
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            # If MG has not been set, use DEFAULT_MG unless it also
            # has not been set. In the latter case UNDEFINED_MG is
            # assigned to MG.
            MG="${MG:-${DEFAULT_MG:-${UNDEFINED_MG}}}"
            usage
            exit 0
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done


# Check for valid combination of values
if [[ "${MODE}" == "${INIT_MODE}" ]]; then
    # handle non-option argument
    if [[ $# -ne 1 ]]; then
        print_error "A single input file is required." 4
    fi
    ! inFile=$(readlink -e -n "${1}")
    if [[ "${PIPESTATUS[0]}" -gt 0 ]]; then
        print_error "'${1}' does not exist." 7
    fi

    # Ensure PWD does not start with BASE_PATH
    ABS_PWD=$(readlink -e -n "${PWD}")
    if [[ "${ABS_PWD##${BASE_PATH}}" != "${ABS_PWD}" ]]; then
        print_error "Current working directory must not be within ${BASE_FOLDER}." 7
    fi

    # Ensure inFile does not start with BASE_PATH
    if [[ "${inFile##${BASE_PATH}}" != "${inFile}"* ]]; then
        print_error "Input file must not be located within ${BASE_FOLDER}." 7
    fi

    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}" >&2
    fi

    # Make command to be an array
    declare -a command
    command=("${FIRST}" "${PWD}" mkdir --parents "${VOLLA_PATH}")
    run "${command[@]}"
    command=("${MIDDLE}" "${PWD}" mkdir --parents "${FRIJA_PATH}/${FRIJA_FOLDER_NAME}")
    run "${command[@]}"
    command=("${MIDDLE}" "${PWD}" "${FRIJA_CONFIG_PATH}" echo "DEFAULT_MG=${MG}")
    run_with_redirect "${command[@]}"
    command=("${MIDDLE}" "${PWD}" "${VOLLA_PATH}/${CONFIG_NAME}" echo "export PATH=\"${VOLLA_PATH}/${BASE_FOLDER}/bin:\${PATH}\"")
    run_with_redirect "${command[@]}"
    command=("${LAST}" "${PWD}" cd "${VOLLA_PATH}")
    run "${command[@]}"

    # Finally ensure that the metadata tools repo is located in
    # the VOLLA_PATH folder
    if [[ ! -d "${VOLLA_PATH}/${BASE_FOLDER}" ]]; then
        command=("${SINGLE}" "${PWD}" mv "${BASE_PATH}" "${VOLLA_PATH}")
        run "${command[@]}"
    else
        print_message "${BASE_FOLDER} already exists in ${VOLLA_PATH}, nothing to move."
    fi

    # Now it is time to clone metadata repos into the VOLLA_PATH folder!
    # -r make read to not treat backslash character as an escape character
    print_message "${BOLD}Ensuring initial metadata repo(s) are found here ${VOLLA_PATH}${CLEAR}"
    while read -r source uri rest; do
        replicate_data "${source}" "${uri}"
    done < "${inFile}"

    echo
    print_message "Environment for ${BOLD}Frija${CLEAR} and ${BOLD}Volla${CLEAR} successfully configured!"
    echo
    echo
    print_message "Now you can manually source ${VOLLA_PATH}/${CONFIG_NAME}, i.e. execute the command"
    print_message "  source ${VOLLA_PATH}/${CONFIG_NAME}"
    print_message "${BOLD}and/or${CLEAR} add above command to your .bashrc file and start a new shell."
elif [[ "${MODE}" == "${JIRA_MODE}" ]]; then
    if [[ -z "${DEFAULT_MG}" ]]; then
        print_error "You must initialize first before you can generate an input file for the other ${BOLD}frija${CLEAR} commands." 7
    fi

    # Ensure MG has been assigned a value
    MG="${MG:-${DEFAULT_MG}}"

    if [[ -n "${SYSTEM}" ]] && [[ -z "${ENTITY}" ]]; then
        echo "Only system '${SYSTEM}'..."
        print_error "Only ${BOLD}System${CLEAR} is not yet supported." 7
    elif [[ -z "${SYSTEM}" ]] && [[ -n "${ENTITY}" ]]; then
        # Placeholder implementation until volla command has been implemented.
        jira_destination=$(realpath -m "${FRIJA_PATH}/${JIRA}" --relative-to="${PWD}")
        command=("${FIRST}" "${PWD}" mkdir --parents "${jira_destination}")
        run "${command[@]}"

        metadata_file="${ENTITY}.repos"
        metadata_file_path="${VOLLA_PATH}/mg${MG}-metadata/${metadata_file}"
        metadata_file_path=$(realpath -e "${metadata_file_path}" --relative-to="${PWD}")
        command=("${LAST}" "${PWD}" cp "${metadata_file_path}" "${jira_destination}")
        run "${command[@]}"

        print_message "Now go to ${BOLD}${jira_destination}${CLEAR} and use command"
        print_message "  ${BOLD}frija clone ${metadata_file}${CLEAR}"
        print_message "to clone the corresponding repos."
    elif [[ -n "${SYSTEM}" ]] && [[ -n "${ENTITY}" ]]; then
        echo "System '${SYSTEM}' and entity '${ENTITY}'"
        print_error "${BOLD}Entity${CLEAR} in combination with ${BOLD}System${CLEAR} is not yet supported." 7
    else
        print_error "Jira option must be combined with ${BOLD}at least${CLEAR} one of System or Entity." 2
    fi

    # handle non-option argument
    if [[ $# -gt 0 ]]; then
        print_error "Unrecognized arguments; ${*}." 4
    fi
else
    print_error "You must select either ${BOLD}${INIT_MODE}${CLEAR} mode or ${BOLD}${JIRA_MODE}${CLEAR} mode." 2
fi
