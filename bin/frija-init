#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e "${0}")

_FRIJA_PROGRAM_DIR="${METADATATOOLS_HOME}"

# Base path is the search path to the metadata tools repo containing
# this command. That is the name of the command is removed and the
# folder containing the command from the path. What remains is the
# _VOLLA_BASE_PATH.
#
# Remove shortest suffix matching "/*/*", i.e. last and 2nd last part of path
_VOLLA_BASE_PATH="${METADATATOOLS_HOME%/*}"

# Remove everything before last part of path, i.e. repo name
_VOLLA_BASE_FOLDER="${_VOLLA_BASE_PATH##*/}"


MG=""
JIRA=""
SYSTEM=""
ENTITY=""
UPDATE="n"
TOOL_UPDATE="n"
DRY_RUN="n"
VERBOSE="n"
DEBUG="n"
initFile=""

INIT_MODE="Reinitialize"
UPDATE_MODE="Update"
TOOL_UPDATE_MODE="Tool-update"
JIRA_MODE="Jira"
MODE=""


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "g:i:j:tum:s:e:vhdD"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "default-mg:,init:,jira:,tool-update,update,material-group:,system:,entity:,verbose,help,debug,dry-run"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)



function synopsis()
{
    cat <<EOF
  Create and initialize ${BOLD}volla${CLEAR} and ${BOLD}frija${CLEAR} home folders.
EOF
}


function _frija_subcommand_option_values()
{
    # RETURN trap is executed before execution resumes after a shell
    # function returns. This RETURN trap restores the extglob
    # (extended pattern matching for globbing expressions)
    # shellcheck disable=SC2064
    trap "$(shopt -p extglob)" RETURN
    shopt -s extglob

    local optionName="${1}"
    local optionValue="${2:-}"
    local result=""

    # Collapse any repeated slashes into single slashes in $optionValue
    optionValue="${optionValue///*(/)//}"
    # Trim any trailing slash from $optionValue
    optionValue="${optionValue%/}"

    case "${optionName}" in
        -e|--entity)
            # Regex for extracting any material group from the command
            # line
            declare -r MG_PATTERN="^.*-(m|-material-group=)([^ ]*).*$"

            # What is on the command line
            local currentItems
            currentItems="${COMP_WORDS[*]:1}"

            local materialGroup="${DEFAULT_MG}"
            if [[ "${currentItems}" =~ ${MG_PATTERN} ]]; then
                materialGroup="${BASH_REMATCH[2]}"
            fi

            # Get all repo files in $materialGroup
            declare -a files
            local mgMetadataPath="${_VOLLA_PATH}/mg${materialGroup}-metadata"
            frija_list_files files "${mgMetadataPath}" "" "${REPO_LIST_EXTENSION}"

            # Remove below line when Bash 4.3 or newer is used
            files=("${_FRIJA_FILE_LIST[@]}")

            # Remove suffix ${REPO_LIST_EXTENSION} from file list
            files=("${files[@]%${REPO_LIST_EXTENSION}}")

            result="${files[*]}"
            ;;
        -i|--init)
            if [[ -z "${optionValue}" ]]; then
                optionValue="${PWD}"
            fi

            declare -a initList
            declare -a initDirs
            initList=("${optionValue}"/*"${INIT_FILE_EXTENSION}")
            initDirs=()

            # If no files were found during globbing then we get back
            # the glob pattern. Thus only way to detect if globbing
            # was unable to find any files is to compare first item in
            # array with glob pattern...
            if [[ "${initList[0]}" == "${optionValue}/*${INIT_FILE_EXTENSION}" ]]; then
                # Make file globbing array empty
                initList=()
            fi

            # Now list only directories
            local findPath="${optionValue}"
            local findName=""

            if [[ ! -e "${optionValue}" ]]; then
                # Partial path; remove everything after last slash
                # and put that in $findPath and take everything
                # after last slash and put that in $findName
                findPath="${optionValue%/*}"
                findName="${optionValue#${findPath}}"

                # Remove initial slash from $findName
                findName="${findName#/}"
            fi

            if (( "${#initList[@]}" == 0 )); then
                # The list of filenames ending with
                # "${INIT_FILE_EXTENSION}" is empty. This might be
                # because the value on the command line ends with for
                # instance just ".in"; thus we should try to expand it
                # and see if there are any "${INIT_FILE_EXTENSION}"
                # files hiding behind a partial filename.

                # Create a temporary array $initFiles that stores all
                # files starting with $findName. This array is then
                # filtered and all entries that ends with
                # "${INIT_FILE_EXTENSION}" are appended to the (empty)
                # $initList array.
                declare -a initFiles
                initFiles=()

                mapfile -t initFiles < <(find "${findPath}" \
                                               -maxdepth 1 \
                                               -name "${findName}*" \
                                               -type f)
                local item
                for item in "${initFiles[@]}"; do
                    if [[ "${item}" == *${INIT_FILE_EXTENSION} ]]; then
                        initList+=("${item}")
                    fi
                done
            fi

            # Now we can let find list only directories for us.
            # This is done using a combination of mapfile,
            # redirect, and Process Substitution to get the output
            # from the find command into an array.
            mapfile -t initDirs < <(find "${findPath}" \
                                          -maxdepth 1 \
                                          -name "${findName}*" \
                                          -type d)

            if (( "${#initDirs[@]}" == 1 )); then
                if (( "${#initList[@]}" == 1 )) && \
                       [[ "${initList[0]}" == "${initDirs[0]}"* ]]; then
                    # When there is only a single directory AND a
                    # single init file AND the directory is also a
                    # prefix to the init file path, then there is no
                    # reason to show the directory at all.
                    initDirs=()
                fi
            fi

            # Append a slash to all entries in the $initDirs array
            initDirs=( "${initDirs[@]/%//}" )

            result="${initList[*]} ${initDirs[*]}"
            ;;
        -j|--jira)
            result=$(_frija_jira_folder_list)
            if [[ -z "${result}" ]]; then
                # Regex for valid Jira ID
                declare -r JIRA_PATTERN="^[A-Z]{4}-[0-9]{4}$"

                if [[ "${optionValue}" =~ ${JIRA_PATTERN} ]]; then
                    result="${optionValue}"
                fi
            fi
            ;;
        -m|--material-group)
            # Get all repo files in $materialGroup
            declare -a materialGroups

            # 1. Find all folders whose name starts with "mg" and ends
            #    with "-metadata" in $_VOLLA_PATH
            #
            # 2. Strip prefix path as well as "mg" folder name prefix
            #    from the entries in the $materialGroups array
            #
            # 3. Strip the "-metadata" suffix from all entries in the
            #    $materialGroups array
            materialGroups=("${_VOLLA_PATH}/mg"*"-metadata")
            materialGroups=("${materialGroups[@]#*/${_VOLLA_HOME_FOLDER}/mg}")
            materialGroups=("${materialGroups[@]%-metadata}")

            result="${materialGroups[*]}"
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    cat <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} -g/--default-mg=MG -i/--init=FILE
${BOLD}  or:${CLEAR}  ${_FRIJA_USAGE_NAME} OPTION
$(synopsis)

  There are four variants
  1. Used for updating installation of the metadata tools + metadata repos
  2. For subsequent invocations of the tools per Jira-ticket.
  3. For updating the metadatatools repo
  4. For updating data metadata repo(s) and corresponding file(s) used in
     Jira-ticket folders

  The ${BOLD}first${CLEAR} variant re-initializes volla folder.

  The ${BOLD}second${CLEAR} variant crates a "home" folder for (and named after) the Jira
  ticket and places a data file in this folder that is used as input to other
  ${BOLD}frija${CLEAR} commands; file lists repos to operate on. It is also this folder where
  any cloned repos are placed when running the ${BOLD}frija clone${CLEAR} command.

  The ${BOLD}third${CLEAR} variant updates the metadatatools repo. In case a branch can not be
  fast-forwarded it is forcibly moved to point to the same commit as remote
  point to. And a tag named "frija" is set to mark the old commit.

  The ${BOLD}fourth${CLEAR} variant places a fresh data file generated from metadata repos in a
  Jira home folder.

${BOLD}Options:${CLEAR}
  -gMG, --default-mg=MG      set default Material Group for subsequent ${BOLD}frija${CLEAR}
                                commands.
                                ${BOLD}Note:${CLEAR} May ${UNDERLINE_ON}only${UNDERLINE_OFF} be combined with
                                      ${BOLD}-i/--init${CLEAR} option.
  -iFILE, --init=FILE        clone metadata repos listed in FILE with
                                extension ${BOLD}${INIT_FILE_EXTENSION}${CLEAR}
                                ${BOLD}Note:${CLEAR} Must ${UNDERLINE_ON}only${UNDERLINE_OFF} be combined with
                                      ${BOLD}-g/--default-mg${CLEAR} option.
  -jJIRA, --jira=JIRA         JIRA (Jira ticket ID) to use when creating folder
                                to host generated repo file list file
                                ${BOLD}Note:${CLEAR} Required option unless initialize or
                                      tool update is given; in the latter case
                                      it will be used when selecting branch to
                                      checkout for the cloned repos (feature
                                      branches must start with Jira ticket ID)
                                ${BOLD}Note:${CLEAR} Not checked with Jira server
                                      whether it is a valid ticket ID or not.
                                      However the given ID is used for instance
                                      when cloning repos to checkout that
                                      feature branch (if it exists) for each
                                      repo.
  -t, --tool-update          update metadatatool repo
  -u, --update               update metadata repos
                                ${BOLD}Note:${CLEAR} May ${UNDERLINE_ON}only${UNDERLINE_OFF} be combined with
                                      ${BOLD}-j/--jira${CLEAR}, ${BOLD}-m/--material-group${CLEAR},
                                      and ${BOLD}-e/--entity${CLEAR} options

  -mMG, --material-group=MG  override default material group ('${MG}')
                                ${BOLD}Note:${CLEAR} May ${UNDERLINE_ON}not${UNDERLINE_OFF} be combined with
                                      ${BOLD}-i/--init${CLEAR} option.
  -sSYSTEM, --system=NAME    name of system entity to use when resolving
                                dependencies; the system level allows for
                                defining overrides regarding from where an
                                entity is obtained
  -eNAME, --entity=NAME      name of entity to export a dependency list file
                                for (extension ${BOLD}${REPO_LIST_EXTENSION}${CLEAR}); used by other ${BOLD}frija${CLEAR}
                                commands and placed in Jira home folder
                                ${BOLD}Note:${CLEAR} May ${UNDERLINE_ON}not${UNDERLINE_OFF} be combined with
                                      ${BOLD}-i/--init${CLEAR} option.
  -v, --verbose               verbose output
  -h, --help                  print this message
  -d, --debug                 enable debug printouts
                                ${BOLD}Note:${CLEAR} Debug messages are prefixed with
                                      "*** LINE  " where LINE is current line
                                      number and written to stderr.
  -D, --dry-run               just echo command lines instead of executing them

  ${BOLD}Note:${CLEAR} When using Jira option, at least one of system and entity options must
        also be given.
EOF
    # Print common init file format documentation, see .preamble
    print_initfile_format_doc

    cat <<EOF


${BOLD}Examples:${CLEAR}
  ${BOLD}$ ${_FRIJA_USAGE_NAME} --default_mg=97-60 --init=metadata${CLEAR}
  This command will ensure that ${UNDERLINE_ON}${PWA}/volla${UNDERLINE_OFF} exist and copy
  ${UNDERLINE_ON}${_VOLLA_BASE_FOLDER}${UNDERLINE_OFF} repo to this folder (and make a backup if already there).
  It will also configure MG ${BOLD}97-60${CLEAR} to be the default MG and thus assume the init
  file will refer to a repo named ${UNDERLINE_ON}mg97-60-metadata${UNDERLINE_OFF} (which is then implicitly the
  default metadata repo). All repos listed in the ${BOLD}metadata${CLEAR} init file are assumed
  to be metadata repos and they are placed in ${UNDERLINE_ON}${PWA}/volla${UNDERLINE_OFF}. Furthermore,
  these repos are automatically setup to follow HEAD on develop branch (if it
  exists, otherwise master).

  In the ${UNDERLINE_ON}above${UNDERLINE_OFF} example the ${BOLD}metadata${CLEAR} file is assumed to be located in current
  working directory and named ${BOLD}metadata${INIT_FILE_EXTENSION}${CLEAR}.


  ${BOLD}$ ${_FRIJA_USAGE_NAME} --jira=FLTS-1234 --system=Foo_01 --entity=PilotStation_01${CLEAR}
  This command will create
  ${UNDERLINE_ON}${PWA}/frija/FLTS-1234${UNDERLINE_OFF}
      Frija home folder for Jira issue FLTS-1234; for instance cloned
      repos are placed here
  ${UNDERLINE_ON}${PWA}/frija/FLTS-1234/PilotStation_01${REPO_LIST_EXTENSION}${UNDERLINE_OFF}
      File containing list of repos to clone (or download corresponding
      files from a file archive like Artifactory) to be able to build
      entity ${BOLD}PilotStation_01${CLEAR}.


${BOLD}Files:${CLEAR}
  ${UNDERLINE_ON}${PWA}/volla${UNDERLINE_OFF}
      Volla home folder containing
  ${UNDERLINE_ON}${PWA}/volla/mg<MG-name>_metadata${UNDERLINE_OFF}
      Repo containing metadata files for MG <MG-name>
  ${UNDERLINE_ON}${PWA}/volla/${_VOLLA_BASE_FOLDER}${UNDERLINE_OFF}
      Repo containing metadata tools ${BOLD}volla${CLEAR} and ${BOLD}frija${CLEAR}
  ${UNDERLINE_ON}${PWA}/volla/bin${UNDERLINE_OFF}
      bin folder with links to volla and frija commands
  ${UNDERLINE_ON}${PWA}/volla/.frija_config${UNDERLINE_OFF}
      Config file for ${BOLD}frija${CLEAR}
  ${UNDERLINE_ON}${PWA}/frija/<Jira issue ID>${UNDERLINE_OFF}
      Home folder for ${BOLD}frija${CLEAR} per Jira issue
  ${UNDERLINE_ON}${PWA}/frija/<Jira issue ID>/${_FRIJA_FOLDER_NAME}${UNDERLINE_OFF}
      Folder containing per-Jira issue specific temporary files for
      ${BOLD}frija${CLEAR}
  ${UNDERLINE_ON}${PWA}/frija/FLTS-1234/*${REPO_LIST_EXTENSION}${UNDERLINE_OFF}
      Per enity files containing lists of repos used by ${BOLD}frija${CLEAR} to
      operate on repos (clone, build, and so on) for corresponding
      entity. May also contain references to items  stored in a file
      archive like Artifactory.
EOF

    # Print common exit codes documentation, see .preamble
    print_exit_codes_doc
}


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi

# Include core command line parsing support, common settings and
# utility functions.
# shellcheck source=./.preamble.bash
source "${METADATATOOLS_HOME}/.preamble.bash"

# Read configured material group configuration so we can print its
# value in help message.
#
# shellcheck source=../../.frija_config
if [[ -f "${_FRIJA_CONFIG_PATH}" ]]; then
    # shellcheck disable=SC1091
    source "${_FRIJA_CONFIG_PATH}"
fi

if [[ "${BASH_SOURCE[0]}" != "$0" ]] && [[ -z "${_BOOTSTRAP_PATH}" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This check is ONLY valid when we are not sourced from the
    # bootstrap script. Since it reuses some of the functions defined
    # in this script.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


# Default value in help message for MG in case Frija config file does
# not yet exist
UNDEFINED_MG="Undefined"


function initialize()
{
    local initFile="${1}"

    DEBUG="${2:-${DEBUG}}"
    DRY_RUN="${3:-${DRY_RUN}}"

    local jira="${4:-${_FRIJA_JIRA}}"

    ! initFile=$(readlink -e -n "${initFile}")
    if [[ "${PIPESTATUS[0]}" -gt 0 ]]; then
        print_error "'${1}' does not exist." 7
    fi

    # Ensure PWD does not start with _VOLLA_BASE_PATH
    ABS_PWD=$(readlink -e -n "${PWD}")
    if [[ "${ABS_PWD##${_VOLLA_BASE_PATH}}" != "${ABS_PWD}" ]]; then
        print_error "Current working directory must not be within ${_VOLLA_BASE_FOLDER}." 7
    fi

    # Ensure initFile does not start with _VOLLA_BASE_PATH
    if [[ "${initFile##${_VOLLA_BASE_PATH}}" != "${initFile}"* ]]; then
        print_error "Init file must not be located within ${_VOLLA_BASE_FOLDER}." 7
    fi

    # Ensure MG has been assigned a value
    MG="${MG:-${DEFAULT_MG}}"
    if [[ -z "${MG}" ]]; then
        print_error "A default MG must be defined before you can initialize." 7
    fi

    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  verbose: ${VERBOSE}, debug: ${DEBUG}, MG: ${MG}, in: ${initFile}" >&2
    fi


    # Make command to be a local array
    declare -a command

    command=("${FIRST}" "Initialize volla file structure" \
                        mkdir --parents "${_VOLLA_PATH}")
    run "${command[@]}"


    command=("${NONE}" "Set default MG" "${_FRIJA_CONFIG_PATH}" \
                       echo "DEFAULT_MG=${MG}")
    run_with_redirect "${command[@]}"


    # NOTE: Assume there is a SINGLE configuration file in this folder
    configFile=("${METADATATOOLS_HOME}/../config/"*".bash")
    configFileName="${configFile[0]##*/}"
    command=("${LAST}" "Initialize volla file structure" \
                       cp "${configFile[0]}" "${_VOLLA_PATH}")
    run "${command[@]}"


    if [[ "${_VOLLA_BASE_PATH}" != "${_VOLLA_PATH}"* ]]; then
        # When Volla and Frija has been installed properly
        # $_VOLLA_PATH should be a prefix to $_VOLLA_BASE_PATH. If
        # they differ it means that we should copy metadatatools repo
        # and so on.

        # Finally ensure that the metadata tools repo is located in
        # the VOLLA_PATH folder
        local oldBaseFolder=""
        if [[ -d "${_VOLLA_PATH}/${_VOLLA_BASE_FOLDER}" ]]; then
            local suffix=""
            # Make "unique" suffix from number of seconds since 1970-01-01
            suffix="$(date +%s)"
            oldBaseFolder="${_VOLLA_PATH}/${_VOLLA_BASE_FOLDER}_${suffix}"

            command=("${SINGLE}" "Create backup of old metadatatools repo" mv \
                                 "${_VOLLA_PATH}/${_VOLLA_BASE_FOLDER}" \
                                 "${oldBaseFolder}")
            run "${command[@]}"

            print_message ""
            print_message "${BOLD}Note:${CLEAR} ${_VOLLA_PATH}/${_VOLLA_BASE_FOLDER} ${BOLD}already exist!${CLEAR}"
            print_message "Moved it to ${oldBaseFolder} in case something went wrong."
            print_message ""
            print_message ""
        fi

        command=("${SINGLE}" "Copy metadatatools repo to Volla folder" \
                             cp -r "${_VOLLA_BASE_PATH}" "${_VOLLA_PATH}")
        run "${command[@]}"
    fi

    # Now it is time to clone metadata repos into the VOLLA_PATH folder!
    # -r make read to not treat backslash character as an escape character
    print_message "${BOLD}Ensuring metadata repo(s) are found here: ${_VOLLA_PATH}${CLEAR}"
    pushd "${_VOLLA_PATH}"
    while read -r source uri rest; do
        # Strip any carriage returns from the read values
        source=${source//$'\r'}
        uri=${uri//$'\r'}
        rest=${rest//$'\r'}

        replicate_data "${source}" "${uri}" "" "" "${jira}"
    done < "${initFile}"

    print_message ""
    print_message "Environment for ${BOLD}Frija${CLEAR} and ${BOLD}Volla${CLEAR} successfully configured!"
    print_message ""
    print_separator
    print_message "${BOLD}Now${CLEAR} you can manually source ${_VOLLA_PATH}/${configFileName}, i.e. execute the command"
    print_message "  source ${_VOLLA_PATH}/${configFileName}"
    print_message "each time a new shell is started ${BOLD}and/or add below to${CLEAR}"
    print_message "  ${HOME:?}/.bash_profile"
    print_message "and start a new shell to load the configuration."
    print_separator
    print_message ""
    print_message "${BOLD}To test${CLEAR} configuration try command 'frija --help' and if you get a friendly help message you are done!"
    print_message ""
    print_message "${BOLD}Once you have${CLEAR} verified that the command works, the next step is to use the frija init subcommand like this"
    print_message "  frija init --jira=${jira} --entity=Ios_01"
    print_message "where \"${BOLD}Ios_01${CLEAR}\" refers to a file named ${BOLD}Ios_01${REPO_LIST_EXTENSION}${CLEAR} found in the metadata repo for MG ${DEFAULT_MG}."
    print_message ""
    print_message "${BOLD}Note:${CLEAR} TAB completion should also work for ${UNDERLINE_ON}all${UNDERLINE_OFF} frija commands!"
    print_message "${BOLD}Note:${CLEAR} All frija commands support -h/--help option."
    print_message ""
    print_message "${BOLD}Tip:${CLEAR} To change the look-and-feel of the MinTTY terminal Git Bash (in Windows) uses you can use a ${BOLD}.minttyrc${CLEAR} file placed in your home folder. An example ${BOLD}.minttyrc${CLEAR} file is placed in the root of the ${BOLD}metadatatools_01${CLEAR} repo, i.e."
    print_message "  cp ${_VOLLA_PATH}/.minttyrc ${HOME}"
    print_message "The next time MinTTY is started the configuration file is applied."
    print_message "${BOLD}Note:${CLEAR} The example configuration file enables the same copy and paste shortcuts as Gnome Terminal uses; Shift + Crtl-c to copy and Shift + Ctrl-v for paste and turns off cursor blink and enables block cursor."
    print_separator
    print_message ""
    print_message "_unameOut=\"\$(uname -s)\""
    print_message "case \"\${_unameOut}\" in"
    print_message "    Linux*)"
    print_message "        if [[ -r \"/p/pwa/\${USER}/volla/metadata-config.bash\" ]]; then"
    print_message "            # shellcheck disable=SC1090,SC1091"
    print_message "            source \"/p/pwa/\${USER}/volla/metadata-config.bash\""
    print_message "        fi"
    print_message "        ;;"
    print_message "    MINGW*|CYGWIN*)"
    print_message "        if [[ -r \"/x/volla/metadata-config.bash\" ]]; then"
    print_message "            # shellcheck disable=SC1091"
    print_message "            source \"/x/volla/metadata-config.bash\""
    print_message "        fi"
    print_message "        ;;"
    print_message "esac"
}


function create_jira_folder()
{
    # Ensure MG has been assigned a value
    MG="${MG:-${DEFAULT_MG}}"
    if [[ -z "${MG}" ]]; then
        print_error "Material Group must be set." 2
    fi

    if [[ -n "${SYSTEM}" ]] && [[ -z "${ENTITY}" ]]; then
        print_error "Only ${BOLD}System${CLEAR} is not yet supported." 7
    elif [[ -z "${SYSTEM}" ]] && [[ -n "${ENTITY}" ]]; then
        jira_destination=$(realpath -m "${_FRIJA_PATH}/${JIRA}" --relative-to="${PWD}")
        command=("${FIRST}" "${PWD}" mkdir --parents "${jira_destination}/${_FRIJA_FOLDER_NAME}")
        run "${command[@]}"

        metadata_file="${ENTITY}"
        metadata_file_path="${_VOLLA_PATH}/mg${MG}-metadata/${metadata_file}"
        metadata_file_path=$(realpath -e "${metadata_file_path}" --relative-to="${PWD}")
        # Placeholder implementation until volla command has been implemented.
        # START
        command=("${LAST}" "${PWD}" cp "${metadata_file_path}" "${jira_destination}")
        run "${command[@]}"
        # END (of placeholder implementation)

        print_message "Now go to ${BOLD}${jira_destination}${CLEAR} using command"
        print_message "  ${BOLD}frija --switch=${JIRA}${CLEAR}"
        print_message "and then do"
        print_message "  ${BOLD}frija clone --input=${metadata_file}${CLEAR}"
        print_message "to clone the corresponding repos."
        print_message ""
        print_message "${BOLD}Note:${CLEAR} TAB-completion works!"
    elif [[ -n "${SYSTEM}" ]] && [[ -n "${ENTITY}" ]]; then
        echo "System '${SYSTEM}' and entity '${ENTITY}'"
        print_error "${BOLD}Entity${CLEAR} in combination with ${BOLD}System${CLEAR} is not yet supported." 7
    else
        print_error "Jira option must be combined with ${BOLD}at least${CLEAR} one of System or Entity." 2
    fi
}


# Test if _BOOTSTRAP_PATH is set
if [[ -v _BOOTSTRAP_PATH ]]; then
    # When we are sourced from the bootstrap script, it is here we
    # should return back to it.
    return
fi


# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -g|--default-mg)
            ensure_mode_set "MODE" "${INIT_MODE}" "Default Material Group"
            ensure_option_not_set "Default Material Group" "${DEFAULT_MG}"
            # Move to required option argument
            shift
            DEFAULT_MG="${1}"
            ensure_option_argument_set "Material Group" "${DEFAULT_MG}"
            # Move to next option
            shift
            ;;
        -i|--init)
            ensure_mode_set "MODE" "${INIT_MODE}" "Init file"
            ensure_option_not_set "Init file" "${initFile}"
            # Move to required option argument
            shift
            initFile="${1}"
            ensure_option_argument_set "Init file" "${initFile}"

            # Append extension AFTER above check; otherwise we would
            # not be able to detect if $1 is empty
            initFile="${initFile}${REPO_LIST_EXTENSION}"

            # Move to next option
            shift
            ;;
        -j|--jira)
            ensure_mode_set "MODE" \
                            "${JIRA_MODE}" "Jira issue" \
                            "${INIT_MODE}" "Init file" \
                            "${TOOL_UPDATE_MODE}" "Update metadata tool repo" \
                            "${UPDATE_MODE}" "Update metadata repos"
            ensure_option_not_set "Jira" "${JIRA}"
            # Move to required option argument
            shift
            JIRA="${1}"
            ensure_option_argument_set "Jira" "${JIRA}"
            # Move to next option
            shift
            ;;
        -t|--tool-update)
            ensure_mode_set "MODE" "${TOOL_UPDATE_MODE}" \
                            "Update metadatatools repo"
            ensure_boolean_option_not_set "Tool-update" "${TOOL_UPDATE}"
            TOOL_UPDATE="y"
            shift  # Move to next option
            ;;
        -u|--update)
            ensure_mode_set "MODE" "${UPDATE_MODE}" "Update metadata repo(s)"
            ensure_boolean_option_not_set "Update" "${UPDATE}"
            UPDATE="y"
            shift  # Move to next option
            ;;
        -m|--material-group)
            ensure_mode_set "MODE" \
                            "${JIRA_MODE}" "Material Group" \
                            "${UPDATE_MODE}" "Update metadata repos"
            ensure_option_not_set "Material Group" "${MG}"
            # Move to required option argument
            shift
            MG="${1}"
            ensure_option_argument_set "Material Group" "${MG}"
            # Move to next option
            shift
            ;;
        -s|--system)
            ensure_mode_set "MODE" "${JIRA_MODE}" "System"
            ensure_option_not_set "System" "${SYSTEM}"
            # Move to required option argument
            shift
            SYSTEM="${1}"
            ensure_option_argument_set "System" "${SYSTEM}"

            # Append extension AFTER above check; otherwise we would
            # not be able to detect if $1 is empty
            SYSTEM="${SYSTEM}${REPO_LIST_EXTENSION}"

            # Move to next option
            shift
            ;;
        -e|--entity)
            ensure_mode_set "MODE" \
                            "${JIRA_MODE}" "Entity" \
                            "${UPDATE_MODE}" "Update metadata repos"
            ensure_option_not_set "Entity" "${ENTITY}"
            # Move to required option argument
            shift
            ENTITY="${1}"
            ensure_option_argument_set "Entity" "${ENTITY}"

            # Append extension AFTER above check; otherwise we would
            # not be able to detect if $1 is empty
            ENTITY="${ENTITY}${REPO_LIST_EXTENSION}"

            # Move to next option
            shift
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            # If MG has not been set, use DEFAULT_MG unless it also
            # has not been set. In the latter case UNDEFINED_MG is
            # assigned to MG.
            MG="${MG:-${DEFAULT_MG:-${UNDEFINED_MG}}}"
            _frija_subcommand_usage
            exit 0
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .core_preamble.bash for more information
            set_dry_run
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done


# handle non-option argument
if [[ $# -gt 0 ]]; then
    print_error "Unrecognized arguments; ${*}." 4
fi


# Ensure MG has been assigned a value
MG="${MG:-${DEFAULT_MG}}"
if [[ -z "${MG}" ]]; then
    print_error "A default MG must be defined before you can initialize." 7
fi


# Check for valid combination of values
if [[ "${MODE}" == "${INIT_MODE}" ]]; then
    if [[ -z "${DEFAULT_MG}" ]]; then
        print_error "You must initialize first before you can generate an init file for the other ${BOLD}frija${CLEAR} commands." 7
    fi
    initialize "${initFile}" "" "" "${JIRA}"
elif [[ "${MODE}" == "${JIRA_MODE}" ]]; then
    if [[ -z "${DEFAULT_MG}" ]]; then
        print_error "You must initialize first before you can generate an init file for the other ${BOLD}frija${CLEAR} commands." 7
    fi

    create_jira_folder
elif [[ "${MODE}" == "${UPDATE_MODE}" ]]; then
    # Enter Volla folder
    pushd "${_VOLLA_PATH}" &> /dev/null

    # Iterate over all metadata repos, that is all directories that
    # start with "mg"
    declare -a metadataRepos
    metadataRepos=( mg* )

    # When globbing finds no matches we get the glob pattern back.
    # This is the only way to detect a failed globbing.
    if [[ "${metadataRepos[0]}" == "mg*" ]]; then
        print_error "No metadata repos found! Please re-initialize." 7
    fi

    for repo in "${metadataRepos[@]}"; do
        pushd "${repo}" &> /dev/null
        update_git_repo "${repo}" "${SINGLE}" "force"
        popd &> /dev/null
    done

    # Go back
    popd &> /dev/null

    if [[ -n "${ENTITY}" ]]; then
        mgMetadataPath="${_VOLLA_PATH}/mg${MG}-metadata/${ENTITY}"

        # If a Jira is set on the command line, use it instead of the
        # Jira implicitly obtained via path.
        if [[ -z "${JIRA}" ]]; then
            _frija_locate_frija_home
            JIRA="${_FRIJA_JIRA}"
            destination="${_FRIJA_HOME}"
        else
            destination="${_FRIJA_PATH}/${JIRA}"
        fi

        if [[ -r "${mgMetadataPath}" && -s "${mgMetadataPath}" ]]; then
            declare -a command
            command=("${SINGLE}" "Copying ${ENTITY} from MG ${MG} to ${JIRA}" \
                                 cp "${mgMetadataPath}" "${destination}")
            run "${command[@]}"
        elif [[ -s "${mgMetadataPath}" ]]; then
            print_error "The file '${mgMetadataPath}' is of zero length; will not copy it to '${destination}'." 7
        else
            print_error "The file '${mgMetadataPath}' does not exist." 7
        fi
    fi
elif [[ "${MODE}" == "${TOOL_UPDATE_MODE}" ]]; then
    print_message "Updating ${BOLD}${_VOLLA_BASE_PATH##*/}${CLEAR} repo..."
    pushd "${_VOLLA_BASE_PATH}" &> /dev/null
    update_git_repo "${_VOLLA_BASE_PATH}" "${SINGLE}" "force"
    print_message "Done!"
else
    print_error "You must select one of ${BOLD}${INIT_MODE}${CLEAR}, ${BOLD}${UPDATE_MODE}${CLEAR}, ${BOLD}${TOOL_UPDATE_MODE}${CLEAR}, or ${BOLD}${JIRA_MODE}${CLEAR} mode." 2
fi
