#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "s::t::r::wai:h"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "scorch::,type::,result::,all,wordy,input:,help,sequential,verbose,trace,debug,dry-run,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
  Clean Build and Result folders across repos.
EOF
}


_FRIJA_CLEAN_RELEASE="RELEASE"
_FRIJA_CLEAN_DEBUG="DEBUG"
_FRIJA_CLEAN_BOTH="BOTH"


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -s|--scorch)
            result="${_FRIJA_CLEAN_RELEASE} "
            result+="${_FRIJA_CLEAN_DEBUG} "
            result+="${_FRIJA_CLEAN_BOTH}"
            ;;
        -t|--type)
            result="${_FRIJA_CLEAN_RELEASE} "
            result+="${_FRIJA_CLEAN_DEBUG} "
            result+="${_FRIJA_CLEAN_BOTH}"
            ;;
        -r|--result)
            result="${_FRIJA_CLEAN_RELEASE} "
            result+="${_FRIJA_CLEAN_DEBUG} "
            result+="${_FRIJA_CLEAN_BOTH}"
            ;;
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            if [[ -z "${result}" ]]; then
                local message="Current Frija Workspace is corrupt; "
                message+="no ${REPO_LIST_EXTENSION} file found"
                _frija_completion_help_message "${message}"
            fi
            ;;
        --force-os)
            result="${_FENSALIR_SUPPORTED_OS_VARIANTS[*]}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  When cleaning, that is removing build artifacts, there are three
  levels controlling how deep the cleansing is done

  -s/--scorch     The deepest cleansing that removes ${BOLD}all${CLEAR} traces of
                    files created by GENERATE and BUILD stages for
                    both Release and/or Debug. That is scorch removes
                    some additional files needed for building the repo
                    itself in addition to what is cleansed by 'build'
                    and 'result' levels.

  -t/--type       Cleanse only files created by the BUILD stage; that
                    is files in the Build folder are removed in
                    addition to what is removed by 'result' level.

                    Please note that this cleansing level does not
                    differentiate between 'static' or 'dynamic' builds
                    regardless of if the underlying build system does
                    that or not. This is due to that the entire Build
                    folder is removed.

  -r/--result     Restrict the BUILD cleansing to only removing files
                    in the Result folder; that is no differentiation
                    between any 'static' or 'dynamic' results
                    regardless of if the underlying build system
                    supports that or not.

  On top of this the build option take an optional argument
  controlling which of Release and Debug subfolders (or both of them)
  gets cleansed. Default behavior is to use the same default TYPE as
  is used by the ${BOLD}frija build${CLEAR} command.

  ${BOLD}Note:${CLEAR} When there is a Makefile in the root of a Workspace this
        command assumes that GNU Make is to be used for building the
        repos. By default it is assumed that a parallel build should
        be used when building using GNU Make, but this behavior may be
        supporessed by giving the --sequential option to this command.
        The Makefile used for building (regardless of if it is located
        in the root of the workspace or in the root of a repo) is
        assumed to be of the format that can be generated by the
        ${BOLD}frija generate${CLEAR} command.

${BOLD}
  Behavior of this command varies slightly depending on where you are
  within generic folder structure shown below${CLEAR}

    frija
      |
      +-- WORKSPACE
                |
                +-- COMPOSITE-NAME
                               |
                               +-- REPO

  The basic rule of thumb is that when you are within a REPO then this
  command is ONLY applied to that repo, otherwise it is applied to
  all applicable repos listed in the input file.

  This default rule-of-thumb-behavior can be overridden when you are
  within REPO (or sub-folder to REPO); you give the -a/--all option on
  the command line.

  The -a/--all option is an escape mechanism that allow you to apply
  the command to all repos listed in the input file regardless of
  where you are within the WORKSPACE directory tree.


  ${UNDERLINE_ON}Background${UNDERLINE_OFF}

  The complete build process consist of the stages
  ${BOLD}GENERATE${CLEAR}   Create non-version controlled files needed to build, for instance
               inter-repo dependency files, make files (generated by CMake),
               and so on

  ${BOLD}BUILD${CLEAR}      Actual compilation stage; which may also generate
             non-version controlled files like files generated
             from Google proto-files

  ${BOLD}PREPARE${CLEAR}    Copy files from Build folder to Prepare folder in a structure that
               is similar to how it should be installed on the target system

  ${BOLD}ARCHIVE${CLEAR}    Create installation archive based on content in Prepare folder and
                            place it within the Archive folder

  In addition to the above stages, there is also the ${BOLD}CLEAN${CLEAR} stage, (this command).

${BOLD}Options:${CLEAR}
  -s[TYPE],             cleanse everything for given optional build TYPE
   --scorch[=TYPE]        inclding files created by frija generate command.

                          Valid values for TYPE are
                          - ${BOLD}RELEASE${CLEAR} => Release build ${BOLD}(default)${CLEAR}
                          -   ${BOLD}DEBUG${CLEAR} => Debug build
                          -    ${BOLD}BOTH${CLEAR} => Both Debug and Release builds

                          ${BOLD}Note:${CLEAR} Generated build input files specific
                                to Frija are also removed in addition
                                to what is removed in the BUILD clean
                                action.

                          ${BOLD}Note:${CLEAR} It is invalid to combine with
                                'build' and 'result' actions.

  -t[TYPE],             clean files in Build and/or Result folders for given
   --type[=TYPE]          optional build TYPE.

                          Valid values for TYPE are
                          - ${BOLD}RELEASE${CLEAR} => Release build ${BOLD}(default)${CLEAR}
                          -   ${BOLD}DEBUG${CLEAR} => Debug build
                          -    ${BOLD}BOTH${CLEAR} => Both Debug and Release builds

                          ${BOLD}Note:${CLEAR} Generated build input files specific
                                to Frija are ${BOLD}NOT${CLEAR} removed.

                          ${BOLD}Note:${CLEAR} It is invalid to combine with
                                'scorch' and 'result' actions.


  -r[TYPE],             clean Result folder only for given optional build TYPE.
   --result[=TYPE]
                          Valid values for TYPE are
                          - ${BOLD}RELEASE${CLEAR} => Release build ${BOLD}(default)${CLEAR}
                          -   ${BOLD}DEBUG${CLEAR} => Debug build
                          -    ${BOLD}BOTH${CLEAR} => Both Debug and Release builds

                          ${BOLD}Note:${CLEAR} Generated build input files specific
                                to Frija are ${BOLD}NOT${CLEAR} removed.

                          ${BOLD}Note:${CLEAR} It is invalid to combine with
                                'scorch' and 'build' actions.

  -w,                 show more information such as executed build command
   --wordy

  -a,                 apply command to all applicable repos listed in input
   --all                file; default or given on the command line via
                        -i/--input option. This option is applied by default
                        when outside of a repo (but still within a workspace).

  -iFILE,             apply selected clean operation to repos listed in FILE
   --input=FILE

  -h,                 print this message
   --help

  --sequential        force a sequential build when GNU Make is used

  --verbose           verbose output

  --trace             trace output

  --debug             enable debug printouts sent to stderr

  --dry-run           do not execute commands with side effects, just echo them

  --force-os=OS       force command to assume given OS instead of detected OS

${BOLD}Examples:${CLEAR}

  ${BOLD}Note:${CLEAR} If outside of a repo the example commands below will apply the
        selected clean action to the repos listed in the default input
        file, otherwise the action will only apply to the current repo
        in the workspace.


  ${BOLD}$ ${_FRIJA_USAGE_NAME} --build${CLEAR}

  This command will clean the RELEASE build in both the Build and
  Result folders. This is due to that it is the default cleansing
  type.

  ${BOLD}$ ${_FRIJA_USAGE_NAME} --build=BOTH${CLEAR}

  This command will clean both the RELEASE and DEBUG builds in both
  the Build and Result folders.

  ${BOLD}$ ${_FRIJA_USAGE_NAME} --scorch${CLEAR}

  This command will scorch the RELEASE build in both the Build and
  Result folders as well as Frija build files generated by ${BOLD}frija
  generate${CLEAR} command. This is due to that it is the default cleansing
  type.

  ${BOLD}Note:${CLEAR} This implies that ${BOLD}frija generate${CLEAR} command must be run after
        scorch action before it is possible to use ${BOLD}${_FRIJA_USAGE_NAME}${CLEAR} again.

  ${BOLD}$ ${_FRIJA_USAGE_NAME} --scorch=BOTH${CLEAR}

  This command will scorch both the RELEASE and DEBUG builds in both
  the Build and Result folders as well as Frija build files generated
  by ${BOLD}frija generate${CLEAR} command.

  ${BOLD}Note:${CLEAR} This implies that ${BOLD}frija generate${CLEAR} command must be run after
        scorch action before it is possible to use ${BOLD}${_FRIJA_USAGE_NAME}${CLEAR} again.

${BOLD}See also:${CLEAR}
  (frija) ${BOLD}build${CLEAR} and ${BOLD}generate${CLEAR} commands for further information

EOF
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${_FENSALIR_HOME}/.preamble.bash"

# Include generic VCS support.
#
# shellcheck source=./.vcs_functions.bash
source "${_FENSALIR_HOME}/.vcs_functions.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...


# Configure Bash options
_frija_configure_bash


# Include common command configuration.
#
# shellcheck source=./.common_command_config.bash
source "${_FENSALIR_HOME}/.common_command_config.bash"


DRY_RUN="n"
SEQUENTIAL="n"
VERBOSE="n"
TRACE="n"
WORDY="n"
DEBUG="n"
allRepos="n"

buildType=""
cleanAction=""

scorch="n"
build="n"
result="n"

inFile=""
osOverride=""

finalMessage=""


# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -s|--scorch)
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            ensure_boolean_option_not_set "Build" "${build}"
            ensure_boolean_option_not_set "Result" "${result}"
            scorch="y"
            # Set to value sent directly to Makefile
            cleanAction="scorch"

            ensure_option_not_set "Build type" "${buildType}"
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_BUILD_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_CLEAN_DEBUG}" \
                                 "${_FRIJA_CLEAN_RELEASE}" \
                                 "${_FRIJA_CLEAN_BOTH}"
            shift  # Move to next option
            ;;
        -t|--type)
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            ensure_boolean_option_not_set "Build" "${build}"
            ensure_boolean_option_not_set "Result" "${result}"
            build="y"
            # Set to value sent directly to Makefile
            cleanAction="clean"

            ensure_option_not_set "Build type" "${buildType}"
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_BUILD_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_CLEAN_DEBUG}" \
                                 "${_FRIJA_CLEAN_RELEASE}" \
                                 "${_FRIJA_CLEAN_BOTH}"
            shift  # Move to next option
            ;;
        -r|--result)
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            ensure_boolean_option_not_set "Build" "${build}"
            ensure_boolean_option_not_set "Result" "${result}"
            result="y"
            # Set to value sent directly to Makefile
            cleanAction="cleanresult"

            ensure_option_not_set "Build type" "${buildType}"
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_BUILD_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_CLEAN_DEBUG}" \
                                 "${_FRIJA_CLEAN_RELEASE}" \
                                 "${_FRIJA_CLEAN_BOTH}"
            shift  # Move to next option
            ;;
        -w|--wordy)
            ensure_boolean_option_not_set "Wordy" "${WORDY}"
            WORDY="y"
            shift  # Move to next option
            ;;
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        --sequential)
            ensure_boolean_option_not_set "Sequential Build" "${SEQUENTIAL}"
            SEQUENTIAL="y"
            shift  # Move to next option
            ;;
        --verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        --trace)
            ensure_boolean_option_not_set "Trace" "${TRACE}"
            TRACE="y"
            shift  # Move to next option
            ;;
        --debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        --dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        --force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done

if [[ -z "${buildType}" ]]; then
    message="You must specify one of -t/--type, -r/--result, or -s/--scorch, "
    message+="aborting."
    print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi

declare -a buildTypeList=()
case "${buildType}" in
    "${_FRIJA_CLEAN_DEBUG}")
        buildTypeList=("${DEBUG_DIR}")
        ;;
    "${_FRIJA_CLEAN_RELEASE}")
        buildTypeList=("${RELEASE_DIR}")
        ;;
    "${_FRIJA_CLEAN_BOTH}")
        buildTypeList=("${RELEASE_DIR}" "${DEBUG_DIR}")
        ;;
    "")
        message="Build type must be specified, aborting."
        print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
        ;;
    *)
        message="Unknown build type '${buildType}', aborting."
        print_error "${message}" $_FRIJA_EXIT_CMD_LINE_PROBLEMS
        ;;
esac


################################################################################
# Consistency checks
################################################################################

# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    _FENSALIR_OS_ID="${osOverride}"
fi


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


print_debug "verbose: ${VERBOSE}, trace: ${TRACE}, debug: ${DEBUG}"


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_WS_PATH, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_WS_PATH or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
#
# Note: See .preamble.bash for more information about
# cwd_in_workspace_repo_folder_p()
_frija_locate_workspace
REPO_SUBPATH=$(cwd_in_workspace_repo_folder_p "")
cd "${_FRIJA_WS_PATH}"


FENSALIR_ENVIRONMENT=""
FENSALIR_ENVIRONMENT=$(frija_retrieve_environment_name "${_FRIJA_WS_PATH##*/}")

FRIJA_BUILD_ENVIRONMENT=""
FRIJA_BUILD_ENVIRONMENT=$(frija_retrieve_build_environment_name \
                       "${FENSALIR_ENVIRONMENT}")

# shellcheck source=./.seci_parser.bash
source "${_FENSALIR_HOME}/.seci_parser.bash"

################################################################################
# Common functions
#


################################################################################
# Below are build system specific functions used for generating input
# file(s) injecting dependency information etc.
################################################################################


################################################################################
# GNU Make
#

function make_clean()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"    # E.g. msbuild;csproj or msbuild;sln
    local repoName="${3}"

    local message=""

    # Set up environment needed for executing GNU Make. The reset of
    # the environment is specified in the
    # $FRIJA_GENERATED_MAKEFILE_FRAGMENT file and applied by the
    # Makefile.
    local buildEnvPath="${_VOLLA_PATH}/${FRIJA_BUILD_ENVIRONMENT}"

    # TODO: Replace hardcoded value of floating with for instance a
    # tag name matching Fensalir version that is expected to be set in
    # the Frija build environment repo.
    local buildEnvVersion="floating"

    local seciList="${MAKE_SECI_NAME_SANS_OS_AND_EXTENSION}"
    seciList+="${FENSALIR_SECI_EXTENSION}"

    print_debug "buildEnvPath='${buildEnvPath}'"
    print_debug "buildEnvVersion='${buildEnvVersion}'"
    print_debug "seciList='${seciList}'"

    # List of environment variable names to export to the
    # isolated environment. It is assumed that the values of
    # these names is obtained by evaluating a variable with the
    # same name.
    local envList="_FENSALIR_GNUMAKE_PATH"
    envList+=",FRIJA_GENERATED_MAKEFILE_FRAGMENT"

    if [[ -z "${repoFolder}" ]]; then
        # Assume user wants to have a parallel make
        repoFolder="${_FRIJA_WS_PATH}"
    else
        local inputFile="${repoFolder}/${FRIJA_GENERATED_MAKEFILE_FRAGMENT}"
        if [[ -f "${inputFile}" ]]; then
            print_debug "inputFile='${inputFile}'"
        else
            message="Missing Frija dependency file in repo '${repoFolder}'. "
            message+="Have you perhaps missed running "
            message+="${BOLD}frija generate${CLEAR}? This must be done before "
            message+="you can run ${BOLD}frija build${CLEAR}."
            print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
        fi
    fi

    local parallelBuild=""
    if [[ "${SEQUENTIAL}" == "n" ]]; then
        parallelBuild="-j"
    fi

    if [[ -f "${repoFolder}/Makefile" ]]; then
        # Now ask GNU Make Makefile to clean requested Build Type for
        # Build and Release folder(s) if they exist.

        declare -a command=()
        # Provide two variants of commands depending on if make should
        # use parallel build or not.
        if [[ -n "${parallelBuild}" ]]; then
            command=("${SINGLE}" "" \
                                 "${buildEnvPath}" \
                                 "${buildEnvVersion}" \
                                 "${seciList}" \
                                 "${envList}" \
                                 make "${parallelBuild}" \
                                 "-C" "${repoFolder}" \
                                 "${cleanAction}" \
                                 "${buildType,,}")
        else
            command=("${SINGLE}" "" \
                                 "${buildEnvPath}" \
                                 "${buildEnvVersion}" \
                                 "${seciList}" \
                                 "${envList}" \
                                 make "-C" "${repoFolder}" \
                                 "${cleanAction}" \
                                 "${buildType,,}")
        fi
        run_isolated "${command[@]}"
    else
        message="Missing Makefile in repo '${repoFolder}'. "
        message+="Please add a Makefile to the repo and try again."
        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    fi

    if [[ "${scorch}" == "n" ]]; then
        finalMessage="Build artifacts has been removed, but existing Frija "
        finalMessage+="generated files have been preserved."
    else
        finalMessage="Build artifacts ${BOLD}as well as${CLEAR} existing "
        finalMessage+="Frija generated files have been ${BOLD}removed${CLEAR}."
        finalMessage+="\\n\\n"
        finalMessage+="Please start over from ${BOLD}frija generate${CLEAR} "
        finalMessage+="to recreate ${FRIJA_GENERATED_MAKEFILE_FRAGMENT} file "
        finalMessage+="in processed repos before you can call "
        finalMessage+="${BOLD}frija build${CLEAR} again."
    fi

    print_debug_exit
}


function make_scorch()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"    # E.g. msbuild;csproj or msbuild;sln
    local repoName="${3}"
    local externalDeps="${4}"  # External dependencies to use

    # Call ordinary clean function for GNU Make that sort out if a
    # normal clean or a scorch clean should be done...
    make_clean "${repoFolder}" "${parameters}" "${repoName}" "${externalDeps}"

    print_debug_exit
}

#
# Make
################################################################################



################################################################################
# CMAKE
#

function cmake_clean()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"    # E.g. msbuild;csproj or msbuild;sln
    local repoName="${3}"
    local externalDeps="${4}"  # External dependencies to use

    local buildFolder="${repoFolder}/${BUILD_DIR}"
    declare -a command

    # Make CMake clean up any files it is aware of first, for instance
    # files placed in the $GENERATED folder
    command=("${SINGLE}" "${repoFolder} (CMake --clean)" \
                         cmake --clean "${BUILD_DIR}/${buildType}")

    # Now do a deep cleansing of the $BUILD_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${buildFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${BUILD_DIR}/${type}${CLEAR})"

            command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="Please re-run ${BOLD}frija generate${CLEAR} to recreate "
    finalMessage+="CMake build structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(_frija_create_sentence_sequence and buildTypeList ${BOLD})"
    finalMessage+=" before you can call ${BOLD}frija build${CLEAR} again for "
    finalMessage+="it/them."

    print_debug_exit
}


function cmake_scorch()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"    # E.g. msbuild;csproj or msbuild;sln
    local repoName="${3}"
    local externalDeps="${4}"  # External dependencies to use

    # First do a normal clean...
    cmake_clean "${repoFolder}" "${parameters}" "${repoName}"

    # ...and then do the scorch cleaning
    local dependencyFile="${repoName}${CMAKE_DEPENDENCY_FILE_SUFFIX}"
    declare -a command
    command=("${SINGLE}" "Removing ${dependencyFile}..." \
                        rm -f "${repoFolder}/${dependencyFile}")
    run "${command[@]}"

    local generatedFolder="${BUILD_DIR}/${GENERATED}"
    declare -a command
    command=("${SINGLE}" "Removing ${generatedFolder}..." \
                        rm -fr "${repoFolder}/${generatedFolder}")
    run "${command[@]}"

    finalMessage="Existing Frija Dependency files has been "
    finalMessage+="${BOLD}removed${CLEAR}.\\n\\n"
    finalMessage+="Please start over from ${BOLD}frija generate${CLEAR} "
    finalMessage+="to recreate CMake build structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(_frija_create_sentence_sequence and buildTypeList ${BOLD})"
    finalMessage+=" before you can call ${BOLD}frija build${CLEAR} "
    finalMessage+="and so on for it/them."

    print_debug_exit
}

#
# CMAKE
################################################################################



################################################################################
# MSBUILD
#

function msbuild_clean()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"    # E.g. msbuild;csproj or msbuild;sln
    local repoName="${3}"
    local externalDeps="${4}"  # External dependencies to use

    local buildFolder="${repoFolder}/${BUILD_DIR}"

    local composite=""
    local name=""
    local version=""
    local sha=""
    local rest=""
    IFS='/' read -r composite name version sha rest <<< \
       "${repoFolder/${REPO_SEPARATOR}//}"

    # Now do a deep cleansing of the $BUILD_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${buildFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${BUILD_DIR}/${type}${CLEAR})"

            command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    # shellcheck disable=SC2155
    local cmd="$(type -p cmd.exe)"
    if [[ -z "${cmd}" ]]; then
        local message="Could not find CMD.EXE in PATH, aborting."
        print_error "${message}" $_FRIJA_EXIT_OTHER_PROBLEM
    fi

    local locale=""
    local version=""
    local configs=""
    local seciList=""
    local rest=""

    # shellcheck disable=SC2034
    IFS=";" read -r locale version configs seciList rest <<< \
       "${externalDeps}"

    # Common base path to the locale repo
    local localePath="${_VOLLA_PATH}/${locale}"

    # Input file to MSBuild.exe command
    local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"
    local inputFile="${repoFolder}/${repoName}.${type}"

    declare -a command=()

    # Make Msbuild clean up any files it is aware of after we have removed
    # the build folder or folders
    local message="Restoring NuGet packages in ${repoFolder} "
    message+="using MSBuild..."
    local buildType=""
    for buildType in "${buildTypeList[@]}"; do
        command=("${SINGLE}" "MSBuild Clean target for ${buildType}..." \
                             "${localePath}" \
                             "${version}" \
                             "${seciList}" \
                             "" \
                             "${cmd}" "//c" \
                             "${_FENSALIR_HOME}/run_windows_command.bat" \
                             MSBuild.exe \
                             "-p:Configuration=${buildType}" \
                             "-target:Clean" \
                             "${inputFile}")
        run_isolated "${command[@]}"
    done


#    # Make Msbuild clean up any files it is aware of after we have removed
#    # the build folder or folders
#    declare -a command
#    for type in "${buildTypeList[@]}"; do
#        local inputFile="${name}.${fileType}"
#        command=("${LAST}" "MSBuild Clean target for ${type}..." \
#                           MSBuild.exe \
#                           "-p:Configuration=${type}" \
#                           "-target:Clean" \
#                           "${repoFolder}/${inputFile}")
#        run "${command[@]}"
#    done

    # Cascade to Prepare folder
    msbuild_clean_prepare_folder "${repoFolder}"

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="You can now  call ${BOLD}frija build${CLEAR} again for "
    # shellcheck disable=SC2086
    finalMessage+="$(_frija_create_sentence_sequence and buildTypeList ${BOLD})"
    finalMessage+=" "

    print_debug_exit
}


function msbuild_scorch()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"    # E.g. msbuild;csproj or msbuild;sln
    local repoName="${3}"
    local externalDeps="${4}"  # External dependencies to use

    # First do a normal clean...
    msbuild_clean "${repoFolder}" "${parameters}" "${repoName}"

    # ...and then do the scorch cleaning
    local objFolder="${repoFolder}/${BUILD_DIR}/obj"
    local propertyFile="${repoFolder}/${MSBUILD_PROPERTY_FILE}"
    local nugetFolder="${repoFolder}/Packages"

    command=("${FIRST}" "Removing ${objFolder}..." rm -fr "${objFolder}")
    run "${command[@]}"

    command=("${MIDDLE}" "Removing ${nugetFolder}..." rm -fr "${nugetFolder}")
    run "${command[@]}"

    command=("${LAST}" "Removing ${propertyFile}" rm -f "${propertyFile}")
    run "${command[@]}"

    local generatedFolder="${BUILD_DIR}/${GENERATED}"
    declare -a command
    command=("${SINGLE}" "Removing ${generatedFolder}..." \
                        rm -fr "${repoFolder}/${generatedFolder}")
    run "${command[@]}"

    finalMessage="Existing Frija Dependency files has been "
    finalMessage+="${BOLD}removed${CLEAR}.\\n\\n"
    finalMessage+="Please start over from ${BOLD}frija generate${CLEAR} "
    finalMessage+="to recreate Frija folder structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(_frija_create_sentence_sequence and buildTypeList ${BOLD})"
    finalMessage+=" before you can call ${BOLD}frija build${CLEAR} "
    finalMessage+="and so on for it/them."

    print_debug_exit
}

#
# MSBUILD
################################################################################


function clean_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"
    local repoName="${3}"

    local message=""

    case "${tool}" in
        make)
            make_clean "${destination}" \
                       "${parameters}" \
                       "${repoName}" \
                       "${externalDeps}"
            ;;
        cmake)
            cmake_clean "${destination}" \
                        "${parameters}" \
                        "${repoName}" \
                        "${externalDeps}"
            ;;
        msbuild)
            msbuild_clean "${destination}" \
                          "${parameters}" \
                          "${repoName}" \
                          "${externalDeps}"
            ;;
        *)
            message="Unsupported build tool '${tool}' for '${destination}', "
            message+="aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
    esac
}


function scorch_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"
    local repoName="${3}"
    local externalDeps="${4}"   # External dependencies to use if any

    local message=""

    case "${tool}" in
        make)
            make_scorch "${destination}" \
                        "${parameters}" \
                        "${repoName}" \
                        "${externalDeps}"
            ;;
        cmake)
            cmake_scorch "${destination}" \
                         "${parameters}" \
                         "${repoName}" \
                         "${externalDeps}"
            ;;
        msbuild)
            msbuild_scorch "${destination}" \
                           "${parameters}" \
                           "${repoName}" \
                           "${externalDeps}"
            ;;
        *)
            message="Unsupported build tool '${tool}' for '${destination}', "
            message+="aborting."
            print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
    esac
}


########
# Iterate over the lines in the input file and act on each line
# depending on $os and $vcs fields.

processedReposFlag=""
foundOperatingSystem=""
operation="processed"
declare -a skippedOperatingSystems=()

if [[ -r "${_FRIJA_WS_PATH}/Makefile" ]]
then
    # There exists a Makefile in the Workspace folder. Assume it is
    # GNU Make user wants to use for the Makefile.

    message="Cleaning repos using Makefile "

    if [[ -z "${REPO_SUBPATH}" ]] || [[ "${allRepos}" == "y" ]]
    then
        message+="${BOLD}${_FRIJA_WS_PATH##*/}/Makefile${CLEAR}"
        print_message "${message}"
        print_separator

        # User is outside of a repo or has given the '--all' flag.
        # This implies all repos should be built.
        make_clean "" "" ""
    else
        message+="${BOLD}${REPO_SUBPATH}/Makefile${CLEAR}"
        print_message "${message}"
        print_separator
        # User is within a repo and has not given the '--all' flag.
        # This means that it is only that repo that should be built.
        make_clean "${REPO_SUBPATH}" "" ""
    fi

    print_double_separator
    print_message "Clean completed successfully!"
else
    print_debug "inFile='${inFile}'"

    # Ensure we have an input file and that it has a valid extension
    inFile=$(ensure_input_file "${inFile}")

    print_debug "inFile='${inFile}'"

    print_message "Reading from ${inFile} and cleaning repos..."
    print_separator

    # GNU Make is not used or there is no Makefile in the root of the
    # Workspace.

    # Now read line by line from the input file and build the repos!
    #
    # The -r flag causes read command to not treat backslash character as
    # an escape character
    #
    # Any leading whitespace is automatically stripped by read command
    while read -r line; do
        if [[ -z "${line}" ]]; then
            # Skip to next entry since it is an empty line
            continue
        fi

        if [[ "${line}" == "#"* ]]; then
            # Parse line and assign to global variable if comment contains
            # a known key-value pair
            _frija_parse_repos_file_comment_line "${line}"
            continue
        else
            ensure_all_metafields_set

            # Parse line and assign fields to global variables
            _frija_parse_repos_file_line "${line}"
        fi

        print_message "_FENSALIR_CURRENT_OS='${_FENSALIR_CURRENT_OS}"
        print_message "os='${os}'"
        if [[ "${os}" != "${_FENSALIR_OS_ID}" ]]; then
            print_message "Skipping '${os}'"
            skippedOperatingSystems+=("${os}")
            # Skip to next entry since target OS does not match current OS
            continue
        fi

        if [[ "${tool}" == "none" ]]; then
            # Skip repos that does not have any build tool
            continue
        fi

        if [[ "${dependencies}" == "none" ]]; then
            # When there are no dependencies, set it to an empty string.
            dependencies=""
        fi

        if [[ "${toolDependencies}" == "none" ]]; then
            # When there are no tool dependencies, set it to an empty string.
            toolDependencies=""
        fi

        # If we reach this point then there is at least one row that
        # matches current operating system. Save this fact in this
        # variable so an error message can adapt to this situation
        #
        # shellcheck disable=SC2034
        foundOperatingSystem="${os}"

        # shellcheck disable=SC2154
        case "${vcs}" in
            git)
                if [[ "${uri}" =~ ${GIT_REPO_PATTERN} ]]; then
                    repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                    destination=$(make_destination "${composite}" \
                                                   "${repoName}" \
                                                   "${version}")
                else
                    message="Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is "
                    message+="'${uri}' and pattern is '${GIT_REPO_PATTERN}', "
                    message+="aborting."
                    print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
                fi
                ;;
            *)
                message="Unsupported VCS: '${vcs}' for '${uri}' found in input "
                message+="file '${inFile}', aborting."
                print_error "${message}" $_FRIJA_EXIT_INPUT_FILE_FORMAT_PROBLEMS
                ;;
        esac

        print_debug "repoName='${repoName}', destination='${destination}'"


        if [[ -n "${REPO_SUBPATH}" ]] && [[ "${allRepos}" == "n" ]]; then
            # REPO_SUBPATH is set, this means that A) we are somewhere
            # below _FRIJA_WS_PATH and B) we are within a repo.
            #
            # NOTE: If inside a repo and 'all' option is set, then it
            # will override this behavior and force all repos to be
            # operated on regardless.
            print_debug "REPO_SUBPATH='${REPO_SUBPATH}'"
            if [[ "${REPO_SUBPATH}" != "${destination}"* ]]; then
                print_debug "destination='${destination}'"
                # In this case we should ONLY operate on repos where
                # REPO_SUBPATH and destination matches, which means that
                # for all other repos we should just skip it and move on
                # to the next one.
                continue;
            fi
        fi


        if [[ "${scorch}" == "n" ]]; then
            # Always show $buildType in uppercase
            message="${BOLD}Cleaning ${buildType,,}${CLEAR} build artifacts for "
            message+="${BOLD}${destination}${CLEAR}..."
            print_message "${message}"

            print_debug "clean ('${tool}' '${buildType}' " \
                        "'${destination}' '${externalDeps}')"

            clean_dispatch "${tool}" \
                           "${destination}" \
                           "${repoName}" \
                           "${externalDeps}"
            operation="cleaned"
        else
            message="${BOLD}Scorching${CLEAR} all build artifacts in "
            message+="${BOLD}${destination}${CLEAR}..."
            print_message "${message}"

            print_debug "clean ('${tool}' '${buildType}' " \
                        "'${destination}' '${externalDeps}')"

            scorch_dispatch "${tool}" \
                            "${destination}" \
                            "${repoName}" \
                            "${externalDeps}"
            operation="scorched"
        fi

        # If we reach this point, at least one repo has been processed
        processedReposFlag="y"
    done < "${inFile}"

    if [[ -z "${processedReposFlag}" ]]; then
        if [[ "${allRepos}" == "n" ]]; then
            print_no_repo_match_error "${REPO_SUBPATH}" \
                                      "${inFile}" \
                                      "No repos were ${operation}!"
        else
            print_os_error "skippedOperatingSystems" \
                           "${inFile}" \
                           "No repos were ${operation}!"
        fi
    fi
fi

if [[ -n "${finalMessage}" ]]; then
    print_message
    print_double_separator
    print_message "${finalMessage}"
    print_double_separator
    print_message
fi
