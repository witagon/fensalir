#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "aSB::P::A::i:vhdDF:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "all,scorch,build::,prepare::,archive::,input:,verbose,help,debug,dry-run,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
  Clean Build, Prepare, and Archive folders across repos.
EOF
}


_FRIJA_CLEAN_RELEASE="RELEASE"
_FRIJA_CLEAN_DEBUG="DEBUG"
_FRIJA_CLEAN_BOTH="BOTH"
_FRIJA_DEFAULT_CLEAN_TYPE="${_FRIJA_CLEAN_BOTH}"


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -B|--build)
            result="${_FRIJA_CLEAN_RELEASE} "
            result+="${_FRIJA_CLEAN_DEBUG} "
            result+="${_FRIJA_CLEAN_BOTH}"
            ;;
        -P|--prepare)
            result="${_FRIJA_CLEAN_RELEASE} "
            result+="${_FRIJA_CLEAN_DEBUG} "
            result+="${_FRIJA_CLEAN_BOTH}"
            ;;
        -A|--archive)
            result="${_FRIJA_CLEAN_RELEASE} "
            result+="${_FRIJA_CLEAN_DEBUG} "
            result+="${_FRIJA_CLEAN_BOTH}"
            ;;
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            if [[ -z "${result}" ]]; then
                local message="Current Frija Workspace is corrupt; "
                message+="no ${REPO_LIST_EXTENSION} file found"
                _frija_completion_help_message "${message}"
            fi
            ;;
        -F|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    local pager=""
    pager=$(_frija_pager)

    ${pager} <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  ${BOLD}Default behavior is to clean both Debug and Release builds in all of Build,
  Archive, and Prepare folders; this can be overridden using the command line
  described below.${CLEAR}

  When cleaning there are three levels controlling how deep the cleansing is

  -S/--scorch     The deepest cleansing that removes all traces of files created
                    by all four stages (GENERATE, BUILD, PREPARE, and ARCHIVE)
                    for both Debug and Release
  -B/--build      Cleanse files creatred by the BUILD, PREPARE, and ARCHIVE
                    stages; this is the default when no option is given
  -P/--prepare    Cleanse files creatred by the PREPARE, and ARCHIVE stages

  -A/--archive    Cleanse files creatred by the ARCHIVE stage

  On top of this these the build, prepare, and archive options take an optional
  argument controlling which of Release and Build (or both of them) gets
  cleansed. Default behavior is to cleans both of them.

${BOLD}
  Behavior of this command varies slightly depending on where you are
  within generic folder structure shown below${CLEAR}

    frija
      |
      +-- WORKSPACE
                |
                +-- COMPOSITE-NAME
                               |
                               +-- REPO

  The basic rule of thumb is that when you are within a REPO then this
  command is ONLY applied to that repo, otherwise it is applied to
  all applicable repos listed in the input file.

  This default rule-of-thumb-behavior can be overridden when you are
  within REPO (or sub-folder to REPO); you give the -a/--all option on
  the command line.

  The -a/--all option is an escape mechanism that allow you to apply
  the command to all repos listed in the input file regardless of
  where you are within the WORKSPACE directory tree.


  ${UNDERLINE_ON}Background${UNDERLINE_OFF}

  The complete build process consist of the stages
  ${BOLD}GENERATE${CLEAR}   Create non-version controlled files needed to build, for instance
               inter-repo dependency files, make files (generated by CMake),
               and so on

  ${BOLD}BUILD${CLEAR}      Actual compilation stage; which may also generate
             non-version controlled files like files generated
             from Google proto-files

  ${BOLD}PREPARE${CLEAR}    Copy files from Build folder to Prepare folder in a structure that
               is similar to how it should be installed on the target system

  ${BOLD}ARCHIVE${CLEAR}    Create installation archive based on content in Prepare folder and
                            place it within the Archive folder

  In addition to the above stages, there is also
  ${BOLD}CLEAN${CLEAR}      Clean build artifacts so a rebuild will trigger re-creation of all
               binaries, including any re-generation and compilation of any
               Google proto-files and so on; i.e. files produced by the build
               stage. Optionally files produced by the generate and prepare
               stages can also be cleaned.

${BOLD}Options:${CLEAR}
  -S,                 cleanse ${BOLD}everything${CLEAR} (applies to ${BOLD}both${CLEAR} types);
   --scorch             generated build input files specific to Frija are also
                        removed in addition to what is removed in the BUILD
                        clean action. This also means it is invalid to combine
                        scorching with any of the clean actions.

  -B[TYPE],           clean Build, Archive, and Prepare folders
   --build[=TYPE]        ${BOLD}Note:${CLEAR} Both Debug and Release cleansed by default

  -A[TYPE],           clean Archive and Prepare folders
   --archive[=TYPE]      ${BOLD}Note:${CLEAR} Both Debug and Release cleansed by default

  -P[TYPE],           clean only Prepare folder
   --prepare[=TYPE]      ${BOLD}Note:${CLEAR} Both Debug and Release cleansed by default

  -a,                 apply command to all applicable repos listed in input
   --all                file; default or given on the command line via
                        -i/--input option. This option is applied by default
                        when outside of a repo (but still within a workspace).

  -iFILE,             apply selected clean operation to repos listed in FILE
   --input=FILE
  -v,                 verbose output
   --verbose
  -h,                 print this message
   --help
  -d,                 enable debug printouts sent to stderr
   --debug
  -D,                 do not execute commands with side effects, just echo them
   --dry-run
  -FOS,               force command to assume given OS instead of detected OS
   --force=OS

${BOLD}See also:${CLEAR}
  (frija) ${BOLD}archive${CLEAR}, ${BOLD}build${CLEAR}, ${BOLD}generate${CLEAR}, ${BOLD}prepare${CLEAR} commands for further information

EOF
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${REPO_TOOLS_HOME}/.preamble.bash"

# Include generic VCS support.
#
# shellcheck source=./.vcs_functions.bash
source "${REPO_TOOLS_HOME}/.vcs_functions.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...

ALL_DIRS="All"
SYS_NAME=""

DRY_RUN="n"
VERBOSE="n"
DEBUG="n"
allRepos="n"
buildType=""
scorch="n"
cleanVariant=""
inFile=""
osOverride=""

finalMessage=""


# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -S|--scorch)
            ensure_boolean_option_not_set "Clean variant" "${cleanVariant}"
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            scorch="y"
            cleanVariant="${ALL_DIRS}"
            buildType="${_FRIJA_CLEAN_BOTH}"
            shift  # Move to next option
            ;;
        -B|--build)
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            ensure_boolean_option_not_set "Clean variant" "${cleanVariant}"
            cleanVariant="${BUILD_DIR}"
            ensure_option_not_set "Build type" "${buildType}"
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_CLEAN_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_CLEAN_DEBUG}" \
                                 "${_FRIJA_CLEAN_RELEASE}" \
                                 "${_FRIJA_CLEAN_BOTH}"
            shift  # Move to next option
            ;;
        -P|--prepare)
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            ensure_boolean_option_not_set "Clean variant" "${cleanVariant}"
            cleanVariant="${PREPARE_DIR}"
            ensure_option_not_set "Build type" "${buildType}"
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_CLEAN_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_CLEAN_DEBUG}" \
                                 "${_FRIJA_CLEAN_RELEASE}" \
                                 "${_FRIJA_CLEAN_BOTH}"
            shift  # Move to next option
            ;;
        -A|--archive)
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            ensure_boolean_option_not_set "Clean variant" "${cleanVariant}"
            cleanVariant="${ARCHIVE_DIR}"
            ensure_option_not_set "Build type" "${buildType}"
            shift  # Move to option argument
            buildType="${1:-${_FRIJA_DEFAULT_CLEAN_TYPE}}"
            ensure_value_in_enum "${buildType}" \
                                 "${_FRIJA_EXIT_CMD_LINE_PROBLEMS}" \
                                 "${_FRIJA_CLEAN_DEBUG}" \
                                 "${_FRIJA_CLEAN_RELEASE}" \
                                 "${_FRIJA_CLEAN_BOTH}"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit $_FRIJA_EXIT_OK
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        -F|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit $_FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac
done

if [[ -z "${buildType}" ]]; then
    message="You must specify one of -S/--scorch, -B/--build, -P/--prepare, "
    message+="or -A/--archive, aborting."
    print_error $_FRIJA_EXIT_CMD_LINE_PROBLEMS
fi

declare -a buildTypeList=()
case "${buildType}" in
    "${_FRIJA_CLEAN_DEBUG}")
        buildTypeList=("${DEBUG_DIR}")
        ;;
    "${_FRIJA_CLEAN_RELEASE}")
        buildTypeList=("${RELEASE_DIR}")
        ;;
    "${_FRIJA_CLEAN_BOTH}")
        buildTypeList=("${RELEASE_DIR}" "${DEBUG_DIR}")
        ;;
esac


################################################################################
# Consistency checks
################################################################################

# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    OPERATING_SYSTEM="${osOverride}"
fi


# Ensure we have an input file and that it has a valid extension
inFile=$(ensure_input_file "${inFile}")

# In case user has provided an input file with an explicit search path
# we must remove it in order to obtain the system name from the input
# filename. And also remove $REPO_LIST_EXTENSION from it.
SYS_NAME="${inFile##*/}"
SYS_NAME="${SYS_NAME%%${REPO_LIST_EXTENSION}}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    message="Unrecognized arguments; ${*}, aborting."
    print_error "${message}" $_FRIJA_EXIT_ARGUMENT_ERROR
fi


print_debug "verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}"


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_HOME or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
#
# Note: See .preamble.bash for more information about
# cwd_in_workspace_repo_folder_p()
_frija_locate_frija_home
REPO_SUBPATH=$(cwd_in_workspace_repo_folder_p "")
cd "${_FRIJA_HOME}"



################################################################################
# Common functions
#

# Create a natural language sequence from a entries in an array. That
# is, if the array is (a b c) then the output from this function could
# the string "a, b, and c". On the other hand, if the array is (a b)
# then the output could be "a and b".
#
# First parameter is the conjunction to use, that is "and" or "or"
#
# Second parameter is the name of the array to create the sequence for.
#
# Third parameter If provided and set to $BOLD, then each item in the
#                 list is bolded. (Optional)
function create_sentence_sequence()
{
    local conjunction="${1}"
    local arrayname="${2}"
    local bold="${3:-}"

    local prefix=""
    local suffix=""
    if [[ "${bold}" == "${BOLD}" ]]; then
        prefix="${BOLD}"
        suffix="${CLEAR}"
    fi

    # Create an array reference
    local arrayRef="${arrayname}[@]"
    # Expand the array reference to the content of the array and
    # assign it to a new array. If Bash 4.3 or newer can be used then
    # replace with named references instead to get simpler code.
    declare -a items=("${!arrayRef}")
    local itemSequence=""
    declare -i length=${#items[@]}
    if (( length > 2 )); then
        for entry in "${items[@]::length-1}"; do
            itemSequence+="${prefix}${entry}${suffix}, "
        done
        itemSequence+="and ${prefix}${items[length-1]}${suffix}"
    elif (( length > 1 )); then
        itemSequence="${prefix}${items[0]}${suffix} ${conjunction} "
        itemSequence+="${prefix}${items[1]}${suffix}"
    else
        itemSequence="${prefix}${items[0]}${suffix}"
    fi

    echo "${itemSequence}"
}

################################################################################
# Below are build system specific functions used for generating input
# file(s) injecting dependency information etc.
################################################################################


################################################################################
# CMAKE
#

function cmake_clean_build_folder()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"

    local buildFolder="${repoFolder}/${BUILD_DIR}"
    declare -a command

    # Make CMake clean up any files it is aware of first, for instance
    # files placed in the $GENERATED folder
    command=("${SINGLE}" "${repoFolder} (CMake --clean)" \
                         cmake --clean "${BUILD_DIR}/${buildType}")

    # Now do a deep cleansing of the $BUILD_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${buildFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${BUILD_DIR}/${type}${CLEAR})"

            command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    # Cascade to Prepare folder
    cmake_clean_prepare_folder "${repoFolder}"

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="Please re-run ${BOLD}frija generate${CLEAR} to recreate "
    finalMessage+="CMake build structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD}) "
    finalMessage+="before you can call ${BOLD}frija build${CLEAR} again for "
    finalMessage+="it/them."

    print_debug_exit
}


function cmake_clean_prepare_folder()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"

    local prepareFolder="${repoFolder}/${PREPARE_DIR}"

    # Now do a deep cleansing of the $PREPARE_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${prepareFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${PREPARE_DIR}/${type}${CLEAR})"

            declare -a command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    # Cascade to Archive folder
    cmake_clean_archive_folder "${repoFolder}"

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="Please re-run ${BOLD}frija generate${CLEAR} to recreate "
    finalMessage+="CMake build structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD}) "
    finalMessage+="before you can call ${BOLD}frija build${CLEAR} followed "
    finalMessage+="by ${BOLD}frija prepare${CLEAR} again for it/them."

    print_debug_exit
}


function cmake_clean_archive_folder()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"

    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"

    # Now do a deep cleansing of the $ARCHIVE_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${archiveFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${ARCHIVE_DIR}/${type}${CLEAR})"

            declare -a command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="Please re-run ${BOLD}frija generate${CLEAR} to recreate "
    finalMessage+="CMake build structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD}) "
    finalMessage+="before you can call ${BOLD}frija build${CLEAR} followed "
    finalMessage+="by ${BOLD}frija prepare${CLEAR}, and finally "
    finalMessage+="${BOLD}frija archive${CLEAR}again for it/them."

    print_debug_exit
}

function cmake_clean()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"  # E.g. csproj or sln
    local repoName="${3}"

    case "${cleanVariant}" in
        "${BUILD_DIR}")
            cmake_clean_build_folder "${repoFolder}"
            ;;
        "${PREPARE_DIR}")
            cmake_clean_prepare_folder "${repoFolder}"
            ;;
        "${ARCHIVE_DIR}")
            cmake_clean_archive_folder "${repoFolder}"
            ;;
        "${ALL_DIRS}")
            cmake_clean_archive_folder "${repoFolder}"
            cmake_clean_prepare_folder "${repoFolder}"
            cmake_clean_build_folder "${repoFolder}"
            ;;
        *)
            message="Unknown cleanVariant '${cleanVariant}', aborting."
            frija_print_error "${message}" _FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac

    print_debug_exit
}


function cmake_scorch()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"  # E.g. csproj or sln
    local repoName="${3}"

    # First do a normal clean...
    cmake_clean "${repoFolder}" "${parameters}" "${repoName}"

    # ...and then do the scorch cleaning
    local dependencyFile="${repoName}${CMAKE_DEPENDENCY_FILE_SUFFIX}"
    declare -a command
    command=("${SINGLE}" "Removing ${dependencyFile}..." \
                        rm -f "${repoFolder}/${dependencyFile}")
    run "${command[@]}"

    local generatedFolder="${BUILD_DIR}/${GENERATED}"
    declare -a command
    command=("${SINGLE}" "Removing ${generatedFolder}..." \
                        rm -fr "${repoFolder}/${generatedFolder}")
    run "${command[@]}"

    finalMessage="Existing Frija Dependency files has been "
    finalMessage+="${BOLD}removed${CLEAR}.\\n\\n"
    finalMessage+="Please start over from ${BOLD}frija generate${CLEAR} "
    finalMessage+="to recreate CMake build structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD}) "
    finalMessage+="before you can call ${BOLD}frija build${CLEAR} "
    finalMessage+="and so on for it/them."

    print_debug_exit
}

#
# CMAKE
################################################################################



################################################################################
# MSBUILD
#

MSBUILD_PROPERTY_FILE="Directory.Build.props"

function msbuild_clean_build_folder()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local fileType="${2}"

    local buildFolder="${repoFolder}/${BUILD_DIR}"

    local composite=""
    local name=""
    local version=""
    local sha=""
    local rest=""
    IFS='/' read -r composite name version sha rest <<< "${repoFolder/__//}"

    # Now do a deep cleansing of the $BUILD_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${buildFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${BUILD_DIR}/${type}${CLEAR})"

            command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    # Make Msbuild clean up any files it is aware of after we have removed
    # the build folder or folders
    declare -a command
    for type in "${buildTypeList[@]}"; do
        local inputFile="${name}.${fileType}"
        command=("${LAST}" "MSBuild Clean target..." \
                           MSBuild.exe \
                           "-p:Configuration=${type}" \
                           "-target:Clean" \
                           "${repoFolder}/${inputFile}")
        run "${command[@]}"
    done

    # Cascade to Prepare folder
    msbuild_clean_prepare_folder "${repoFolder}"

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="You can now  call ${BOLD}frija build${CLEAR} again for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD})."

    print_debug_exit
}


function msbuild_clean_prepare_folder()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"

    local prepareFolder="${repoFolder}/${PREPARE_DIR}"

    # Now do a deep cleansing of the $PREPARE_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${prepareFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${PREPARE_DIR}/${type}${CLEAR})"

            declare -a command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    # Cascade to Archive folder
    msbuild_clean_archive_folder "${repoFolder}"

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="You can now call ${BOLD}frija build${CLEAR} followed "
    finalMessage+="by ${BOLD}frija prepare${CLEAR} for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD})."

    print_debug_exit
}


function msbuild_clean_archive_folder()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"

    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"

    # Now do a deep cleansing of the $ARCHIVE_DIR/$buildType folder(s)
    local type=""
    for type in "${buildTypeList[@]}"; do
        local folder="${archiveFolder}/${type}"

        if [[ -d "${folder}" ]]; then
            local message="${repoFolder} "
            message+="(removing ${BOLD}${ARCHIVE_DIR}/${type}${CLEAR})"

            declare -a command=("${SINGLE}" "${message}" rm -fr "${folder}")
            run "${command[@]}"
        fi
    done

    finalMessage="Existing Frija Dependency files has been preserved.\\n\\n"
    finalMessage+="You can now call ${BOLD}frija build${CLEAR} followed "
    finalMessage+="by ${BOLD}frija prepare${CLEAR}, and finally "
    finalMessage+="${BOLD}frija archive${CLEAR}again for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD})."

    print_debug_exit
}

function msbuild_clean()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"  # E.g. msbuild;csproj or msbuild;sln
    local repoName="${3}"

    local fileType="${parameters##*;}"  # "msbuild;csproj" ==> "csproj"

    case "${cleanVariant}" in
        "${BUILD_DIR}")
            msbuild_clean_build_folder "${repoFolder}" "${fileType}"
            ;;
        "${PREPARE_DIR}")
            msbuild_clean_prepare_folder "${repoFolder}"
            ;;
        "${ARCHIVE_DIR}")
            msbuild_clean_archive_folder "${repoFolder}"
            ;;
        "${ALL_DIRS}")
            msbuild_clean_archive_folder "${repoFolder}"
            msbuild_clean_prepare_folder "${repoFolder}"
            msbuild_clean_build_folder "${repoFolder}" "${fileType}"
            ;;
        *)
            message="Unknown cleanVariant '${cleanVariant}', aborting."
            frija_print_error "${message}" _FRIJA_EXIT_INTERNAL_ERROR
            ;;
    esac

    print_debug_exit
}


function msbuild_scorch()
{
    print_debug_enter "${@}"

    local repoFolder="${1}"
    local parameters="${2}"  # E.g. csproj or sln
    local repoName="${3}"

    # First do a normal clean...
    msbuild_clean "${repoFolder}" "${parameters}" "${repoName}"

    # ...and then do the scorch cleaning
    local objFolder="${repoFolder}/${BUILD_DIR}/obj"
    local propertyFile="${repoFolder}/${MSBUILD_PROPERTY_FILE}"
    local nugetFolder="${repoFolder}/Packages"

    command=("${FIRST}" "Removing ${objFolder}..." rm -fr "${objFolder}")
    run "${command[@]}"

    command=("${MIDDLE}" "Removing ${nugetFolder}..." rm -fr "${nugetFolder}")
    run "${command[@]}"

    command=("${LAST}" "Removing ${propertyFile}" rm -f "${propertyFile}")
    run "${command[@]}"

    local generatedFolder="${BUILD_DIR}/${GENERATED}"
    declare -a command
    command=("${SINGLE}" "Removing ${generatedFolder}..." \
                        rm -fr "${repoFolder}/${generatedFolder}")
    run "${command[@]}"

    finalMessage="Existing Frija Dependency files has been "
    finalMessage+="${BOLD}removed${CLEAR}.\\n\\n"
    finalMessage+="Please start over from ${BOLD}frija generate${CLEAR} "
    finalMessage+="to recreate Frija folder structure for "
    # shellcheck disable=SC2086
    finalMessage+="$(create_sentence_sequence and buildTypeList ${BOLD}) "
    finalMessage+="before you can call ${BOLD}frija build${CLEAR} "
    finalMessage+="and so on for it/them."

    print_debug_exit
}


