#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")

# Remove shortest suffix matching "/*", i.e. last part of path
_FRIJA_PROGRAM_DIR="${_FRIJA_PROGRAM_PATH%/*}"


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "t:asi:vhdDf:"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "type:,all,scorch,input:,verbose,help,debug,dry-run,force-os:"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Clean generated files in repos listed in given repo-list file.
EOF
}


_FRIJA_BUILD_RELEASE="Release"
_FRIJA_BUILD_DEBUG="Debug"
BUILD_TYPE="${_FRIJA_BUILD_RELEASE}"


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -t|--type)
            result="${_FRIJA_BUILD_RELEASE} ${_FRIJA_BUILD_DEBUG}"
            ;;
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            ;;
        -f|--force-os)
            result="${LINUX_OS} ${WINDOWS_OS}"
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    cat <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  The complete build process consist of the stages
  ${BOLD}generate${CLEAR}   Create non-version controlled files needed to build, for instance
               inter-repo dependency files, make files (generated by CMake),
               and so on
  ${BOLD}build${CLEAR}      Actual compilation stage
  ${BOLD}prepare${CLEAR}    Copy files from Build folder to Archive folder in a structure that
               is similar to how it should be installed on the target system
  ${BOLD}archive${CLEAR}    Create installation archive and place it within the Archive folder

  In addition to the above stages, there is also
  ${BOLD}clean${CLEAR}      Clean build artifacts so a rebuild will trigger re-creation of all
               binaries, including any re-generation and compilation of any
               Google proto-files and so on; i.e. files produced by the build
               stage. Optionally files produced by the generate and prepare
               stages can also be cleaned.

  This command is thus primarily used for cleaning files generated by the
  build stage, but can also be used for cleaning files produced by the
  generate and prepare stages as well.

  ${BOLD}Note:${CLEAR} The behavior of the command varies slightly depending on where
        you are in the filesystem. If you are within a repo, then by
        default the operation is applied only to that repo (this can
        be overridden, see below). On the other hand, if you are in
        the frija root folder (for instance the Jira ticket folder)
        then the operation is applied to all repos referenced from the
        input file that are for the current OS.

${BOLD}Options:${CLEAR}
  -t[TYPE], --type[=TYPE]   generate files for either release (default) or
                              debug. This only have effect for some build
                              systems, for instance CMake where the generated
                              files for the targeted build system explicitly
                              depend on if you build for debug or release.
  -a, --all                 ${BOLD}when${CLEAR} inside a repo ${BOLD}and${CLEAR} this option is set it will
                              force command to operate on all repos applicable
                              to current OS, ${BOLD}otherwise${CLEAR} it has ${BOLD}no effect${CLEAR}
  -s, --scorch                  clean everything; ${_FRIJA_BUILD_RELEASE} and ${_FRIJA_BUILD_DEBUG} builds,
                                  prepared installation files (both ${_FRIJA_BUILD_RELEASE}
                                  and ${_FRIJA_BUILD_DEBUG}), any generated buildscript as well
                                  as any remaining intermediate files
  -iFILE, --input=FILE      build repos listed in FILE
  -v, --verbose             verbose output
  -h, --help                print this message
  -d, --debug               enable debug printouts
                              ${BOLD}NOTE:${CLEAR} Debug messages are prefixed with
                                    "*** LINE  " where LINE is current line
                                    number and written to stderr.
  -D, --dry-run             just echo command lines instead of executing them
  -fOS, --force=OS          force command to assume given OS instead of
                              detected OS
EOF
    # Print common input file format documentation, see .preamble
    print_file_format_doc

    # Print common exit codes documentation, see .preamble
    print_exit_codes_doc
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${METADATATOOLS_HOME}/.preamble.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...

BUILD_DIR="Build"
ARCHIVE_DIR="Archive"
SYS_NAME=""

DRY_RUN="n"
VERBOSE="n"
DEBUG="n"
autoInFile=$(auto_locate_repo_file)
allRepos="n"
scorch="n"
inFile=""
osOverride=""


# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -t|--type)
            shift  # Move to option argument

            # Check for optional argument
            if [[ -n "${1}" ]]; then
                BUILD_TYPE="${1}"
            fi

            shift  # Move to next option
        ;;
        -a|--all)
            ensure_boolean_option_not_set "All repos" "${allRepos}"
            allRepos="y"
            shift  # Move to next option
            ;;
        -s|--scorch)
            ensure_boolean_option_not_set "Scorch" "${scorch}"
            scorch="y"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit 0
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        -f|--force-os)
            ensure_option_not_set "OS override" "${osOverride}"
            shift  # Move to next option
            osOverride="${1}"
            ensure_option_argument_set "OS override" "${osOverride}"
            shift  # Move to next option
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done


# Ensure build type contain a legal value
case "${BUILD_TYPE}" in
    ${_FRIJA_BUILD_RELEASE}|${_FRIJA_BUILD_DEBUG})
        ;;
    *)
        # Illegal value given for the optional TYPE
        msg="TYPE ('${BUILD_TYPE}') may only be one of '${_FRIJA_BUILD_RELEASE}' or '${_FRIJA_BUILD_DEBUG}'."
        print_error "${msg}" 2
        ;;
esac


# Allow user to explicitly override detected OS
if [[ -n "${osOverride}" ]]; then
    OPERATING_SYSTEM="${osOverride}"
fi

# Allow explicit command line to specify inFile and override the
# automatically found inFile. This case is only valid when there is a
# single repo-list file.
inFile="${inFile:-${autoInFile}}"
if [[ -z "${inFile}" ]]; then
    print_error "No input file specified." 2
fi

# Append extension AFTER above check; otherwise we would
# not be able to detect if $inFile is empty
inFile="${inFile}${REPO_LIST_EXTENSION}"

SYS_NAME="${inFile##*/}"
SYS_NAME="${SYS_NAME%%${REPO_LIST_EXTENSION}}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    print_error "Command does not support any arguments." 4
fi


print_debug "verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}"


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
#
# Note that a check is also made whether current working directory is
# inside a repo located below _FRIJA_HOME or not. If that is the case
# then REPO_SUBPATH contain a non-empty string.
_frija_locate_frija_home
REPO_SUBPATH=$(cwd_in_frija_repo_folder_p)
cd "${_FRIJA_HOME}"


####################
# Note: See .preamble.bash for more information about the run function!
####################


################################################################################
# CMAKE
#

function cmake_clean()
{
    local repoFolder="${1}"
    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}/${BUILD_TYPE}"
    local command

    command=("${FIRST}" "${repoFolder}" rm -fr "${buildFolder}")
    run "${command[@]}"
    command=("${LAST}" "${repoFolder}" rm -fr "${archiveFolder}")
    run "${command[@]}"
}


function cmake_scorch()
{
    local repoFolder="${1}"
    local buildFolder="${repoFolder}/${BUILD_DIR}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"
    local command

    command=("${FIRST}" "${repoFolder}" rm -fr "${buildFolder}")
    run "${command[@]}"
    command=("${LAST}" "${repoFolder}" rm -fr "${archiveFolder}")
    run "${command[@]}"
}

#
# CMAKE
################################################################################



################################################################################
# MSBUILD
#

MSBUILD_PROPERTY_FILE="Directory.Build.props"

function msbuild_clean()
{
    local repoFolder="${1}"
    local parameters="${2}"  # E.g. csproj or sln

    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}/${BUILD_TYPE}"
    local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"

    # Extract mg, repo name, and version from given path
    IFS='/' read -r mg name version<<<"${repoFolder}"
    local inputFile="${name}.${type}"

    local command
    command=("${FIRST}" "Removing ${buildFolder}..." rm -fr "${buildFolder}")
    run "${command[@]}"

    if [[ -e "${archiveFolder}" ]]; then
        command=("${MIDDLE}" "Removing ${archiveFolder}..." \
                             rm -fr "${archiveFolder}")
        run "${command[@]}"
    fi

    command=("${LAST}" "MSBuild Clean target..." \
                         MSBuild.exe \
                         "-p:Configuration=${BUILD_TYPE}" \
                         "-target:Clean" \
                         "${repoFolder}/${inputFile}")
    run "${command[@]}"
}


function msbuild_scorch()
{
    local repoFolder="${1}"
    local parameters="${2}"  # E.g. csproj or sln

    local objFolder="${repoFolder}/${BUILD_DIR}/obj"
    local propertyFile="${repoFolder}/${MSBUILD_PROPERTY_FILE}"
    local nugetFolder="${repoFolder}/Packages"
    local command

    # Start with a normal clean operation
    msbuild_clean "${repoFolder}" "${parameters}"

    command=("${FIRST}" "Removing ${objFolder}..." rm -fr "${objFolder}")
    run "${command[@]}"

    command=("${MIDDLE}" "Removing ${nugetFolder}..." rm -fr "${nugetFolder}")
    run "${command[@]}"

    command=("${LAST}" "Removing ${propertyFile}" rm -f "${propertyFile}")
    run "${command[@]}"
}

#
# MSBUILD
################################################################################


function clean_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_clean "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_clean "${destination}" "${parameters}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


function scorch_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_scorch "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_scorch "${destination}" "${parameters}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


########
# Iterate over the lines in the input file and act on each line
# depending on SOURCE field.

print_message "Reading from ${inFile} and cleaning repos..."
print_separator

processedReposFlag=""
operation="undefined"
declare -a skippedOperatingSystems=()
declare -A uniqueSkippedOperatingSystems=()

# -r make read to not treat backslash character as an escape character
while read -r os source mg version uri repoKind tool dependencies toolDependencies rest; do
    # Strip any carriage returns from the read values
    os=${os//$'\r'}
    source=${source//$'\r'}
    mg=${mg//$'\r'}
    version=${version//$'\r'}
    uri=${uri//$'\r'}
    repoKind=${repoKind//$'\r'}
    tool=${tool//$'\r'}
    dependencies=${dependencies//$'\r'}
    toolDependencies=${toolDependencies//$'\r'}
    rest=${rest//$'\r'}

    print_debug "os='${os}', " \
                "source='${source}', " \
                "version='${version}', " \
                "uri='${uri}', " \
                "repotype='${repoKind}', " \
                "tool='${tool}', " \
                "dependencies='${dependencies}', " \
                "rest='${rest}'"

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    if [[ "${tool}" == "none" ]]; then
        # Skip repos that does not have any build tool
        continue
    fi

    if [[ "${dependencies}" == "none" ]]; then
        # When there are no dependencies, set it to an empty string.
        dependencies=""
    fi

    if [[ "${toolDependencies}" == "none" ]]; then
        # When there are no tool dependencies, set it to an empty string.
        toolDependencies=""
    fi


    case "${source}" in
        git)
            if [[ "${uri}" =~ ${GIT_REPO_PATTERN} ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination=$(make_destination "${mg}" "${repoName}" "${version}")
            else
                print_error "Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is '${uri}' and pattern is '${GIT_REPO_PATTERN}', aborting." 6
            fi
            ;;
        *)
            print_error "Unsupported SOURCE: '${source}' for '${uri}', aborting." 6
            ;;
    esac

    print_debug "repoName='${repoName}', destination='${destination}'"


    if [[ -n "${REPO_SUBPATH}" ]] && [[ "${allRepos}" == "n" ]]; then
        # REPO_SUBPATH is set, this means that A) we are somewhere
        # below _FRIJA_HOME and B) we are within a repo.
        #
        # NOTE: If inside a repo and 'all' option is set, then it
        # will override this behavior and force all repos to be
        # operated on regardless.
        print_debug "REPO_SUBPATH='${REPO_SUBPATH}'"
        if [[ "${REPO_SUBPATH}" != "${destination}"* ]]; then
            print_debug "destination='${destination}'"
            # In this case we should ONLY operate on repos where
            # REPO_SUBPATH and destination matches, which means that
            # for all other repos we should just skip it and move on
            # to the next one.
            continue;
        fi
    fi


    if [[ "${scorch}" == "n" ]]; then
        print_message "${BOLD}Cleaning${CLEAR} build artifacts in ${BOLD}${BUILD_TYPE,,}${CLEAR} in ${BOLD}${destination}${CLEAR}..."
        print_debug "clean ('${tool}' '${BUILD_TYPE}' '${destination}')"
        clean_dispatch "${tool}" "${destination}"
        operation="cleaned"
    else
        print_message "${BOLD}Scorching${CLEAR} all build artifacts in ${BOLD}${destination}${CLEAR}..."
        print_debug "clean ('${tool}' '${BUILD_TYPE}' '${destination}')"
        scorch_dispatch "${tool}" "${destination}"
        operation="scorched"
    fi

    # If we reach this point, at least one repo has been processed
    processedReposFlag="y"
done < "${inFile}"


if [[ -z "${processedReposFlag}" ]]; then
    # Make $skippedOperatingSystems unique by using an associative
    # array (hashmap)
    for i in "${skippedOperatingSystems[@]}"; do
        uniqueSkippedOperatingSystems["${i}"]=1
    done
    print_message ""
    print_message "====================="
    print_message "${BOLD}No repos were ${operation}!${CLEAR}"
    print_message "====================="
    print_message ""
    print_message "Current OS is ${BOLD}${OPERATING_SYSTEM}${CLEAR} and all entries in"
    print_message "  ${BOLD}${inFile}${CLEAR}"
    print_message "required the following operating system$(plural ${#skippedOperatingSystems[@]})${BOLD}"
    printf '  %s\n' "${!uniqueSkippedOperatingSystems[@]}"
    print_message "${CLEAR}"
    print_message "Are you sure you are using an input file designed for your OS?"
fi
