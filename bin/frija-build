#!/bin/bash
_FRIJA_PROGRAM_PATH=$(readlink -e -n "${0}")

# Remove shortest suffix matching "/*", i.e. last part of path
_FRIJA_PROGRAM_DIR="${_FRIJA_PROGRAM_PATH%/*}"


function _frija_subcommand_shortoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    echo "g::b::c:sp:a:i:vhdD"
}

function _frija_subcommand_longoptions()
{
    # - Option followed by : indicate a required argument to option
    # - Option followed by :: indicate an optional argument to option
    # - Comma (,) separates multiple long options
    echo "generate::,build::,clean:,scorch,prepare:,archive:,input:,verbose,help,debug,dry-run"
}

_FRIJA_SUBCOMMAND_OPTIONS=$(_frija_subcommand_shortoptions)
_FRIJA_SUBCOMMAND_LONGOPTS=$(_frija_subcommand_longoptions)


function synopsis()
{
    cat <<EOF
  Build repos listed in given repo-list file.
EOF
}


_FRIJA_BUILD_RELEASE="Release"
_FRIJA_BUILD_DEBUG="Debug"
BUILD_TYPE="${_FRIJA_BUILD_RELEASE}"


function _frija_subcommand_option_values()
{
    local option="${1}"
    local result=""

    case "${option}" in
        -g|--generate|-b|--build|-c|--clean|-p|--prepare|-a|--archive)
            result="${_FRIJA_BUILD_RELEASE} ${_FRIJA_BUILD_DEBUG}"
            ;;
        -i|--input)
            result=$(_frija_subcommand_repo_file_list)
            ;;
        *)
            ;;
    esac

    echo "${result}"
}


function _frija_subcommand_usage()
{
    cat <<EOF
${BOLD}Usage:${CLEAR} ${_FRIJA_USAGE_NAME} OPTION...
$(synopsis)

  The build process consist of the main stages generate, build, prepare,
  and archive. In addition to these stages there are clean and scroch.

  ${BOLD}generate${CLEAR}   Create non-version controlled files needed to build, for instance
               inter-repo dependency files, make files (for instance from
               CMake), and so on.
  ${BOLD}build${CLEAR}      Actual compilation stage
  ${BOLD}prepare${CLEAR}    Copy files from Build folder to Archive folder in a structure that
               is similar to how it should be installed on the target system
  ${BOLD}archive${CLEAR}    Create installation archive and place it within the Archive folder

  ${BOLD}clean${CLEAR}      Clean build artifacts so a rebuild will trigger re-creation of all
               binaries, including any re-generation and compilation of
               proto-files and so on.
  ${BOLD}scorch${CLEAR}     A deep clean that also deletes files created by the generate stage

${BOLD}Options:${CLEAR}
  -g[TYPE], --generate[=TYPE]   generate buildscript, e.g. using CMake
  -b[TYPE], --build[=TYPE]      build, e.g. using GNU Make or Ninja
  -cTYPE, --clean=TYPE          clean build artifacts
  -s, --scorch                  clean everything; ${_FRIJA_BUILD_RELEASE} and ${_FRIJA_BUILD_DEBUG} builds,
                                  prepared installation files (both ${_FRIJA_BUILD_RELEASE}
                                  and ${_FRIJA_BUILD_DEBUG}), any generated buildscript as well
                                  as any remaining intermediate files
  -pTYPE, --prepare=TYPE        prepare for (installation)archive creation
                                  I.e. copies selected build artifacts to
                                  archive folder
  -aTYPE, --archive=TYPE        create (installation)archive
                                  I.e. create an (installation)archive from
                                  archive folder
  -iFILE, --input=FILE          build repos listed in FILE
  -v, --verbose                 verbose output
  -h, --help                    print this message
  -d, --debug                   enable debug printouts
                                  NOTE: Debug messages are prefixed with
                                        "*** LINE  " where LINE is current line
                                        number and written to stderr.
  -D, --dry-run                 just echo command lines instead of executing
                                  them

  TYPE is one of '${_FRIJA_BUILD_RELEASE}' or '${_FRIJA_BUILD_DEBUG}', default is '${BUILD_TYPE}'.

  NOTE: Options generate, build, clean, scorch, prepare, and archive may
        ${BOLD}not${CLEAR} be combined with each other.
EOF
    # Print common input file format documentation, see .preamble
    print_file_format_doc

    # Print common exit codes documentation, see .preamble
    print_exit_codes_doc
};


_FRIJA_IS_SOURCED=""
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: This is for informing the sourced scripts that we as a
    # caller is sourced.
    _FRIJA_IS_SOURCED="y"
fi


# Include command line parsing support, common settings and utility functions.
# shellcheck source=./.preamble.bash
source "${METADATATOOLS_HOME}/.preamble.bash"


if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    # When script is sourced BASH_SOURCE[0] differs from $0, otherwise
    # they are equal.
    #
    # Note: We can't test $_FRIJA_IS_SOURCED here since the sourced
    # scripts will set it. Hence we have to repeat the test again.
    return
fi


################################################################################
# Below this point it is safe to for instance call exit; above it
# would cause the users shell to exit if we are sourced...

BUILD_DIR="Build"
ARCHIVE_DIR="Archive"
SYS_NAME=""

DRY_RUN="n"
VERBOSE="n"
DEBUG="n"
COMMAND="-"
autoInFile=$(auto_locate_repo_file)
inFile=""


function parse_command()
{
    if [[ "${COMMAND}" == "-" ]]; then
        COMMAND="${1}"
    else
        print_command_error "${COMMAND}" "${1}"
        exit 2
    fi
}


# Iterate over options in order and nicely split until we see --
while true; do
    case "${1}" in
        -g|--generate)
            parse_command "generate"
            shift  # Move to option argument

            # Check for optional argument
            if [[ -n "${1}" ]]; then
                BUILD_TYPE="${1}"
            fi

            shift  # Move to next option
        ;;
        -b|--build)
            parse_command "build"
            shift  # Move to next option

            # Check for optional argument
            if [[ -n "${1}" ]]; then
                BUILD_TYPE="${1}"
            fi

            shift  # Move to next option
        ;;
        -c|--clean)
            parse_command "clean"
            shift  # Move to next option

            # Required argument
            BUILD_TYPE="${1}"
            shift  # Move to next option
        ;;
        -s|--scorch)
            parse_command "scorch"
            shift  # Move to next option
        ;;
        -p|--prepare)
            parse_command "prepare"
            shift  # Move to next option

            # Required argument
            BUILD_TYPE="${1}"
            shift  # Move to next option
        ;;
        -a|--archive)
            parse_command "archive"
            shift  # Move to next option

            # Required argument
            BUILD_TYPE="${1}"
            shift  # Move to next option
            ;;
        -i|--input)
            ensure_option_not_set "Input file" "${inFile}"
            shift  # Move to option argument
            inFile="${1}"
            ensure_option_argument_set "Input file" "${inFile}"
            shift  # Move to next option
            ;;
        -v|--verbose)
            ensure_boolean_option_not_set "Verbose" "${VERBOSE}"
            VERBOSE="y"
            shift  # Move to next option
            ;;
        -h|--help)
            _frija_subcommand_usage
            exit 0
            ;;
        -d|--debug)
            ensure_boolean_option_not_set "Debug" "${DEBUG}"
            DEBUG="y"
            shift
            ;;
        -D|--dry-run)
            # See .preamble.bash for more information
            set_dry_run
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Internal command line parsing error"
            echo "Current option is '${1}' and rest is"
            echo "$@"
            exit 3
            ;;
    esac
done


# Ensure build type contain a legal value
case "${BUILD_TYPE}" in
    ${_FRIJA_BUILD_RELEASE}|${_FRIJA_BUILD_DEBUG})
        ;;
    *)
        # Illegal value given for the optional TYPE
        msg="TYPE ('${BUILD_TYPE}') may only be one of '${_FRIJA_BUILD_RELEASE}' or '${_FRIJA_BUILD_DEBUG}'."
        print_error "${msg}" 2
        ;;
esac


if [[ "${COMMAND}" == "-" ]]; then
    print_error "Unknown build stage, please use one of the options  '--build', '--clean', etc. to tell me what to do." 2
fi


# Allow explicit command line to specify inFile and override the
# automatically found inFile. This case is only valid when there is a
# single repo-list file.
inFile="${inFile:-${autoInFile}}"
if [[ -z "${inFile}" ]]; then
    print_error "No input file specified." 2
fi

# Append extension AFTER above check; otherwise we would
# not be able to detect if $inFile is empty
inFile="${inFile}${REPO_LIST_EXTENSION}"

SYS_NAME="${inFile##*/}"
SYS_NAME="${SYS_NAME%%${REPO_LIST_EXTENSION}}"


# handle non-option argument
if [[ $# -gt 0 ]]; then
    print_error "Command does not support any arguments." 4
fi


if [[ "${DEBUG}" == "y" ]]; then
    echo "*** ${LINENO}  verbose: ${VERBOSE}, debug: ${DEBUG}, in: ${inFile}" >&2
fi


# Ensure we are within frija folder structure and if so change
# directory to _FRIJA_HOME, otherwise exit with an error message
_frija_locate_frija_home
cd "${_FRIJA_HOME}"


# Iterate over input string ($1) that is assumed to have format
# KEY=MG;VERSION;REPONAME;DELTA,KEY=MG;VERSION;REPONAME;DELTA,...
# which is transformed to format
# -DKEY=MG/REPONAME/VERSION/$2/DELTA -DKEY=MG/REPONAME/VERSION/$2/DELTA ...
#
# Note: $2 is an optional argument and setting DELTA field to '.'
#       effectively makes it optional as well.
#
# Note: The resulting path is canonicalized, i.e. collapse //, . and,
#       .. paths and follow any symlinks.
function dependencies_to_defines()
{
    local input="${1}"
    local suffix="${2:-}"  # Implicitly tell shellcheck it is optional
    local output=""
    local deltapath=""

    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  input: ${input}, suffix: ${suffix}" >&2
    fi

    # Do not do anything if input is an empty string
    if [[ -n "${input}" ]]; then
        # -d set delimiter to ',' instead of newline
        # -r make read to not treat backslash character as an escape character
        # IFS define word separator

        while read -d, -r pair; do
            IFS='=' read -r key value <<<"${pair}"
            IFS=';' read -r mg version name delta <<<"${value}"
            deltapath="${mg}/${name}/${version}"

            if [[ "${DEBUG}" == "y" ]]; then
                echo "*************" >&2
                echo "*** ${LINENO}  deltapath: ${deltapath}" >&2
            fi

            if [[ -n "${delta}" ]]; then
                if [[ -n "${suffix}" ]]; then
                    if [[ "${DEBUG}" == "y" ]]; then
                        echo "*** ${LINENO}  deltapath: ${deltapath}, suffix: ${suffix}" >&2
                    fi
                    deltapath="${deltapath}/${suffix}"
                    if [[ "${DEBUG}" == "y" ]]; then
                        echo "*** ${LINENO}  deltapath: ${deltapath}" >&2
                    fi
                fi

                deltapath="${deltapath}/${delta}"
                if [[ "${DEBUG}" == "y" ]]; then
                    echo "*** ${LINENO}  deltapath: ${deltapath}" >&2
                fi
            fi

            # Canonicalize deltapath
            deltapath=$(readlink -m -n "${deltapath}")
            if [[ "${DEBUG}" == "y" ]]; then
                echo "*** ${LINENO}  deltapath: ${deltapath}" >&2
            fi

            output="${output}-D${key}=${deltapath} "
        done <<<"${input}," # Add ',' to cover single-item case
    fi

    # Return transformed value by using an echo statement
    echo "${output}"
}


####################
# Note: See .preamble.bash for more information about the run function!
####################


################################################################################
# CMAKE
#

function cmake_generate()
{
    local repoFolder="${1}"          # MG/Repo Name/Version
    local target="${2}"
    local dependencies="${3}"
    local repoKind="${4}"            # E.g. app, lib, ...
    local toolDependencies="${5:-}"  # Implicitly tell shellcheck it is optional

    local buildDelta="${BUILD_DIR}/${BUILD_TYPE}"
    local archiveDelta="${ARCHIVE_DIR}/${BUILD_TYPE}"

    local buildFolder="${repoFolder}/${buildDelta}"
    local archiveFolder="${repoFolder}/${archiveDelta}"
    local defines=""
    defines="-DCMAKE_BUILD_TYPE=${BUILD_TYPE}"
    defines="${defines} -DSYSTEM_NAME=${SYS_NAME}"
    defines="${defines} -DBUILD_ID=6666"
    defines="${defines} -DCMAKE_INSTALL_PREFIX=${archiveFolder}"

    defines="${defines} "$(dependencies_to_defines "${dependencies}" "${archiveDelta}")

    local command
    command=("${FIRST}" "${repoFolder}" mkdir --parents "${buildFolder}")
    run "${command[@]}"
    command=("${MIDDLE}" "${repoFolder}" mkdir --parents "${archiveFolder}/include")
    run "${command[@]}"

    # Here we DO want word splitting to happen for ${defines}
    # shellcheck disable=SC2206
    command=("${LAST}" "${repoFolder}" cmake -L -G "${target}" -B "${buildFolder}" -S "${repoFolder}" ${defines})
    run "${command[@]}"
}


function cmake_build()
{
    local repoFolder="${1}"  # MG/Repo Name/Version
    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local command

    command=("${FIRST}" "${repoFolder}" cmake --build "${buildFolder}")
    run "${command[@]}"
    command=("${LAST}" "${repoFolder}" cmake --install "${buildFolder}")
    run "${command[@]}"
}


function cmake_clean()
{
    local repoFolder="${1}"
    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}/${BUILD_TYPE}"
    local command

    command=("${FIRST}" "${repoFolder}" rm -fr "${buildFolder}")
    run "${command[@]}"
    command=("${LAST}" "${repoFolder}" rm -fr "${archiveFolder}")
    run "${command[@]}"
}



function cmake_scorch()
{
    local repoFolder="${1}"
    local buildFolder="${repoFolder}/${BUILD_DIR}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"
    local command

    command=("${FIRST}" "${repoFolder}" rm -fr "${buildFolder}")
    run "${command[@]}"
    command=("${LAST}" "${repoFolder}" rm -fr "${archiveFolder}")
    run "${command[@]}"
}


function cmake_prepare()
{
    local repoFolder="${1}"
    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"
    local command

    command=("${SINGLE}" "${repoFolder}" \
                         cmake --build "${buildFolder}" \
                         --target prepare)
    run "${command[@]}"
}


function cmake_archive()
{
    local repoFolder="${1}"

    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"
    local command

    # Append $tarFile to $TARGET_TAR
    local tarFile="${archiveFolder}/${BUILD_TYPE}.tar"
    command=("${MIDDLE}" "${repoFolder}" \
                         tar --concatenate \
                         "--file=${TARGET_TAR}" "${tarFile}")
    run "${command[@]}"

    # Append to installed.txt
    command=("${MIDDLE}" "${repoFolder}" "${_FRIJA_FOLDER_NAME}/installed.txt" \
                         cat "${archiveFolder}/${BUILD_TYPE}_installed.txt")
    run_with_append "${command[@]}"

    # Append to versions.txt
    command=("${LAST}" "${repoFolder}" "${_FRIJA_FOLDER_NAME}/versions.txt" \
                         cat "${archiveFolder}/${BUILD_TYPE}_versions.txt")
    run_with_append "${command[@]}"
}

