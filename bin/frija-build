################################################################################
# MSBUILD
#

MSBUILD_PROPERTY_FILE="Directory.Build.props"

# Redirects an echo destination to /dev/stdout if DRY_RUN is enabled.
# Note that if no argument is given then /dev/stdout is returned.
function get_echo_destination()
{
    local result=""
    if [[ "${DRY_RUN}" == "y" ]]; then
        result="/dev/stdout"
    elif [[ "${1-}" == "" ]]; then
        result="/dev/stdout"
    else
        result="${1}"
    fi

    echo "${result}"
}


# TODO:
# 1) Remove debug printouts
# 2) Tag Google protoc repo
# 3) Change name of folder
# 4) Compile


# Extract tool definitions used during the build from the given
# dependency. These are then used when for instance the corresponding
# Directory.Build.props file is created.
function extract_tool_dependencies()
{
    local repoPath="${1}"
    local toolDependencies="${2}"

    # Ensure global associative arrays TOOL_COMMANDS, TOOL_LIBS, and
    # TOOL_INCLUDES are empty before we fill them with information.
    declare -gA TOOL_COMMANDS=( )
    declare -gA TOOL_LIBS=( )
    declare -gA TOOL_INCS=( )

    while read -d, -r toolDep; do
        if [[ -z "${toolDep}" ]]; then
            # Guard against empty $toolDep, that is no tool
            # dependencies exist.
            continue;
        fi

        # Parse content of toolDep where fields are split on ';'
        IFS=';' read -r mg version name rest<<<"${toolDep}"

        # shellcheck disable=SC2155
        local repoSubPath=$(make_destination "${mg}" "${name}" "${version}")

        local toolRepoPath="${repoPath}/${repoSubPath}"
        toolRepoPath="${toolRepoPath}/content.tools"

        if [[ ! -r "${toolRepoPath}" ]]; then
            print_error "Could not read from '${toolRepoPath}'; ensure file exists and is readable and/or update ${BOLD}${REPO_LIST_EXTENSION}${CLEAR} file and re-run ${BOLD}frija fetch${CLEAR} or ${BOLD}frija clone${CLEAR}, aborting." 6
        fi

        while read -r os variable path lib include rest; do
            if [[ "${os}" == "#*" || "${os}" != "${OPERATING_SYSTEM}" ]]; then
                continue
            fi

            if [[ "${DEBUG}" == "y" ]]; then
                echo "*** ${LINENO}  os='${os}', variable='${variable}', path='${path}', lib='${lib}', include='${include}', rest='${rest}'" >&2
            fi

            # This IF-statement will also ignore any comment lines as
            # they start with '#' which does not match any of the
            # known operating systems. ;)
            if [[ "${OPERATING_SYSTEM}" == "${os}" ]]; then
                if [[ ! -v "TOOL_COMMANDS[$variable]" ]]; then
                    TOOL_COMMANDS[$variable]="${repoSubPath}/${path}"
                else
                    print_error "Duplicate definitions of tool variable ${BOLD}'${variable}'${CLEAR} found; '${TOOL_COMMANDS[$variable]}' and '${path}', aborting." 6
                fi

                if [[ ! -v "TOOL_LIBS[$variable]" ]]; then
                    TOOL_LIBS[$variable]="${repoSubPath}/${lib}"
                else
                    print_error "Duplicate definitions of tool lib variable ${BOLD}'${variable}'${CLEAR} found; '${TOOL_LIBS[$variable]}' and '${path}', aborting." 6
                fi

                if [[ ! -v "TOOL_INCS[$variable]" ]]; then
                    TOOL_INCS[$variable]="${repoSubPath}/${include}"
                else
                    print_error "Duplicate definitions of tool include variable ${BOLD}'${variable}'${CLEAR} found; '${TOOL_INCLUDES[$variable]}' and '${path}', aborting." 6
                fi
            fi
        done < "${toolRepoPath}"
    done <<<"${toolDependencies}," # Add ',' to cover single-item case
}

declare -r DEPENDENCY_FILE="Dependencies.bash"

function insert_dependency_includes()
{
    local name="${1}"
    local linuxDepPath="${2}"
    local dependencyPath="${3}"  # OS-dependent path

    local dependencyFile="${linuxDepPath}/${DEPENDENCY_FILE}"
    local dependencies=""
    local -r element="${name^^}-INCLUDES"
    local -r INCS="incs"

    if [[ -r "${dependencyFile}" ]]; then
        while read -r os kind deps rest; do
            if [[ "${os}" == "${OPERATING_SYSTEM}" ]]; then
                if [[ "${kind}" == "${INCS}" ]]; then
                    while read -d, -r path; do
                        if [[ -n "${dependencies}" ]]; then
                            dependencies="${dependencies}${OS_PATH_SEPARATOR}"
                        fi

                        # Prepend a separator before we do any
                        # OS-specific transformation of the found
                        # path.
                        path="/${path}"

                        if [[ "${os}" == "${WINDOWS_OS}" ]]; then
                            # Replace all forward slashes with backward
                            # slashes using built-in string replace;
                            # ${foo//what-to-replace/replacement} and
                            # 'what-to-replace' is a '/' and this must be
                            # escaped using a backslash, hence '\/' and
                            # the replacement is a backslash that must be
                            # escaped, hence '\\'.
                            path="${path//\//\\}"
                        fi

                        dependencies="${dependencies}${dependencyPath}${path}"
                    done <<<"${deps}," # Add ',' to cover single-item case
                fi
            fi
        done <"${dependencyFile}"
    fi

    if [[ -n "${dependencies}" ]]; then
        echo "    <${element}>${dependencies}</${element}>"
    fi
}


function msbuild_generate()
{
    local repoFolder="${1}"          # MG/Repo Name/Version
    local parameters="${2}"          # E.g. csproj or sln
    local dependencies="${3}"        # dep-A;dep-B;dep-C;...
    local repoKind="${4}"            # E.g. app, lib, ...
    local toolDependencies="${5:-}"  # Implicitly tell shellcheck it is optional

    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  Dependencies are '${dependencies}'" >&2
    fi

    local destination=""
    destination=$(get_echo_destination "${repoFolder}/${MSBUILD_PROPERTY_FILE}")


    print_message "  Generating ${BOLD}MSBuild${CLEAR} Property file '${BOLD}${destination}${CLEAR}'..."

    # Extract mg, repo name, and version from given path
    IFS='/' read -r mg name version<<<"${repoFolder}"

    # Save repo name since the variables 'mg', 'name', and 'version'
    # will be overwritten several times.
    local repoName="${name}"

    local repoPath=""
    local linuxRepoPath=""
    local currentPath=""
    local linuxCurrentPath=""

    if [[ "${OPERATING_SYSTEM}" == "${WINDOWS_OS}" ]]; then
        # Get Windows variant of current working directory
        currentPath=$(pwd -W)
        linuxCurrentPath=$(pwd)

        repoPath="${currentPath}/${repoFolder}"
        # Replace all forward slashes with backward slashes using
        # built-in string replace; ${foo//what-to-replace/replacement}
        # and 'what-to-replace' is a '/' and this must be escaped
        # using a backslash, hence '\/' and the replacement is a
        # backslash that must be escaped, hence '\\'.
        repoPath="${repoPath//\//\\}"
    else
        currentPath=$(pwd)
        linuxCurrentPath="${currentPath}"
        repoPath="${currentPath}/${repoFolder}"
    fi
    linuxRepoPath="${linuxCurrentPath}/${repoFolder}"


    # Force overwrite of any existing file
    cat <<EOF >| "${destination}"
<?xml version="1.0" encoding="utf-8" ?>
<!--
  ***************************************
  This is a generated file - Do Not Edit!
  ***************************************
-->
<Project>
  <ImportGroup Label="Shared">
    <Import Condition="Exists('SolutionProperties.props')"
            Project="SolutionProperties.props" />
  </ImportGroup>

  <PropertyGroup>
    <!--
        Force target platform to x64.
    -->
    <Platform>x64</Platform>

EOF

    # Append dependencies as properties
    {
        local dependencyRootPath=""
        local dependencyBuildPath=""
        if [[ -n "${dependencies}" ]]; then
            echo "    <!--"
            echo "        Dependencies to Build folder in other repos represented as"
            echo "        properties named using repo-name in all uppercase. Root of"
            echo "        these repos get properties with the same name with an additional"
            echo "        \"-ROOT\" suffix. Other kinds of paths within a repo get"
            echo "        corresponding suffixes, e.g. \"-INCLUDES\" for include file path"
            echo "        needed when building a C++ project."
            echo "    -->"
            while read -d, -r dep; do
                IFS=';' read -r mg version name rest<<<"${dep}"
                dependencyRootPath="${currentPath}/${mg}/${name}/${version}"
                linuxDepRootPath="${linuxCurrentPath}/${mg}/${name}/${version}"
                dependencyBuildPath="${dependencyRootPath}/Build"
                if [[ "${OPERATING_SYSTEM}" == "Windows" ]]; then
                    dependencyRootPath="${dependencyRootPath//\//\\}"
                    dependencyBuildPath="${dependencyBuildPath//\//\\}"
                fi

                echo "    <${name^^}>${dependencyBuildPath}</${name^^}>"
                echo "    <${name^^}-ROOT>${dependencyRootPath}</${name^^}-ROOT>"
                # For C++ projects paths to include files in other
                # repos might need to be inserted.
                insert_dependency_includes "${name}" \
                                           "${linuxDepRootPath}" \
                                           "${dependencyRootPath}"
            done <<<"${dependencies}," # Add ',' to cover single-item case
            echo ""
            echo ""
        fi
    } >> "${destination}"

    local branchName=""
    branchName=$(get_branch_name "${linuxRepoPath}")

    cat <<EOF >> "${destination}"
    <!--
        Known kinds of repos as well as kind assigned to current repo.
    -->
    <FrijaAppKind>${APP_REPO}</FrijaAppKind>
    <FrijaLibKind>${LIB_REPO}</FrijaLibKind>
    <FrijaInterfaceKind>${INF_REPO}</FrijaInterfaceKind>
    <FrijaToolKind>${TOL_REPO}</FrijaToolKind>
    <FrijaPluginKind>${PLG_REPO}</FrijaPluginKind>
    <FrijaDataKind>${DTA_REPO}</FrijaDataKind>
    <FrijaRepoKind>${repoKind}</FrijaRepoKind>


EOF

    # Extract tool definitions used during the build from the given
    # dependency. As a side effect TOOL_COMMANDS, TOOL_LIBS, and
    # TOOL_INCLUDES are updated based on content of $toolDependencies
    # or cleared if corresponding is empty.
    extract_tool_dependencies "${linuxCurrentPath}" "${toolDependencies}"

    # Assume that having a tool key is a precondition for having libs.
    local toolKeys="${!TOOL_COMMANDS[*]}"
    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  toolKeys='${toolKeys}'" >&2
    fi

    if [[ -n "${toolKeys}" ]]; then
        {
            echo "    <!--"
            echo "        Dependencies to Build Tools represented as properties."
            echo "    -->"
            # For every key in the associative array $TOOL_COMMANDS...
            local toolPath=""
            for key in $toolKeys; do
                toolPath="${currentPath}/${TOOL_COMMANDS[$key]}"
                toolPath="${toolPath//\//\\}"

                echo "    <${key}>${toolPath}</${key}>"

                toolLib="${TOOL_LIBS[$key]}"
                if [[ -n "${toolLib}" ]]; then
                    toolLib="${currentPath}/${toolLib}"
                    toolLib="${toolLib//\//\\}"
                    echo "    <${key}LibPath>${toolLib}</${key}LibPath>"
                fi
            done
            echo ""
            echo ""
        } >> "${destination}"
    fi

    # Build include path for tools
    local toolIncPath=""
    local toolIncKeys="${!TOOL_INCS[*]}"
    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  toolIncKeys='${toolIncKeys}'" >&2
    fi

    {
        echo "    <!--"
        echo "        Include paths for Build Tools as property."
        echo "    -->"
    } >> "${destination}"

    if [[ -n "${toolIncKeys}" ]]; then
        # For every key in the associative array $TOOL_INCS...
        for key in $toolIncKeys; do
            if [[ -n "${toolIncPath}" ]]; then
                toolIncPath="${toolIncPath}${OS_PATH_SEPARATOR}"
            fi
            toolIncPath="${toolIncPath}${currentPath}/${TOOL_INCS[$key]}"
        done
        toolIncPath="${toolIncPath//\//\\}"
    fi

    # shellcheck disable=SC2129
    {
        echo "    <ToolIncludePaths>${toolIncPath}</ToolIncludePaths>"
        echo ""
        echo ""
    } >> "${destination}"

    # Append rest of XML to output file.
    #
    # NOTE: All backslashes must be escaped due to that we also want
    # to expand variables, e.g. $repoPath and so on.
    #
    # shellcheck disable=SC2129
    cat <<EOF >> "${destination}"
    <!--
        Redirect where build results ends up
    -->
    <FrijaRoot>${repoPath}</FrijaRoot>
    <FrijaBuildRoot>${repoPath}\\Build</FrijaBuildRoot>
    <FrijaArchiveRoot>${repoPath}\\Archive</FrijaArchiveRoot>

    <BaseIntermediateOutputPath>${repoPath}\\Build\\obj\\\$(AssemblyName)</BaseIntermediateOutputPath>
    <IntDir>\$(FrijaBuildRoot)\\Intermediate\\\$(Platform)\\\$(Configuration)\\</IntDir>
    <OutDir>\$(FrijaBuildRoot)\\\$(Configuration)\\</OutDir>
    <OutputPath>\$(FrijaBuildRoot)\\\$(Configuration)\\</OutputPath>


    <!--
        Where generated source code from for instance Google proto-files
        are placed. Also used by clean target.
    -->
    <GeneratedPath>\$(FrijaBuildRoot)\\${GENERATED}\\</GeneratedPath>


    <!--
        Properties used by prepare and clean targets.
    -->
    <FrijaLinuxArchiveRoot>${linuxRepoPath}/Archive</FrijaLinuxArchiveRoot>
    <VersionsFile>\$(FrijaArchiveRoot)\\\$(Configuration)_versions.txt</VersionsFile>
    <TarPrefix>${SYS_NAME}_${branchName}/6666/\$(CSCI)/\$(Configuration)/\$(AssemblyName)</TarPrefix>
    <TarTransform>s|^\$(Configuration)|\$(TarPrefix)|</TarTransform>
    <VollaCommandRoot>${METADATATOOLS_HOME}</VollaCommandRoot>
    <SystemName>${SYS_NAME}</SystemName>
  </PropertyGroup>


  <!--

      This item group contain dependencies to all DLLs used directly
      and indirectly by projects we depend on, i.e. secondary,
      tertiary, etc. dependency chains (DLLs that in turn depends on
      DLLs that depends on DLLs and so on).

     If it is empty it should be because there are no repos we
     directly depend on.
  -->
  <ItemGroup>
EOF

    # Append instructions to copy DLLs from projects in other repos we
    # depend on.
    #
    # NOTE: All backslashes must be escaped. This is also true for all
    # $-characters since they should be written to the output file.
    # Otherwise the sequence '$(...)' would have triggered Bash to try
    # to execute whatever is within the parentheses, which is not what
    # we want.
    #
    # NOTE: The sequence ${...} is intentionally NOT escaped since it
    # triggers an expansion of a Bash variable, e.g. '${name^^}' which
    # expands the variable 'name' in all uppercase.
    {
        if [[ -n "${dependencies}" ]]; then
            declare -i counter
            counter=1
            while read -d, -r dep; do
                IFS=';' read -r mg version name rest<<<"${dep}"

                # Ensure empty separator line is ONLY written on all
                # iterations EXCEPT first.
                ((counter > 1)) && echo ""
                ((counter++))

                echo "    <None Include=\"\$(${name^^})\\\$(Configuration)\\*.dll\">"
                echo "      <Link>%(Filename)%(Extension)</Link>"
                echo "      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>"
                echo "    </None>"
                echo "    <None Include=\"\$(${name^^})\\\$(Configuration)\\*.pdb\">"
                echo "      <Link>%(Filename)%(Extension)</Link>"
                echo "      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>"
                echo "    </None>"
            done <<<"${dependencies}," # Add ',' to cover single-item case
        fi
    } >> "${destination}"


    # Append rest of XML to output file.
    #
    # NOTE: All backslashes must be escaped. This is also true for all
    # $-characters since they should be written to the output file.
    # Otherwise the sequence '$(...)' would have triggered Bash to try
    # to execute whatever is within the parentheses, which is not what
    # we want.
    cat <<EOF >> "${destination}"
  </ItemGroup>


  <!--
      Common compilation options for all Release builds of C# projects.
  -->
  <PropertyGroup Condition="'\$(Configuration)' == 'Release'">
    <PathMap>\$(BaseIntermediateOutputPath)\\\$(Platform)\\\$(Configuration)=.</PathMap>
  </PropertyGroup>


  <!--
      Common compilation and linking options for all Release builds of
      C++ projects.
  -->
  <ItemDefinitionGroup Condition="'\$(Configuration)' == 'Release'">
    <Link>
      <!--
          Store only filename of PDB file within .EXE/.DLL for
          deterministic builds.
      -->
      <AdditionalOptions>/PDBALTPATH:%_PDB% %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>


  <!--
       Default empty implementation of prepare target.
  -->
  <Target Name="prepare" />


  <!--
       Enhance clean target so it becomes a deep-clean target.
  -->
  <Target Name="CleanBuildFolder"
          BeforeTargets="CoreClean">
    <RemoveDir Condition="Exists(\$(OutputPath))"
               Directories="\$(OutputPath)"
               ContinueOnError="true" />
    <RemoveDir Condition="Exists(\$(BaseIntermediateOutputPath))"
               Directories="\$(BaseIntermediateOutputPath)"
               ContinueOnError="true" />
    <RemoveDir Condition="Exists(\$(IntDir))"
               Directories="\$(IntDir)"
               ContinueOnError="true" />
    <RemoveDir Condition="Exists(\$(GeneratedPath))"
               Directories="\$(GeneratedPath)"
               ContinueOnError="true" />
  </Target>
</Project>
EOF


    if [[ -r "${repoFolder}/NuGet.config" ]]; then
        local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"
        local inputFile="${repoName}.${type}"
        local command
        command=("${SINGLE}" "  Restoring NuGet packages..." \
                             MSBuild.exe \
                             "-t:restore" \
                             "-p:RestorePackagesConfig=true" \
                             "${repoFolder}/${inputFile}")
        run "${command[@]}"
        print_message "    Done!"
    else
        print_message "  No NuGet packages to restore! (NuGet.config file does not exist)"
    fi
}


# Build a Visual Studio solution or project
function msbuild_build()
{
    local repoFolder="${1}"  # MG/Repo Name/Version
    local parameters="${2}"  # E.g. csproj or sln

    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"

    # Extract mg, repo name, and version from given path
    IFS='/' read -r mg name version<<<"${repoFolder}"
    local inputFile="${name}.${type}"

    local command
    command=("${SINGLE}" "${repoFolder}" \
                         MSBuild.exe \
                         "-warnaserror" \
                         "-p:Configuration=${BUILD_TYPE}" \
                         "${repoFolder}/${inputFile}")
    run "${command[@]}"
}


function msbuild_clean()
{
    local repoFolder="${1}"
    local parameters="${2}"  # E.g. csproj or sln

    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}/${BUILD_TYPE}"
    local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"

    # Extract mg, repo name, and version from given path
    IFS='/' read -r mg name version<<<"${repoFolder}"
    local inputFile="${name}.${type}"

    local command
    command=("${FIRST}" "${repoFolder}" rm -fr "${buildFolder}")
    run "${command[@]}"

    command=("${MIDDLE}" "${repoFolder}" rm -fr "${archiveFolder}")
    run "${command[@]}"

    command=("${LAST}" "${repoFolder}" \
                         MSBuild.exe \
                         "-p:Configuration=${BUILD_TYPE}" \
                         "-target:Clean" \
                         "${repoFolder}/${inputFile}")
    run "${command[@]}"
}


function msbuild_scorch()
{
    local repoFolder="${1}"
    local objFolder="${repoFolder}/${BUILD_DIR}/obj"
    local propertyFile="${repoFolder}/${MSBUILD_PROPERTY_FILE}"
    local nugetFolder="${repoFolder}/Packages"
    local command

    # Start with a normal clean operation
    msbuild_clean "${repoFolder}"

    command=("${FIRST}" "${repoFolder}" rm -fr "${objFolder}")
    run "${command[@]}"

    command=("${MIDDLE}" "${repoFolder}" rm -fr "${nugetFolder}")
    run "${command[@]}"

    command=("${LAST}" "${repoFolder}" rm -f "${propertyFile}")
    run "${command[@]}"
}


function msbuild_prepare()
{
    local repoFolder="${1}"  # MG/Repo Name/Version
    local parameters="${2}"  # E.g. csproj or sln

    local buildFolder="${repoFolder}/${BUILD_DIR}/${BUILD_TYPE}"
    local archiveFolder="${repoFolder}/${ARCHIVE_DIR}"
    local type="${parameters%%;*}"  # "csproj;smthng" ==> "csproj"

    # Extract mg, repo name, and version from given path
    IFS='/' read -r mg name version<<<"${repoFolder}"
    local inputFile="${name}.${type}"

    local command
    command=("${SINGLE}" "${repoFolder}" \
                         MSBuild.exe \
                         "-warnaserror" \
                         "-p:Configuration=${BUILD_TYPE}" \
                         "-target:prepare" \
                         "${repoFolder}/${inputFile}")
    run "${command[@]}"
}


function msbuild_archive()
{
    local repoFolder="${1}"

    local objFolder="${repoFolder}/${BUILD_DIR}/obj"
    local propertyFile="${repoFolder}/${MSBUILD_PROPERTY_FILE}"
    local nugetFolder="${repoFolder}/Packages"
    local command

    echo "${BOLD}Placeholder for msbuild_archive!${CLEAR}"
}

#
# MSBUILD
################################################################################


function generate_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"
    local dependencies="${3}"
    local repoKind="${4}"       # E.g. app, lib, ...
    local toolDependencies="${5:-}"

    local msg

    case "${tool}" in
        cmake)
            cmake_generate "${destination}" "${parameters}" \
                           "${dependencies}" "${repoKind}" \
                           "${toolDependencies}"
            ;;
        msbuild)
            msbuild_generate "${destination}" "${parameters}" \
                             "${dependencies}" "${repoKind}" \
                             "${toolDependencies}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


function build_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_build "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_build "${destination}" "${parameters}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


function clean_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_clean "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_clean "${destination}" "${parameters}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


function scorch_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_scorch "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_scorch "${destination}" "${parameters}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


function prepare_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_prepare "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_prepare "${destination}" "${parameters}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


function archive_dispatch()
{
    # Tool may contain multiple "sub-fields" separated by ';', for
    # instance the cmake tool must know which build system it should
    # generate for and this would be expressed as e.g. "cmake;Ninja"
    local tool="${1%%;*}"       # $1="cmake;Ninja;Foo" gives "cmake"
    local parameters="${1#*;}"  # $1="cmake;Ninja;Foo" gives "Ninja;foo"
    local destination="${2}"

    local msg

    case "${tool}" in
        cmake)
            cmake_archive "${destination}" "${parameters}"
            ;;
        msbuild)
            msbuild_archive "${destination}" "${parameters}"
            ;;
        *)
            msg="Unsupported build tool '${tool}' for '${destination}', aborting."
            print_error "${msg}" 6
    esac
}


########
# Prepare before executing user command

case "${COMMAND}" in
    archive)
        # Create an empty TAR file in $_FRIJA_FOLDER_NAME. This folder
        # is automatically cleared at exit.
        buildId=$(date +%Y%V%u.%H%M%S)
        TARGET_TAR="${_FRIJA_FOLDER_NAME}/${SYS_NAME}"
        TARGET_TAR="${TARGET_TAR}__${_FRIJA_JIRA}"
        TARGET_TAR="${TARGET_TAR}__${buildId}"

        if [[ "${BUILD_TYPE}" == "Debug" ]]; then
            TARGET_TAR="${TARGET_TAR}-${BUILD_TYPE}"
        fi
        TARGET_TAR="${TARGET_TAR}.tar"

        if [[ ! -e "${TARGET_TAR}" ]]; then
            command=("${SINGLE}" "" \
                                tar --create \
                                "--file=${TARGET_TAR}" \
                                "--files-from=/dev/null")
            run "${command[@]}"
        fi
        ;;
esac


########
# Iterate over the lines in the input file and act on each line
# depending on SOURCE field.

print_message "Reading from ${inFile} and building repos..."
print_separator

builtReposFlag=""
commandName="undefined"
declare -a skippedOperatingSystems=()
declare -A uniqueSkippedOperatingSystems=()

# -r make read to not treat backslash character as an escape character
while read -r os source mg version uri repoKind tool dependencies toolDependencies rest; do
    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  os='${os}', source='${source}', version='${version}', uri='${uri}', repotype='${repoKind}', tool='${tool}', dependencies='${dependencies}', rest='${rest}'" >&2
    fi

    if [[ "${os}" != "${OPERATING_SYSTEM}" ]]; then
        # Skip to next entry since target OS does not match current OS
        continue
    fi

    if [[ "${tool}" == "none" ]]; then
        # Skip repos that does not have any build tool
        continue
    fi

    if [[ "${dependencies}" == "none" ]]; then
        # When there are no dependencies, set it to an empty string.
        dependencies=""
    fi

    if [[ "${toolDependencies}" == "none" ]]; then
        # When there are no tool dependencies, set it to an empty string.
        toolDependencies=""
    fi


    case "${source}" in
        git)
            if [[ "${uri}" =~ ${GIT_REPO_PATTERN} ]]; then
                repoName="${BASH_REMATCH[2]:-${BASH_REMATCH[1]}}"
                destination="${mg}/${repoName}/${version}"
            else
                print_error "Unsupported ${BOLD}Git repo URI path${CLEAR}: URI is '${uri}' and pattern is '${GIT_REPO_PATTERN}', aborting." 6
            fi
            ;;
        *)
            print_error "Unsupported SOURCE: '${source}' for '${uri}', aborting." 6
            ;;
    esac

    if [[ "${DEBUG}" == "y" ]]; then
        echo "*** ${LINENO}  repoName='${repoName}', destination='${destination}'" >&2
    fi


    case "${COMMAND}" in
        generate)
            print_message "${BOLD}Generating${CLEAR} build-files for ${BOLD}${BUILD_TYPE,,}${CLEAR} in ${BOLD}${destination}${CLEAR} using system name '${BOLD}${SYS_NAME}${CLEAR}'..."
            if [[ "${DEBUG}" == "y" ]]; then
                echo "*** ${LINENO}  generate ('${tool}' '${BUILD_TYPE}' '${destination}' '${dependencies}')" >&2
            fi
            generate_dispatch "${tool}" "${destination}" "${dependencies}" \
                              "${repoKind}" "${toolDependencies}"
            commandName="generated"
            ;;

        build)
            print_message "${BOLD}Building${CLEAR} for ${BOLD}${BUILD_TYPE,,}${CLEAR} in ${BOLD}${destination}${CLEAR}..."
            if [[ "${DEBUG}" == "y" ]]; then
                echo "*** ${LINENO}  build ('${tool}' '${BUILD_TYPE}' '${destination}')" >&2
            fi
            build_dispatch "${tool}" "${destination}"
            commandName="built"
            ;;

        clean)
            print_message "${BOLD}Cleaning${CLEAR} build artifacts in ${BOLD}${BUILD_TYPE,,}${CLEAR} in ${BOLD}${destination}${CLEAR}..."
            if [[ "${DEBUG}" == "y" ]]; then
                echo "*** ${LINENO}  clean ('${tool}' '${BUILD_TYPE}' '${destination}')" >&2
            fi
            clean_dispatch "${tool}" "${destination}"
            commandName="cleaned"
            ;;

        scorch)
            print_message "${BOLD}Scorching${CLEAR} all build artifacts in ${BOLD}${destination}${CLEAR}..."
            if [[ "${DEBUG}" == "y" ]]; then
                echo "*** ${LINENO}  clean ('${tool}' '${BUILD_TYPE}' '${destination}')" >&2
            fi
            scorch_dispatch "${tool}" "${destination}"
            commandName="scorched"
            ;;

        prepare)
            if [[ "${repoKind}" == "${TOL_REPO}" ]]; then
                print_message "${BOLD}Skipping${CLEAR} ${COMMAND} of ${repoKind} repo ${BOLD}${destination}${CLEAR}..."
                continue
            else
                print_message "${BOLD}Preparing${CLEAR} creation of installation archive in ${BOLD}${destination}${CLEAR}..."
                prepare_dispatch "${tool}" "${destination}"
            fi
            commandName="prepared"
            ;;

        archive)
            if [[ "${repoKind}" == "${TOL_REPO}" ]]; then
                print_message "${BOLD}Skipping${CLEAR} ${COMMAND} of ${repoKind} repo ${BOLD}${destination}${CLEAR}..."
                continue
            else
                print_message "${BOLD}Creating${CLEAR} installation archive for ${BOLD}${destination}${CLEAR}..."
                archive_dispatch "${tool}" "${destination}"
            fi
            commandName="archived"
            ;;
        *)
            print_error "Unknown command '${COMMAND}'." 7
    esac

    # If we reach this point, at least one repo has been processed
    builtReposFlag="y"
done < "${inFile}"


# Operate on the whole set of repos after the build "operation"
case "${COMMAND}" in
    archive)
        command=("${FIRST}" "" tar "--directory=${_FRIJA_FOLDER_NAME}" \
                            --append \
                            "--file=${TARGET_TAR}" \
                             "versions.txt" \
                             "installed.txt")
        run "${command[@]}"

        command=("${MIDDLE}" "" gzip --force "${TARGET_TAR}")
        run "${command[@]}"

        command=("${LAST}" "" mv "${TARGET_TAR}.gz" ".")
        run "${command[@]}"
        ;;
esac


if [[ -z "${builtReposFlag}" ]]; then
    # Make $skippedOperatingSystems unique by using an associative
    # array (hashmap)
    for i in "${skippedOperatingSystems[@]}"; do
        uniqueSkippedOperatingSystems["${i}"]=1
    done
    print_message ""
    print_message "====================="
    print_message "${BOLD}No repos were ${commandName}!${CLEAR}"
    print_message "====================="
    print_message ""
    print_message "Current OS is ${BOLD}${OPERATING_SYSTEM}${CLEAR} and all entries in"
    print_message "  ${BOLD}${inFile}${CLEAR}"
    print_message "required the following operating system$(plural ${#skippedOperatingSystems[@]})${BOLD}"
    printf '  %s\n' "${!uniqueSkippedOperatingSystems[@]}"
    print_message "${CLEAR}"
    print_message "Are you sure you are using an input file designed for your OS?"
fi
