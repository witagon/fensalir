conflict  gnumake
append    PATH  "/sw/pd/pkg/make/4.4/Linux-x86_64/bin"

# Tools used from within Makefile
set       AR      "/bin/ar"
set       CP      "/bin/cp"
set       LN      "/bin/ln"
set       MKDIR   "/bin/mkdir"
set       MV      "/bin/mv"
set       RM      "/bin/rm"
set       SED     "/bin/sed"
set       TOUCH   "/bin/touch"
