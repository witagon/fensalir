# Function that remove Emacs backup and auto-save files recursively
function expunge()
{
    # Find all files recursively who's name ends with '~', a sequence
    # number like '.~1~', or is enclosed with '#' like '#fnord#'. The
    # two former variants are backups created by emacs when saving a
    # new version of a buffer and the latter is an Emacs auto-save
    # file.
    find "${1:-.}" \
         -depth \
         -type f \( -name "*~" -o -name "*.~?*~" -o -name "#*#" \) \
         -print \
         -delete
}


